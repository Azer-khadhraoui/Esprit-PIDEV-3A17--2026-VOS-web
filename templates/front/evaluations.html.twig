{% extends 'front/base_front.html.twig' %}
{% block title %}Mes Évaluations{% endblock %}
{% block hero_title %}Mes Évaluations{% endblock %}
{% block hero_subtitle %}Consultez tous vos résultats d'entretiens{% endblock %}

{% block body %}

{% if evaluations|length > 0 %}
<div class="row g-3">
    {% for eval in evaluations %}
    <div class="col-md-6">
        <div class="front-card">
            <div style="padding:20px">
                {# Header #}
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div style="font-size:0.75rem;color:#8c98a4;text-transform:uppercase;letter-spacing:0.5px">
                            Évaluation #{{ eval.id }}
                        </div>
                        {% if eval.entretien %}
                        <div style="font-size:0.9rem;font-weight:700;color:#1a1a2e;margin-top:2px">
                            Entretien #{{ eval.entretien.id }}
                            {% if eval.entretien.dateEntretien %}
                                — {{ eval.entretien.dateEntretien|date('d/m/Y') }}
                            {% endif %}
                        </div>
                        {% endif %}
                    </div>
                    {% set d = eval.decision|lower %}
                    <span class="badge-s {% if 'accept' in d %}b-accepte{% elseif 'refus' in d %}b-refuse{% else %}b-attente{% endif %}">
                        {{ eval.decision ?? '-' }}
                    </span>
                </div>

                {# Score + Note #}
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div style="flex:1">
                        <div style="font-size:0.78rem;color:#8c98a4;margin-bottom:4px">Score</div>
                        <div class="d-flex align-items-center gap-2">
                            <div style="flex:1;height:8px;background:#f0f2f5;border-radius:4px;overflow:hidden">
                                <div style="width:{{ eval.scoreTest ?? 0 }}%;height:100%;background:{% if (eval.scoreTest ?? 0) >= 75 %}#06d6a0{% elseif (eval.scoreTest ?? 0) >= 50 %}#fb8500{% else %}#f72585{% endif %};border-radius:4px"></div>
                            </div>
                            <strong style="font-size:0.9rem;color:#1a1a2e;min-width:32px">{{ eval.scoreTest ?? '-' }}</strong>
                        </div>
                    </div>
                    <div class="text-end">
                        <div style="font-size:0.78rem;color:#8c98a4;margin-bottom:4px">Note</div>
                        {% for i in 1..5 %}
                            <i class="fas fa-star" style="font-size:0.75rem;color:{% if i <= (eval.noteEntretien ?? 0) %}#fb8500{% else %}#dee2e6{% endif %}"></i>
                        {% endfor %}
                    </div>
                </div>

                {# Compétences mini #}
                <div class="row g-1 mb-3">
                    {% set comps = [
                        {'l': 'Tech', 'v': eval.competencesTechniques,       'c': '#4361ee'},
                        {'l': 'Comp', 'v': eval.competencesComportementales, 'c': '#7209b7'},
                        {'l': 'Com',  'v': eval.communication,               'c': '#4cc9f0'},
                        {'l': 'Mot',  'v': eval.motivation,                  'c': '#06d6a0'},
                        {'l': 'Exp',  'v': eval.experience,                  'c': '#fb8500'},
                    ] %}
                    {% for c in comps %}
                    <div class="col">
                        <div style="text-align:center;background:#fafbfc;border-radius:8px;padding:6px 4px">
                            <div style="font-size:1rem;font-weight:800;color:{{ c.c }}">{{ c.v ?? 0 }}</div>
                            <div style="font-size:0.68rem;color:#8c98a4">{{ c.l }}</div>
                        </div>
                    </div>
                    {% endfor %}
                </div>

                {# Commentaire #}
                {% if eval.commentaire %}
                <div style="font-size:0.82rem;color:#6c757d;background:#f8f9ff;padding:10px 14px;border-radius:8px;border-left:3px solid #4361ee;line-height:1.5">
                    "{{ eval.commentaire|slice(0, 120) }}{% if eval.commentaire|length > 120 %}...{% endif %}"
                </div>
                {% endif %}

                {% if eval.entretien %}
                <div class="mt-3 text-end">
                    <a href="{{ path('app_front_entretien_show', {'id': eval.entretien.id}) }}" class="btn-detail">
                        <i class="fas fa-eye me-1"></i>Voir l'entretien
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% else %}
<div class="front-card">
    <div class="empty-state">
        <i class="fas fa-star"></i>
        <h3>Aucune évaluation</h3>
        <p>Vos résultats d'entretiens apparaîtront ici.</p>
    </div>
</div>
{% endif %}

{% endblock %}

{% extends 'front/base_front.html.twig' %}
{% block title %}Mes Entretiens{% endblock %}
{% block hero_title %}Mes Entretiens{% endblock %}
{% block hero_subtitle %}Consultez tous vos entretiens planifiés et passés{% endblock %}

{% block body %}

{# ── FILTRES ── #}
<div class="front-card mb-4" style="overflow:visible">
    <div style="padding:16px 20px">
        <form method="get" action="{{ path('app_front_entretiens') }}">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text" style="background:#f5f7fa;border:1.5px solid #e0e6ed;border-right:0">
                            <i class="fas fa-search text-muted" style="font-size:0.8rem"></i>
                        </span>
                        <input type="text" name="search" value="{{ search }}"
                               class="form-control" style="border:1.5px solid #e0e6ed;border-left:0"
                               placeholder="Rechercher lieu, type...">
                    </div>
                </div>
                <div class="col-md-2">
                    <select name="type" class="form-select" style="border:1.5px solid #e0e6ed">
                        <option value="">Tous les types</option>
                        <option value="RH"        {% if type == 'RH' %}selected{% endif %}>RH</option>
                        <option value="TECHNIQUE" {% if type == 'TECHNIQUE' %}selected{% endif %}>TECHNIQUE</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="statut" class="form-select" style="border:1.5px solid #e0e6ed">
                        <option value="">Tous les statuts</option>
                        <option value="Planifié"   {% if statut == 'Planifié' %}selected{% endif %}>Planifié</option>
                        <option value="Terminé"    {% if statut == 'Terminé' %}selected{% endif %}>Terminé</option>
                        <option value="Annulé"     {% if statut == 'Annulé' %}selected{% endif %}>Annulé</option>
                        <option value="En attente" {% if statut == 'En attente' %}selected{% endif %}>En attente</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" style="background:#4361ee;color:white;border:none;padding:9px 18px;border-radius:8px;font-weight:600;font-size:0.88rem">
                        <i class="fas fa-search me-1"></i> Filtrer
                    </button>
                    <a href="{{ path('app_front_entretiens') }}" style="background:#f0f2f5;color:#6c757d;border:none;padding:9px 12px;border-radius:8px;font-size:0.88rem;text-decoration:none;display:inline-flex;align-items:center">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

{# ── LISTE ── #}
{% if entretiens|length > 0 %}
<div class="row g-3">
    {% for e in entretiens %}
    <div class="col-md-6 col-lg-4">
        <div class="front-card h-100" style="transition:transform 0.2s" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
            <div style="padding:20px">
                {# Header carte #}
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div style="font-size:0.75rem;color:#8c98a4;text-transform:uppercase;letter-spacing:0.5px">Entretien #{{ e.id }}</div>
                        <div style="font-size:1.1rem;font-weight:800;color:#1a1a2e;margin-top:2px">
                            {{ e.dateEntretien ? e.dateEntretien|date('d/m/Y') : '-' }}
                        </div>
                    </div>
                    <span class="badge-s {{ e.typeEntretien == 'RH' ? 'b-rh' : 'b-technique' }}">
                        {{ e.typeEntretien ?? '-' }}
                    </span>
                </div>

                {# Infos #}
                <div class="d-flex flex-column gap-2 mb-3" style="font-size:0.85rem">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-clock" style="color:#8c98a4;width:14px"></i>
                        <span style="color:#495057">{{ e.heureEntretien ? e.heureEntretien|date('H:i') : '-' }}</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-map-marker-alt" style="color:#8c98a4;width:14px"></i>
                        <span style="color:#495057">{{ e.lieu ?? '-' }}</span>
                        {% if e.lienReunion and 'en ligne' in (e.lieu|lower) %}
                            <a href="{{ e.lienReunion }}" target="_blank" style="color:#4361ee;font-size:0.78rem;text-decoration:none">
                                <i class="fas fa-video"></i> Rejoindre
                            </a>
                        {% endif %}
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-clipboard" style="color:#8c98a4;width:14px"></i>
                        <span style="color:#495057">{{ e.typeTest ?? '-' }}</span>
                    </div>
                </div>

                {# Statut + évaluation #}
                <div class="d-flex justify-content-between align-items-center pt-2" style="border-top:1px solid #f0f2f5">
                    {% set s = e.statutEntretien|lower %}
                    <span class="badge-s {% if 'termin' in s %}b-termine{% elseif 'planifi' in s %}b-planifie{% elseif 'annul' in s %}b-annule{% else %}b-attente{% endif %}">
                        {{ e.statutEntretien ? e.statutEntretien|upper : '-' }}
                    </span>
                    <a href="{{ path('app_front_entretien_show', {'id': e.id}) }}" class="btn-detail">
                        Voir détail <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% else %}
<div class="front-card">
    <div class="empty-state">
        <i class="fas fa-briefcase"></i>
        <h3>Aucun entretien trouvé</h3>
        <p>{% if search or type or statut %}Modifiez vos filtres pour voir plus de résultats.{% else %}Vous n'avez pas encore d'entretiens planifiés.{% endif %}</p>
    </div>
</div>
{% endif %}

{% endblock %}

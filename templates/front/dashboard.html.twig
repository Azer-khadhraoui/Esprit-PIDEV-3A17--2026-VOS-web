{% extends 'front/base_front.html.twig' %}
{% block title %}Tableau de bord{% endblock %}
{% block hero_title %}Bonjour, Candidat 👋{% endblock %}
{% block hero_subtitle %}Voici un aperçu de votre parcours de recrutement{% endblock %}

{% block body %}

{# ── KPI CARDS ── #}
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="kpi-card blue">
            <div class="k-icon"><i class="fas fa-briefcase"></i></div>
            <div class="k-label">Mes Entretiens</div>
            <div class="k-value">{{ totalEntretiens }}</div>
            <div class="k-sub">Au total</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="kpi-card green">
            <div class="k-icon"><i class="fas fa-check-circle"></i></div>
            <div class="k-label">Terminés</div>
            <div class="k-value">{{ termines }}</div>
            <div class="k-sub">Entretiens clôturés</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="kpi-card orange">
            <div class="k-icon"><i class="fas fa-clock"></i></div>
            <div class="k-label">À venir</div>
            <div class="k-value">{{ planifies }}</div>
            <div class="k-sub">Entretiens planifiés</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="kpi-card purple">
            <div class="k-icon"><i class="fas fa-star"></i></div>
            <div class="k-label">Évaluations</div>
            <div class="k-value">{{ totalEvals }}</div>
            <div class="k-sub">Rapports reçus</div>
        </div>
    </div>
</div>

<div class="row g-3">
    {# ── Derniers entretiens ── #}
    <div class="col-md-7">
        <div class="front-card">
            <div class="front-card-header">
                <div>
                    <h2><i class="fas fa-briefcase me-2" style="color:#4361ee"></i>Derniers entretiens</h2>
                    <p>Vos 5 entretiens les plus récents</p>
                </div>
                <a href="{{ path('app_front_entretiens') }}" class="btn-detail">Voir tout</a>
            </div>
            {% if dernierEntretiens|length > 0 %}
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Statut</th>
                        <th>Lieu</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {% for e in dernierEntretiens %}
                    <tr>
                        <td><strong>{{ e.dateEntretien ? e.dateEntretien|date('d/m/Y') : '-' }}</strong></td>
                        <td>
                            <span class="badge-s {{ e.typeEntretien == 'RH' ? 'b-rh' : 'b-technique' }}">
                                {{ e.typeEntretien ?? '-' }}
                            </span>
                        </td>
                        <td>
                            {% set s = e.statutEntretien|lower %}
                            <span class="badge-s {% if 'termin' in s %}b-termine{% elseif 'planifi' in s %}b-planifie{% elseif 'annul' in s %}b-annule{% else %}b-attente{% endif %}">
                                {{ e.statutEntretien ? e.statutEntretien|upper : '-' }}
                            </span>
                        </td>
                        <td>{{ e.lieu ?? '-' }}</td>
                        <td>
                            <a href="{{ path('app_front_entretien_show', {'id': e.id}) }}" class="btn-detail">
                                <i class="fas fa-eye me-1"></i>Détail
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
                <div class="empty-state">
                    <i class="fas fa-briefcase"></i>
                    <h3>Aucun entretien</h3>
                    <p>Vous n'avez pas encore d'entretiens planifiés.</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# ── Résultats évaluations ── #}
    <div class="col-md-5">
        <div class="front-card h-100">
            <div class="front-card-header">
                <div>
                    <h2><i class="fas fa-chart-bar me-2" style="color:#7209b7"></i>Mes résultats</h2>
                    <p>Synthèse de vos évaluations</p>
                </div>
            </div>
            <div style="padding:20px">
                {% if totalEvals > 0 %}
                {# Score moyen #}
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="score-ring" style="--pct:{{ scoreMoyen }}%">
                        <span>{{ scoreMoyen }}</span>
                    </div>
                    <div>
                        <div style="font-weight:700;font-size:1rem;color:#1a1a2e">Score moyen</div>
                        <div style="font-size:0.82rem;color:#8c98a4">Sur 100 points</div>
                        <div class="mt-1">
                            {% for i in 1..5 %}
                                <i class="fas fa-star" style="font-size:0.75rem;color:{% if i <= noteMoyenne %}#fb8500{% else %}#dee2e6{% endif %}"></i>
                            {% endfor %}
                            <span style="font-size:0.78rem;color:#8c98a4;margin-left:4px">{{ noteMoyenne }}/5</span>
                        </div>
                    </div>
                </div>

                {# Compétences #}
                <div style="font-size:0.78rem;font-weight:700;color:#8c98a4;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px">
                    Compétences
                </div>
                {% set competences = [
                    {'label': 'Techniques',       'val': evalStats[0], 'color': '#4361ee'},
                    {'label': 'Comportementales', 'val': evalStats[1], 'color': '#7209b7'},
                    {'label': 'Communication',    'val': evalStats[2], 'color': '#4cc9f0'},
                    {'label': 'Motivation',       'val': evalStats[3], 'color': '#06d6a0'},
                    {'label': 'Expérience',       'val': evalStats[4], 'color': '#fb8500'},
                ] %}
                {% for c in competences %}
                <div class="mb-2">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:0.82rem;color:#495057">{{ c.label }}</span>
                        <span style="font-size:0.82rem;font-weight:700;color:{{ c.color }}">{{ c.val }}/5</span>
                    </div>
                    <div class="progress-bar-custom">
                        <div class="fill" style="width:{{ (c.val / 5 * 100)|round }}%;background:{{ c.color }}"></div>
                    </div>
                </div>
                {% endfor %}

                {# Décision #}
                <div class="mt-3 p-3 rounded-3 text-center" style="background:#f8f9ff">
                    <div style="font-size:0.8rem;color:#8c98a4;margin-bottom:6px">Dernière décision</div>
                    {% if derniereDecision %}
                        {% set d = derniereDecision|lower %}
                        <span class="badge-s {% if 'accept' in d %}b-accepte{% elseif 'refus' in d %}b-refuse{% else %}b-attente{% endif %}" style="font-size:0.88rem;padding:8px 20px">
                            {{ derniereDecision }}
                        </span>
                    {% else %}
                        <span style="color:#adb5bd">En attente</span>
                    {% endif %}
                </div>

                {% else %}
                <div class="empty-state">
                    <i class="fas fa-star"></i>
                    <h3>Aucune évaluation</h3>
                    <p>Vos résultats apparaîtront ici après vos entretiens.</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

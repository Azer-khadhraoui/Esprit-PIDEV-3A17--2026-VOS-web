{% extends 'front/base_front.html.twig' %}
{% block title %}Détail Entretien #{{ entretien.id }}{% endblock %}
{% block hero_title %}Entretien #{{ entretien.id }}{% endblock %}
{% block hero_subtitle %}{{ entretien.dateEntretien ? entretien.dateEntretien|date('d/m/Y') : '' }} — {{ entretien.typeEntretien }} — {{ entretien.lieu }}{% endblock %}

{% block body %}

<div class="mb-3">
    <a href="{{ path('app_front_entretiens') }}" style="color:#4361ee;text-decoration:none;font-size:0.88rem;font-weight:600">
        <i class="fas fa-arrow-left me-1"></i> Retour à mes entretiens
    </a>
</div>

<div class="row g-3">

    {# ── INFOS ENTRETIEN ── #}
    <div class="col-md-6">
        <div class="front-card h-100">
            <div class="front-card-header">
                <div>
                    <h2><i class="fas fa-info-circle me-2" style="color:#4361ee"></i>Informations</h2>
                </div>
                {% set s = entretien.statutEntretien|lower %}
                <span class="badge-s {% if 'termin' in s %}b-termine{% elseif 'planifi' in s %}b-planifie{% elseif 'annul' in s %}b-annule{% else %}b-attente{% endif %}">
                    {{ entretien.statutEntretien ? entretien.statutEntretien|upper : '-' }}
                </span>
            </div>
            <div style="padding:22px">
                <div class="info-grid">
                    <div class="info-item">
                        <div class="i-label">Date</div>
                        <div class="i-value">{{ entretien.dateEntretien ? entretien.dateEntretien|date('d/m/Y') : '-' }}</div>
                    </div>
                    <div class="info-item">
                        <div class="i-label">Heure</div>
                        <div class="i-value">{{ entretien.heureEntretien ? entretien.heureEntretien|date('H:i') : '-' }}</div>
                    </div>
                    <div class="info-item">
                        <div class="i-label">Type</div>
                        <div class="i-value">
                            <span class="badge-s {{ entretien.typeEntretien == 'RH' ? 'b-rh' : 'b-technique' }}">
                                {{ entretien.typeEntretien ?? '-' }}
                            </span>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="i-label">Lieu</div>
                        <div class="i-value">{{ entretien.lieu ?? '-' }}</div>
                    </div>
                    <div class="info-item">
                        <div class="i-label">Type de test</div>
                        <div class="i-value">{{ entretien.typeTest ?? '-' }}</div>
                    </div>
                    <div class="info-item">
                        <div class="i-label">ID Candidature</div>
                        <div class="i-value">{{ entretien.idCandidature ?? '-' }}</div>
                    </div>
                </div>

                {% if entretien.lienReunion %}
                <div class="mt-3 p-3 rounded-3" style="background:#eef1ff;border:1.5px solid #c7d2fe">
                    <div style="font-size:0.78rem;font-weight:700;color:#4361ee;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px">
                        <i class="fas fa-video me-1"></i> Lien de réunion
                    </div>
                    <a href="{{ entretien.lienReunion }}" target="_blank"
                       style="color:#4361ee;font-size:0.88rem;word-break:break-all;text-decoration:none;font-weight:600">
                        {{ entretien.lienReunion }}
                        <i class="fas fa-external-link-alt ms-1" style="font-size:0.75rem"></i>
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── ÉVALUATION ── #}
    <div class="col-md-6">
        <div class="front-card h-100">
            <div class="front-card-header">
                <div>
                    <h2><i class="fas fa-star me-2" style="color:#7209b7"></i>Mon Évaluation</h2>
                    <p>Résultat de cet entretien</p>
                </div>
            </div>
            <div style="padding:22px">
                {% if entretien.evaluationEntretiens is not empty %}
                    {% set eval = entretien.evaluationEntretiens|first %}

                    {# Score + Note #}
                    <div class="d-flex align-items-center gap-4 mb-4">
                        <div class="text-center">
                            <div style="font-size:2.8rem;font-weight:800;color:#4361ee;line-height:1">{{ eval.scoreTest ?? '-' }}</div>
                            <div style="font-size:0.75rem;color:#8c98a4">Score / 100</div>
                            <div style="height:5px;width:80px;background:#f0f2f5;border-radius:3px;margin:6px auto 0;overflow:hidden">
                                <div style="width:{{ eval.scoreTest ?? 0 }}%;height:100%;background:{% if (eval.scoreTest ?? 0) >= 75 %}#06d6a0{% elseif (eval.scoreTest ?? 0) >= 50 %}#fb8500{% else %}#f72585{% endif %};border-radius:3px"></div>
                            </div>
                        </div>
                        <div>
                            <div style="font-size:0.78rem;color:#8c98a4;margin-bottom:4px">Note globale</div>
                            {% for i in 1..5 %}
                                <i class="fas fa-star" style="font-size:1.1rem;color:{% if i <= (eval.noteEntretien ?? 0) %}#fb8500{% else %}#dee2e6{% endif %}"></i>
                            {% endfor %}
                            <div style="font-size:0.78rem;color:#8c98a4;margin-top:4px">{{ eval.noteEntretien ?? '-' }} / 5</div>
                        </div>
                        <div class="ms-auto">
                            {% set d = eval.decision|lower %}
                            <span class="badge-s {% if 'accept' in d %}b-accepte{% elseif 'refus' in d %}b-refuse{% else %}b-attente{% endif %}" style="font-size:0.88rem;padding:8px 18px">
                                {{ eval.decision ?? '-' }}
                            </span>
                        </div>
                    </div>

                    {# Compétences #}
                    {% set competences = [
                        {'label': 'Compétences techniques',  'val': eval.competencesTechniques,       'color': '#4361ee'},
                        {'label': 'Comportementales',        'val': eval.competencesComportementales, 'color': '#7209b7'},
                        {'label': 'Communication',           'val': eval.communication,               'color': '#4cc9f0'},
                        {'label': 'Motivation',              'val': eval.motivation,                  'color': '#06d6a0'},
                        {'label': 'Expérience',              'val': eval.experience,                  'color': '#fb8500'},
                    ] %}
                    {% for c in competences %}
                    <div class="mb-2">
                        <div class="d-flex justify-content-between mb-1">
                            <span style="font-size:0.82rem;color:#495057">{{ c.label }}</span>
                            <span style="font-size:0.82rem;font-weight:700;color:{{ c.color }}">{{ c.val ?? 0 }}/5</span>
                        </div>
                        <div class="progress-bar-custom">
                            <div class="fill" style="width:{{ ((c.val ?? 0) / 5 * 100)|round }}%;background:{{ c.color }}"></div>
                        </div>
                    </div>
                    {% endfor %}

                    {% if eval.commentaire %}
                    <div class="mt-3 p-3 rounded-3" style="background:#f8f9ff;border-left:3px solid #4361ee">
                        <div style="font-size:0.75rem;font-weight:700;color:#8c98a4;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px">Commentaire</div>
                        <div style="font-size:0.88rem;color:#495057;line-height:1.6">{{ eval.commentaire }}</div>
                    </div>
                    {% endif %}

                {% else %}
                    <div class="empty-state" style="padding:40px 20px">
                        <i class="fas fa-hourglass-half" style="color:#dee2e6"></i>
                        <h3>Évaluation en attente</h3>
                        <p>Votre évaluation sera disponible après l'entretien.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── QUESTIONS ── #}
    {% if entretien.questionsEntretien %}
    <div class="col-12">
        <div class="front-card">
            <div class="front-card-header">
                <div>
                    <h2><i class="fas fa-question-circle me-2" style="color:#fb8500"></i>Questions de l'entretien</h2>
                    <p>Préparez-vous avec ces questions</p>
                </div>
            </div>
            <div style="padding:22px;white-space:pre-line;font-size:0.9rem;line-height:1.8;color:#495057">
                {{ entretien.questionsEntretien }}
            </div>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}

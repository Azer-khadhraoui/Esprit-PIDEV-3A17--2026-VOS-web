<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VOS Admin - {% block title %}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; display: flex; min-height: 100vh; margin: 0; }

        /* ── SIDEBAR ── */
        .sidebar {
            width: 240px; min-height: 100vh; background: #0f1c2e;
            display: flex; flex-direction: column;
            position: fixed; top: 0; left: 0; bottom: 0; z-index: 100;
        }
        .sidebar-brand {
            padding: 22px 24px 18px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            display: flex; align-items: center; gap: 10px;
        }
        .sidebar-brand .dot { width: 10px; height: 10px; border-radius: 50%; background: #4cc9f0; flex-shrink:0; }
        .sidebar-brand span { color: white; font-weight: 700; font-size: 1rem; }
        .sidebar nav { padding: 16px 0; flex: 1; }
        .sidebar nav a {
            display: block; padding: 11px 24px; color: #8892b0;
            text-decoration: none; font-size: 0.9rem; font-weight: 500;
            transition: all 0.2s; border-left: 3px solid transparent;
        }
        .sidebar nav a:hover { color: white; background: rgba(255,255,255,0.05); }
        .sidebar nav a.active {
            color: white; background: rgba(67,97,238,0.18);
            border-left-color: #4361ee; font-weight: 600;
        }

        /* ── MAIN ── */
        .main { margin-left: 240px; flex: 1; min-height: 100vh; display: flex; flex-direction: column; }

        /* ── TOPBAR ── */
        .topbar {
            background: #0f1c2e; padding: 14px 32px;
            display: flex; align-items: center; justify-content: space-between;
        }
        .topbar .brand { color: white; font-weight: 700; font-size: 1rem; }
        .btn-deconnect {
            background: #4361ee; color: white; border: none;
            padding: 8px 20px; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
            text-decoration: none;
        }
        .btn-deconnect:hover { background: #3451b2; color: white; }

        /* ── TABS ── */
        .tab-bar {
            background: #0f1c2e;
            padding: 12px 32px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .tab-container {
            display: inline-flex;
            background: #1a2d45;
            border-radius: 10px;
            padding: 4px;
            gap: 2px;
        }
        .tab-container a {
            padding: 8px 20px;
            text-decoration: none;
            color: #8892b0;
            font-size: 0.88rem;
            font-weight: 500;
            border-radius: 7px;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .tab-container a:hover { color: white; background: rgba(255,255,255,0.07); }
        .tab-container a.active {
            background: white;
            color: #0f1c2e;
            font-weight: 700;
        }

        /* ── PAGE ── */
        .page { padding: 28px 32px; }
        .page h1 { font-size: 2rem; font-weight: 800; color: #1a1a2e; margin-bottom: 4px; }
        .page .subtitle { color: #6c757d; font-size: 0.88rem; margin-bottom: 24px; }

        /* ── STAT CARDS ── */
        .stat-card {
            background: white; border-radius: 14px; padding: 22px 24px;
            border-top: 3px solid #e0e6ed; height: 100%;
        }
        .stat-card.blue   { border-top-color: #4361ee; }
        .stat-card.green  { border-top-color: #06d6a0; }
        .stat-card.orange { border-top-color: #fb8500; }
        .stat-card.purple { border-top-color: #7209b7; }
        .stat-card.red    { border-top-color: #f72585; }
        .stat-card .s-label { color: #8c98a4; font-size: 0.85rem; margin-bottom: 8px; font-weight: 500; }
        .stat-card .s-value { font-size: 2.2rem; font-weight: 800; color: #1a1a2e; line-height: 1; }

        /* ── TABLE CARD ── */
        .table-card { background: white; border-radius: 14px; overflow: hidden; margin-top: 24px; }
        .table-card-header {
            padding: 20px 24px 16px;
            display: flex; justify-content: space-between; align-items: flex-start;
            border-bottom: 1px solid #f0f2f5;
        }
        .table-card-header h2 { font-size: 1.1rem; font-weight: 700; color: #1a1a2e; margin: 0; }
        .table-card-header p  { color: #8c98a4; font-size: 0.82rem; margin: 3px 0 0; }
        .entries-count { color: #4361ee; font-size: 0.88rem; font-weight: 600; }

        /* ── SEARCH ── */
        .search-row { padding: 12px 24px; background: #fafbfc; border-bottom: 1px solid #f0f2f5; }
        .search-row .form-control, .search-row .form-select {
            border: 1.5px solid #e0e6ed; font-size: 0.88rem; border-radius: 8px;
        }
        .search-row .input-group-text {
            background: #f5f7fa; border: 1.5px solid #e0e6ed;
            border-right: 0; border-radius: 8px 0 0 8px;
        }
        .search-row .input-group .form-control { border-left: 0; border-radius: 0 8px 8px 0; }

        /* ── TABLE ── */
        table { width: 100%; border-collapse: collapse; }
        thead th {
            padding: 11px 16px; font-size: 0.78rem; font-weight: 700;
            color: #8c98a4; text-transform: uppercase; letter-spacing: 0.5px;
            background: #fafbfc; border-bottom: 1px solid #f0f2f5;
        }
        thead th a { text-decoration: none; color: inherit; }
        tbody td { padding: 13px 16px; font-size: 0.88rem; border-bottom: 1px solid #f8f9fa; vertical-align: middle; }
        tbody tr:last-child td { border-bottom: none; }
        tbody tr:hover { background: #f8f9ff; }

        /* ── BADGES ── */
        .badge-s { padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; display: inline-block; }
        .b-termine   { color: #06d6a0; }
        .b-planifie  { color: #4361ee; }
        .b-annule    { color: #f72585; }
        .b-attente   { color: #fb8500; }
        .b-accepte   { background: #d4f5e9; color: #1a7a4a; }
        .b-refuse    { background: #fde8e8; color: #c0392b; }
        .b-rh        { background: #e8f4fd; color: #1565c0; border-radius: 6px; }
        .b-technique { background: #f3e5f5; color: #6a1b9a; border-radius: 6px; }

        /* ── ACTION BUTTONS ── */
        .btn-voir      { background: #d4f5e9; color: #1a7a4a; border: none; padding: 7px 14px; border-radius: 8px; font-size: 0.82rem; font-weight: 600; text-decoration: none; display: inline-block; }
        .btn-modifier  { background: #4361ee; color: white; border: none; padding: 7px 14px; border-radius: 8px; font-size: 0.82rem; font-weight: 600; text-decoration: none; display: inline-block; }
        .btn-modifier:hover { background: #3451b2; color: white; }
        .btn-supprimer { background: #fde8e8; color: #c0392b; border: none; padding: 7px 14px; border-radius: 8px; font-size: 0.82rem; font-weight: 600; cursor: pointer; }
        .btn-ajouter   { background: #4361ee; color: white; border: none; padding: 9px 20px; border-radius: 9px; font-size: 0.88rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 7px; }
        .btn-ajouter:hover { background: #3451b2; color: white; }
        .btn-filter    { background: #4361ee; color: white; border: none; padding: 8px 14px; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; }
        .btn-reset     { background: #f0f2f5; color: #6c757d; border: none; padding: 8px 12px; border-radius: 8px; font-size: 0.85rem; text-decoration: none; display: inline-block; cursor: pointer; }

        /* ── FLASH ── */
        .flash-ok  { background: #d4f5e9; color: #1a7a4a; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 0.88rem; }
        .flash-err { background: #fde8e8; color: #c0392b; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 0.88rem; }

        /* ── FORM ── */
        .form-wrap { background: white; border-radius: 14px; padding: 28px; max-width: 720px; }
        .form-label { font-weight: 600; font-size: 0.84rem; color: #495057; }
        .form-control, .form-select { border-radius: 9px; border: 1.5px solid #e0e6ed; padding: 9px 13px; font-size: 0.9rem; }
        .form-control:focus, .form-select:focus { border-color: #4361ee; box-shadow: 0 0 0 3px rgba(67,97,238,0.1); }
        textarea.form-control { min-height: 100px; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
    <div class="sidebar-brand">
        <div class="dot"></div>
        <span>VOS Admin</span>
    </div>
    <nav>
        <a href="#">Gestion Users</a>
        <a href="#">Gestion Offres</a>
        <a href="{{ path('app_entretien_index') }}"
           class="{% if app.request.attributes.get('_route') starts with 'app_entretien' or app.request.attributes.get('_route') starts with 'app_evaluation' %}active{% endif %}">
            Gestion Entretiens
        </a>
        <a href="#">Gestion Recrutements</a>
        <a href="#">Forum</a>
        <a href="#">Rapports</a>
    </nav>
</div>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
        <div class="brand">VOS Admin</div>
        <a href="#" class="btn-deconnect">Déconnexion</a>
    </div>

    <!-- TABS -->
    <div class="tab-bar">
        <div class="tab-container">
            <a href="{{ path('app_entretien_index') }}"
               class="{% if app.request.attributes.get('_route') starts with 'app_entretien' and app.request.attributes.get('_route') != 'app_entretien_stats' %}active{% endif %}">
                Gestion des Entretiens
            </a>
            <a href="{{ path('app_evaluation_entretien_index') }}"
               class="{% if app.request.attributes.get('_route') starts with 'app_evaluation' %}active{% endif %}">
                Gestion des Évaluations
            </a>
            <a href="{{ path('app_entretien_stats') }}"
               class="{% if app.request.attributes.get('_route') == 'app_entretien_stats' %}active{% endif %}">
                Statistiques
            </a>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="page">
        {% for msg in app.flashes('success') %}
            <div class="flash-ok"><i class="fas fa-check-circle me-2"></i>{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="flash-err"><i class="fas fa-exclamation-circle me-2"></i>{{ msg }}</div>
        {% endfor %}
        {% block body %}{% endblock %}
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>

{% extends 'gestion_offre_base.html.twig' %}

{% block title %}Ajouter Recrutement | VOS{% endblock %}

{% block body %}
<div class="admin-shell">
    <aside class="sidebar">
        <div class="brand">
            <span class="brand-dot"></span>
            <span>VOS Admin</span>
        </div>
        <nav class="nav-list">
            <a class="nav-item is-active" href="{{ path('recrutement_index') }}">Gestion Recrutements</a>
            <a class="nav-item" href="{{ path('app_admin_forum') }}">Forum</a>
            <a class="nav-item" href="{{ path('app_admin_reports') }}">Rapports</a>
        </nav>
        <div class="sidebar-footer">Panel Administration</div>
    </aside>

    <main class="content">
        <header class="topbar">
            <div>
                <h1>Ajouter un recrutement</h1>
                <p>Complétez le formulaire ci-dessous.</p>
            </div>
            <a href="{{ path('recrutement_index') }}" class="btn-logout">Retour à la liste</a>
        </header>

        <section class="table-card">
            {{ include('recrutement/_form.html.twig', {'form': form, 'button_label': 'Créer'}) }}
        </section>
    </main>
</div>
{% endblock %}

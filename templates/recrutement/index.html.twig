{% extends 'gestion_offre_base.html.twig' %}

{% block title %}Gestion Recrutements | VOS{% endblock %}

{% block body %}
<div class="admin-shell">
    <aside class="sidebar">
        <div class="brand">
            <span class="brand-dot"></span>
            <span>VOS Admin</span>
        </div>
        <nav class="nav-list">
            <a class="nav-item is-active" href="{{ path('recrutement_index') }}">Gestion Recrutements</a>
            <a class="nav-item" href="{{ path('app_admin_forum') }}">Forum</a>
            <a class="nav-item" href="{{ path('app_admin_reports') }}">Rapports</a>
        </nav>
        <div class="sidebar-footer">Panel Administration</div>
    </aside>

    <main class="content">
        <header class="topbar">
            <div>
                <h1>Gestion des recrutements</h1>
                <p>Liste des recrutements enregistrés</p>
            </div>
            <a href="{{ path('recrutement_new') }}" class="btn-logout">Nouveau recrutement</a>
        </header>

        <div class="module-nav">
            <a class="module-link is-active" href="{{ path('recrutement_index') }}">Recrutements</a>
            <a class="module-link" href="{{ path('contrat_embauche_index') }}">Contrats</a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="flash flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash flash-error">{{ message }}</div>
        {% endfor %}

        <section class="table-card">
            <div class="table-head">
                <h2>Recrutements</h2>
                <span class="table-badge">{{ recrutements|length }} entrées</span>
            </div>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Date décision</th>
                            <th>Décision finale</th>
                            <th>ID Entretien</th>
                            <th>ID Utilisateur</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for recrutement in recrutements %}
                            <tr>
                                <td>{{ recrutement.id }}</td>
                                <td>{{ recrutement.dateDecision ? recrutement.dateDecision|date('d/m/Y') : '-' }}</td>
                                <td>{{ recrutement.decisionFinale }}</td>
                                <td>{{ recrutement.idEntretien }}</td>
                                <td>{{ recrutement.idUtilisateur }}</td>
                                <td>
                                    <div class="actions">
                                        <a class="btn-edit" href="{{ path('recrutement_edit', {id: recrutement.id}) }}">Modifier</a>
                                        <form method="post" action="{{ path('recrutement_delete', {id: recrutement.id}) }}" onsubmit="return confirm('Supprimer ce recrutement ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_recrutement_' ~ recrutement.id) }}">
                                            <button class="btn-delete" type="submit">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6">Aucun recrutement trouvé.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}Gestion des Entretiens{% endblock %}

{% block body %}

{# ── HEADER ── #}
<h1>Dashboard Entretiens</h1>
<p class="subtitle">Bienvenue — Gestion des entretiens et évaluations</p>

{# ── STAT CARDS ── #}
<div class="row g-3 mb-2">
    <div class="col-md-3 col-6">
        <div class="stat-card blue">
            <div class="s-label">Total Entretiens</div>
            <div class="s-value">{{ entretiens|length }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card green">
            <div class="s-label">Entretiens Terminés</div>
            <div class="s-value">{{ entretiens|filter(e => 'termin' in e.statutEntretien|lower)|length }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card orange">
            <div class="s-label">Entretiens Planifiés</div>
            <div class="s-value">{{ entretiens|filter(e => 'planifi' in e.statutEntretien|lower)|length }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card purple">
            <div class="s-label">Type RH</div>
            <div class="s-value">{{ entretiens|filter(e => e.typeEntretien == 'RH')|length }}</div>
        </div>
    </div>
</div>

{# ── TABLE CARD ── #}
<div class="table-card">
    <div class="table-card-header">
        <div>
            <h2>Liste des entretiens</h2>
            <p>Vue d'ensemble de tous les entretiens planifiés</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="entries-count">{{ entretiens|length }} entrées</span>
            <a href="{{ path('app_entretien_new') }}" class="btn-ajouter">
                <i class="fas fa-plus"></i> Ajouter
            </a>
        </div>
    </div>

    {# SEARCH ROW #}
    <div class="search-row">
        <form method="get" action="{{ path('app_entretien_index') }}">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search text-muted" style="font-size:0.8rem"></i></span>
                        <input type="text" name="search" value="{{ search }}" class="form-control" placeholder="Rechercher...">
                    </div>
                </div>
                <div class="col-md-2">
                    <select name="type" class="form-select">
                        <option value="">Tous les types</option>
                        <option value="RH"        {% if type == 'RH' %}selected{% endif %}>RH</option>
                        <option value="TECHNIQUE" {% if type == 'TECHNIQUE' %}selected{% endif %}>TECHNIQUE</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="statut" class="form-select">
                        <option value="">Tous les statuts</option>
                        <option value="Planifié"   {% if statut == 'Planifié' %}selected{% endif %}>Planifié</option>
                        <option value="Terminé"    {% if statut == 'Terminé' %}selected{% endif %}>Terminé</option>
                        <option value="Annulé"     {% if statut == 'Annulé' %}selected{% endif %}>Annulé</option>
                        <option value="En attente" {% if statut == 'En attente' %}selected{% endif %}>En attente</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="e.dateEntretien"   {% if sortBy == 'e.dateEntretien' %}selected{% endif %}>Par date</option>
                        <option value="e.typeEntretien"   {% if sortBy == 'e.typeEntretien' %}selected{% endif %}>Par type</option>
                        <option value="e.statutEntretien" {% if sortBy == 'e.statutEntretien' %}selected{% endif %}>Par statut</option>
                        <option value="e.lieu"            {% if sortBy == 'e.lieu' %}selected{% endif %}>Par lieu</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <select name="sortDir" class="form-select">
                        <option value="DESC" {% if sortDir == 'DESC' %}selected{% endif %}>↓</option>
                        <option value="ASC"  {% if sortDir == 'ASC' %}selected{% endif %}>↑</option>
                    </select>
                </div>
                <div class="col-md-1 d-flex gap-2">
                    <button type="submit" class="btn-filter"><i class="fas fa-search"></i></button>
                    <a href="{{ path('app_entretien_index') }}" class="btn-reset"><i class="fas fa-times"></i></a>
                </div>
            </div>
        </form>
    </div>

    {% if search or type or statut %}
    <div class="px-4 py-2" style="font-size:0.83rem;color:#6c757d;background:#fffbf0;border-bottom:1px solid #f0f2f5">
        <i class="fas fa-filter me-1"></i> <strong>{{ entretiens|length }}</strong> résultat(s)
        {% if search %} pour "<strong>{{ search }}</strong>"{% endif %}
        {% if type %} · <strong>{{ type }}</strong>{% endif %}
        {% if statut %} · <strong>{{ statut }}</strong>{% endif %}
    </div>
    {% endif %}

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>
                    <a href="{{ path('app_entretien_index', {search:search,type:type,statut:statut,sortBy:'e.dateEntretien',sortDir:sortBy=='e.dateEntretien' and sortDir=='ASC'?'DESC':'ASC'}) }}">
                        Date {% if sortBy=='e.dateEntretien' %}<i class="fas fa-sort-{{ sortDir=='ASC'?'up':'down' }}" style="color:#4361ee"></i>{% else %}<i class="fas fa-sort" style="color:#dee2e6"></i>{% endif %}
                    </a>
                </th>
                <th>Heure</th>
                <th>
                    <a href="{{ path('app_entretien_index', {search:search,type:type,statut:statut,sortBy:'e.typeEntretien',sortDir:sortBy=='e.typeEntretien' and sortDir=='ASC'?'DESC':'ASC'}) }}">
                        Type {% if sortBy=='e.typeEntretien' %}<i class="fas fa-sort-{{ sortDir=='ASC'?'up':'down' }}" style="color:#4361ee"></i>{% else %}<i class="fas fa-sort" style="color:#dee2e6"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_entretien_index', {search:search,type:type,statut:statut,sortBy:'e.statutEntretien',sortDir:sortBy=='e.statutEntretien' and sortDir=='ASC'?'DESC':'ASC'}) }}">
                        Statut {% if sortBy=='e.statutEntretien' %}<i class="fas fa-sort-{{ sortDir=='ASC'?'up':'down' }}" style="color:#4361ee"></i>{% else %}<i class="fas fa-sort" style="color:#dee2e6"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_entretien_index', {search:search,type:type,statut:statut,sortBy:'e.lieu',sortDir:sortBy=='e.lieu' and sortDir=='ASC'?'DESC':'ASC'}) }}">
                        Lieu {% if sortBy=='e.lieu' %}<i class="fas fa-sort-{{ sortDir=='ASC'?'up':'down' }}" style="color:#4361ee"></i>{% else %}<i class="fas fa-sort" style="color:#dee2e6"></i>{% endif %}
                    </a>
                </th>
                <th>Type Test</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        {% for entretien in entretiens %}
            <tr>
                <td><strong>{{ entretien.id }}</strong></td>
                <td>{{ entretien.dateEntretien ? entretien.dateEntretien|date('d/m/Y') : '-' }}</td>
                <td>{{ entretien.heureEntretien ? entretien.heureEntretien|date('H:i') : '-' }}</td>
                <td>
                    <span class="badge-s {{ entretien.typeEntretien == 'RH' ? 'b-rh' : 'b-technique' }}">
                        {{ entretien.typeEntretien ?? '-' }}
                    </span>
                </td>
                <td>
                    {% set s = entretien.statutEntretien|lower %}
                    <span class="badge-s {% if 'termin' in s %}b-termine{% elseif 'planifi' in s %}b-planifie{% elseif 'annul' in s %}b-annule{% else %}b-attente{% endif %}">
                        {{ entretien.statutEntretien ? entretien.statutEntretien|upper : '-' }}
                    </span>
                </td>
                <td>{{ entretien.lieu ?? '-' }}</td>
                <td>{{ entretien.typeTest ?? '-' }}</td>
                <td>
                    <div class="d-flex gap-1 flex-wrap">
                        <a href="{{ path('app_entretien_show', {'id': entretien.id}) }}" class="btn-voir">Voir</a>
                        <a href="{{ path('app_entretien_edit', {'id': entretien.id}) }}" class="btn-modifier">Modifier</a>
                        <form method="post" action="{{ path('app_entretien_delete', {'id': entretien.id}) }}"
                              style="display:inline" onsubmit="return confirm('Supprimer ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entretien.id) }}">
                            <button class="btn-supprimer">Supprimer</button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8" class="text-center text-muted py-5">
                    <i class="fas fa-inbox fa-2x mb-2 d-block" style="color:#dee2e6"></i>
                    Aucun entretien trouvé
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

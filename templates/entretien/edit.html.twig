{% extends 'base.html.twig' %}
{% block title %}Modifier Entretien{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1><i class="fas fa-pen me-2" style="color:#4361ee"></i>Modifier l'Entretien #{{ entretien.id }}</h1>
        <p>Modifiez les informations de l'entretien</p>
    </div>
    <a href="{{ path('app_entretien_index') }}" class="btn-refresh">
        <i class="fas fa-arrow-left"></i> Retour
    </a>
</div>

<div class="card form-wrap">
    <div class="card-body p-4">
        {{ include('entretien/_form.html.twig') }}
    </div>
</div>
{% endblock %}

    {{ form_label(form.heureEntretien) }}
    {{ form_widget(form.heureEntretien, {'attr': {'class': 'form-control' ~ (form.heureEntretien.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
    {% if form.heureEntretien.vars.errors|length > 0 %}
        <div class="invalid-feedback d-block">{{ form.heureEntretien.vars.errors[0].message }}</div>
    {% endif %}
</div>

<div class="col-md-6">
    {{ form_label(form.typeEntretien) }}

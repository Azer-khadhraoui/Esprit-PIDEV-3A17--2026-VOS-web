<div class="col-md-6">
    {{ form_label(form.typeTest) }}
    {{ form_widget(form.typeTest, {'attr': {'class': 'form-control' ~ (form.typeTest.vars.errors|length > 0 ? ' is-invalid' : ''), 'placeholder': 'Ex: Technique, QCM...'}}) }}
    {% if form.typeTest.vars.errors|length > 0 %}
        <div class="invalid-feedback d-block">{{ form.typeTest.vars.errors[0].message }}</div>
    {% endif %}
</div>

{# Champ conditionnel — visible uniquement si lieu contient "en ligne" #}
<div class="col-md-6" id="bloc_lien_reunion" style="display:none">
    <label class="form-label fw-semibold">
        <i class="fas fa-video me-1 text-primary"></i>Lien de réunion
    </label>
    {{ form_widget(form.lienReunion, {'attr': {
        'class': 'form-control' ~ (form.lienReunion.vars.errors|length > 0 ? ' is-invalid' : ''),
        'id': 'champ_lien_reunion',
        'placeholder': 'https://meet.google.com/...'
    }}) }}
    {% if form.lienReunion.vars.errors|length > 0 %}
        <div class="invalid-feedback d-block">{{ form.lienReunion.vars.errors[0].message }}</div>
    {% endif %}
    <div class="form-text text-primary" style="font-size:0.8rem">
        <i class="fas fa-info-circle me-1"></i>Requis pour les entretiens en ligne.
    </div>
</div>

<div class="col-md-6">
    {{ form_label(form.idCandidature) }}
    {{ form_widget(form.idCandidature, {'attr': {'class': 'form-control' ~ (form.idCandidature.vars.errors|length > 0 ? ' is-invalid' : ''), 'placeholder': 'Ex: 1, 2, 3...'}}) }}
    {% if form.idCandidature.vars.errors|length > 0 %}
        <div class="invalid-feedback d-block">{{ form.idCandidature.vars.errors[0].message }}</div>
    {% endif %}
</div>

<div class="col-12">
    {{ form_label(form.questionsEntretien) }}
    {{ form_widget(form.questionsEntretien, {'attr': {'class': 'form-control' ~ (form.questionsEntretien.vars.errors|length > 0 ? ' is-invalid' : ''), 'rows': '5', 'placeholder': 'Saisissez les questions...'}}) }}
    {% if form.questionsEntretien.vars.errors|length > 0 %}
        <div class="invalid-feedback d-block">{{ form.questionsEntretien.vars.errors[0].message }}</div>
    {% endif %}
</div>

<div class="col-12 d-flex gap-2 mt-2">
    <button type="submit" class="btn-ajouter">
        <i class="fas fa-save"></i> Enregistrer
    </button>
    <a href="{{ path('app_entretien_index') }}" class="btn btn-light rounded-3">
        <i class="fas fa-arrow-left me-1"></i> Annuler
    </a>
</div>

{{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function () {
    // Trouver par name (toujours fiable avec Symfony)
    var champLieu = document.querySelector('[name$="[lieu]"]');
    var blocLien  = document.getElementById('bloc_lien_reunion');
    var champLien = document.querySelector('[name$="[lienReunion]"]');

    if (!champLieu || !blocLien) return;

    function verifierLieu() {
        var valeur = champLieu.value.trim().toLowerCase();
        if (valeur.includes('en ligne') || valeur === 'online') {
            blocLien.style.display = 'block';
        } else {
            blocLien.style.display = 'none';
            if (champLien) champLien.value = '';
        }
    }

    verifierLieu();
    champLieu.addEventListener('input', verifierLieu);
});
</script>
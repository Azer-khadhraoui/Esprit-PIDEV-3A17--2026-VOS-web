{% extends 'base.html.twig' %}
{% block title %}Gestion des Évaluations{% endblock %}

{% block body %}

<h1>Dashboard Évaluations</h1>
<p class="subtitle">Vue d'ensemble des évaluations d'entretien</p>

{# ── STAT CARDS ── #}
<div class="row g-3 mb-2">
    <div class="col-md-3 col-6">
        <div class="stat-card blue">
            <div class="s-label">Total Évaluations</div>
            <div class="s-value">{{ evaluation_entretiens|length }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card green">
            <div class="s-label">Acceptés</div>
            <div class="s-value">{{ evaluation_entretiens|filter(e => 'accept' in e.decision|lower)|length }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card red">
            <div class="s-label">Refusés</div>
            <div class="s-value">{{ evaluation_entretiens|filter(e => 'refus' in e.decision|lower)|length }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card orange">
            <div class="s-label">En Attente</div>
            <div class="s-value">{{ evaluation_entretiens|filter(e => 'attente' in e.decision|lower)|length }}</div>
        </div>
    </div>
</div>

{# ── TABLE CARD ── #}
<div class="table-card">
    <div class="table-card-header">
        <div>
            <h2>Liste des évaluations</h2>
            <p>Vue d'ensemble des évaluations et scores</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="entries-count">{{ evaluation_entretiens|length }} entrées</span>
            <a href="{{ path('app_evaluation_entretien_new') }}" class="btn-ajouter">
                <i class="fas fa-plus"></i> Ajouter
            </a>
        </div>
    </div>

    <div class="search-row">
        <form method="get" action="{{ path('app_evaluation_entretien_index') }}">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search text-muted" style="font-size:0.8rem"></i></span>
                        <input type="text" name="search" value="{{ search }}" class="form-control" placeholder="Rechercher...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="decision" class="form-select">
                        <option value="">Toutes les décisions</option>
                        <option value="Accepté"    {% if decision == 'Accepté' %}selected{% endif %}>Accepté</option>
                        <option value="Refusé"     {% if decision == 'Refusé' %}selected{% endif %}>Refusé</option>
                        <option value="En attente" {% if decision == 'En attente' %}selected{% endif %}>En attente</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="ev.scoreTest"     {% if sortBy == 'ev.scoreTest' %}selected{% endif %}>Par score</option>
                        <option value="ev.noteEntretien" {% if sortBy == 'ev.noteEntretien' %}selected{% endif %}>Par note</option>
                        <option value="ev.decision"      {% if sortBy == 'ev.decision' %}selected{% endif %}>Par décision</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <select name="sortDir" class="form-select">
                        <option value="DESC" {% if sortDir == 'DESC' %}selected{% endif %}>↓</option>
                        <option value="ASC"  {% if sortDir == 'ASC' %}selected{% endif %}>↑</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn-filter"><i class="fas fa-search"></i> Filtrer</button>
                    <a href="{{ path('app_evaluation_entretien_index') }}" class="btn-reset"><i class="fas fa-times"></i></a>
                </div>
            </div>
        </form>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>
                    <a href="{{ path('app_evaluation_entretien_index', {search:search,decision:decision,sortBy:'ev.scoreTest',sortDir:sortBy=='ev.scoreTest' and sortDir=='ASC'?'DESC':'ASC'}) }}">
                        Score {% if sortBy=='ev.scoreTest' %}<i class="fas fa-sort-{{ sortDir=='ASC'?'up':'down' }}" style="color:#4361ee"></i>{% else %}<i class="fas fa-sort" style="color:#dee2e6"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_evaluation_entretien_index', {search:search,decision:decision,sortBy:'ev.noteEntretien',sortDir:sortBy=='ev.noteEntretien' and sortDir=='ASC'?'DESC':'ASC'}) }}">
                        Note {% if sortBy=='ev.noteEntretien' %}<i class="fas fa-sort-{{ sortDir=='ASC'?'up':'down' }}" style="color:#4361ee"></i>{% else %}<i class="fas fa-sort" style="color:#dee2e6"></i>{% endif %}
                    </a>
                </th>
                <th>Commentaire</th>
                <th>
                    <a href="{{ path('app_evaluation_entretien_index', {search:search,decision:decision,sortBy:'ev.decision',sortDir:sortBy=='ev.decision' and sortDir=='ASC'?'DESC':'ASC'}) }}">
                        Décision {% if sortBy=='ev.decision' %}<i class="fas fa-sort-{{ sortDir=='ASC'?'up':'down' }}" style="color:#4361ee"></i>{% else %}<i class="fas fa-sort" style="color:#dee2e6"></i>{% endif %}
                    </a>
                </th>
                <th>ID Entretien</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        {% for eval in evaluation_entretiens %}
            <tr>
                <td><strong>{{ eval.id }}</strong></td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div style="width:55px;height:6px;background:#f0f2f5;border-radius:3px;overflow:hidden">
                            <div style="width:{{ eval.scoreTest ?? 0 }}%;height:100%;background:{% if (eval.scoreTest ?? 0) >= 75 %}#06d6a0{% elseif (eval.scoreTest ?? 0) >= 50 %}#fb8500{% else %}#f72585{% endif %};border-radius:3px"></div>
                        </div>
                        <strong>{{ eval.scoreTest ?? '-' }}</strong>
                    </div>
                </td>
                <td>
                    {% for i in 1..5 %}
                        <i class="fas fa-star" style="font-size:0.7rem;color:{% if i <= (eval.noteEntretien ?? 0) %}#fb8500{% else %}#dee2e6{% endif %}"></i>
                    {% endfor %}
                    <span class="text-muted ms-1" style="font-size:0.8rem">{{ eval.noteEntretien ?? '-' }}/5</span>
                </td>
                <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{{ eval.commentaire ?? '-' }}</td>
                <td>
                    {% set d = eval.decision|lower %}
                    <span class="badge-s {% if 'accept' in d %}b-accepte{% elseif 'refus' in d %}b-refuse{% else %}b-attente{% endif %}">
                        {{ eval.decision ?? '-' }}
                    </span>
                </td>
                <td>
                    {% if eval.entretien %}
                        <a href="{{ path('app_entretien_show', {'id': eval.entretien.id}) }}" style="color:#4361ee;font-weight:700;text-decoration:none">
                            {{ eval.entretien.id }}
                        </a>
                    {% else %}-{% endif %}
                </td>
                <td>
                    <div class="d-flex gap-1">
                        <a href="{{ path('app_evaluation_entretien_show', {'id': eval.id}) }}" class="btn-voir">Voir</a>
                        <a href="{{ path('app_evaluation_entretien_edit', {'id': eval.id}) }}" class="btn-modifier">Modifier</a>
                        <form method="post" action="{{ path('app_evaluation_entretien_delete', {'id': eval.id}) }}"
                              style="display:inline" onsubmit="return confirm('Supprimer ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ eval.id) }}">
                            <button class="btn-supprimer">Supprimer</button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7" class="text-center text-muted py-5">
                    <i class="fas fa-star fa-2x mb-2 d-block" style="color:#dee2e6"></i>
                    Aucune évaluation trouvée
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

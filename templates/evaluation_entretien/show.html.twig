{% extends 'base.html.twig' %}
{% block title %}Évaluation #{{ evaluation_entretien.id }}{% endblock %}
{% block body %}
<div class="page-header">
    <div>
        <h1><i class="fas fa-eye me-2" style="color:#4361ee"></i>Évaluation #{{ evaluation_entretien.id }}</h1>
        <p>Détail de l'évaluation</p>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('app_evaluation_entretien_edit', {'id': evaluation_entretien.id}) }}" class="btn-add">
            <i class="fas fa-pen"></i> Modifier
        </a>
        <a href="{{ path('app_evaluation_entretien_index') }}" class="btn-refresh">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4">
                <h6 class="text-muted mb-4" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:1px">Résultat</h6>

                <!-- Score -->
                <div class="text-center mb-4">
                    <div style="font-size:3rem;font-weight:800;color:#4361ee">{{ evaluation_entretien.scoreTest ?? '-' }}</div>
                    <div class="text-muted" style="font-size:0.85rem">Score / 100</div>
                    <div class="mt-2" style="height:8px;background:#f0f2f5;border-radius:4px;overflow:hidden">
                        <div style="width:{{ evaluation_entretien.scoreTest ?? 0 }}%;height:100%;background:{% if (evaluation_entretien.scoreTest ?? 0) >= 75 %}#06d6a0{% elseif (evaluation_entretien.scoreTest ?? 0) >= 50 %}#fb8500{% else %}#f72585{% endif %};border-radius:4px;transition:width 0.5s"></div>
                    </div>
                </div>

                <!-- Note -->
                <div class="text-center mb-3">
                    {% for i in 1..5 %}
                        <i class="fas fa-star" style="font-size:1.3rem;color:{% if i <= (evaluation_entretien.noteEntretien ?? 0) %}#fb8500{% else %}#dee2e6{% endif %}"></i>
                    {% endfor %}
                    <div class="text-muted mt-1" style="font-size:0.82rem">{{ evaluation_entretien.noteEntretien ?? '-' }} / 5</div>
                </div>

                <!-- Décision -->
                {% set d = evaluation_entretien.decision|lower %}
                <div class="text-center">
                    <span class="badge-s {% if 'accept' in d %}b-accepte{% elseif 'refus' in d %}b-refuse{% else %}b-attente{% endif %}" style="font-size:0.9rem;padding:8px 20px">
                        {{ evaluation_entretien.decision ?? '-' }}
                    </span>
                </div>

                {% if evaluation_entretien.entretien %}
                <div class="mt-4 p-3 rounded-3" style="background:#f8f9ff">
                    <div class="text-muted" style="font-size:0.78rem">Entretien lié</div>
                    <a href="{{ path('app_entretien_show', {'id': evaluation_entretien.entretien.id}) }}" style="color:#4361ee;font-weight:600;text-decoration:none">
                        <i class="fas fa-briefcase me-1"></i> Entretien #{{ evaluation_entretien.entretien.id }}
                        ({{ evaluation_entretien.entretien.dateEntretien ? evaluation_entretien.entretien.dateEntretien|date('d/m/Y') : '' }})
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-body p-4">
                <h6 class="text-muted mb-4" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:1px">Grille de compétences</h6>

                {% set competences = {
                    'Compétences techniques': evaluation_entretien.competencesTechniques,
                    'Comportementales': evaluation_entretien.competencesComportementales,
                    'Communication': evaluation_entretien.communication,
                    'Motivation': evaluation_entretien.motivation,
                    'Expérience': evaluation_entretien.experience
                } %}
                {% set colors = ['#4361ee','#7209b7','#4cc9f0','#06d6a0','#fb8500'] %}
                {% set i = 0 %}
                {% for label, val in competences %}
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:0.85rem;font-weight:600">{{ label }}</span>
                        <span style="font-size:0.85rem;color:#6c757d">{{ val ?? 0 }}/5</span>
                    </div>
                    <div style="height:8px;background:#f0f2f5;border-radius:4px;overflow:hidden">
                        <div style="width:{{ ((val ?? 0) / 5 * 100)|round }}%;height:100%;background:{{ colors[i] }};border-radius:4px"></div>
                    </div>
                </div>
                {% set i = i + 1 %}
                {% endfor %}

                {% if evaluation_entretien.commentaire %}
                <div class="mt-4">
                    <div class="text-muted mb-2" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:1px">Commentaire</div>
                    <div class="p-3 rounded-3" style="background:#f8f9ff;font-size:0.9rem;line-height:1.6">
                        {{ evaluation_entretien.commentaire }}
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

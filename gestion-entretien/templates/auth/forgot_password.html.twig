{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mot de passe | VOS{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/reset-password.css') }}">
{% endblock %}

{% block body %}
<div class="reset-page">
    <header class="top-nav">
        <div class="brand">
            <img src="{{ asset('images/logo.png') }}" alt="VOS Logo" class="logo-img">
        </div>
        <nav>
            <a href="{{ path('app_signin') }}">Accueil</a>
            <a href="{{ path('app_contact') }}">Contact</a>
            <a href="{{ path('app_about') }}">À propos</a>
        </nav>
    </header>

    <main class="reset-layout">
        <section class="visual-side">
            <div class="visual-card">
                <img src="{{ asset('images/reinitialisationmdppage1.png') }}" alt="Réinitialisation de mot de passe">
            </div>
        </section>

        <section class="form-side">
            <div class="form-card">
                <h1>Réinitialiser votre mot de passe</h1>
                <p class="description">L'e-mail de vérification sera envoyé à votre boîte e-mail. Veuillez le consulter.</p>

                {% for message in app.flashes('error') %}
                    <div class="flash flash-error" style="background: #ffe4e4; color: #8d1f1f; padding: 0.7rem; border-radius: 8px; margin-bottom: 1rem;">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('success') %}
                    <div class="flash flash-success" style="background: #e7f7e7; color: #1d6f3d; padding: 0.7rem; border-radius: 8px; margin-bottom: 1rem;">{{ message }}</div>
                {% endfor %}

                <form method="POST" class="reset-form">
                    <div class="field">
                        <label for="email">Adresse e-mail</label>
                        <div class="email-field-wrapper">
                            <input type="email" id="email" name="email" placeholder="votre@email.com" required>
                            <button type="submit" class="btn-send">Envoyer</button>
                        </div>
                    </div>

                    <div class="field">
                        <label for="verification_code">Code de vérification</label>
                        <input type="text" id="verification_code" name="verification_code" placeholder="Entrez le code reçu" required>
                    </div>

                    <button type="button" class="btn-submit" onclick="document.querySelector('.reset-form').submit()">Vérifier</button>
                </form>

                <div class="back-link">
                    <a href="{{ path('app_signin') }}">← Retour à la connexion</a>
                </div>
            </div>
        </section>
    </main>
</div>
{% endblock %}

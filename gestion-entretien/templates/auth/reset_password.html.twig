{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mot de passe | VOS{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/reset-password.css') }}">
{% endblock %}

{% block body %}
<div class="reset-page">
    <header class="top-nav">
        <div class="brand">
            <img src="{{ asset('images/logo.png') }}" alt="VOS Logo" class="logo-img">
        </div>
        <nav>
            <a href="{{ path('app_signin') }}">Accueil</a>
            <a href="{{ path('app_contact') }}">Contact</a>
            <a href="{{ path('app_about') }}">À propos</a>
        </nav>
    </header>

    <main class="reset-layout">
        <section class="visual-side">
            <div class="visual-card">
                <img src="{{ asset('images/reinitialisationmdppage2.png') }}" alt="Réinitialisation de mot de passe">
            </div>
        </section>

        <section class="form-side">
            <div class="form-card">
                <h1>Réinitialiser votre mot de passe</h1>
                <p class="description">L'e-mail de vérification sera envoyé à votre boîte e-mail. Veuillez le consulter.</p>

                {% for message in app.flashes('error') %}
                    <div class="flash flash-error" style="background: #ffe4e4; color: #8d1f1f; padding: 0.7rem; border-radius: 8px; margin-bottom: 1rem;">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('success') %}
                    <div class="flash flash-success" style="background: #e7f7e7; color: #1d6f3d; padding: 0.7rem; border-radius: 8px; margin-bottom: 1rem;">{{ message }}</div>
                {% endfor %}

                <form method="POST" class="reset-form">
                    <div class="field">
                        <label for="password">Nouveau mot de passe</label>
                        <div class="password-field-wrapper">
                            <input type="password" id="password" name="password" placeholder="xxxxxx" required>
                            <button type="button" class="toggle-password" onclick="togglePassword('password')">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 5C7 5 2.73 8.11 1 12.5 2.73 16.89 7 20 12 20s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zm0 12a4.5 4.5 0 100-9 4.5 4.5 0 000 9z"/>
                                    <circle cx="12" cy="12" r="2.5"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="field">
                        <label for="confirmPassword">Confirmer le nouveau mot de passe</label>
                        <div class="password-field-wrapper">
                            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="xxxxxx" required>
                            <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword')">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 5C7 5 2.73 8.11 1 12.5 2.73 16.89 7 20 12 20s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zm0 12a4.5 4.5 0 100-9 4.5 4.5 0 000 9z"/>
                                    <circle cx="12" cy="12" r="2.5"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn-submit">Réinitialiser le mot de passe</button>
                </form>

                <div class="back-link">
                    <a href="{{ path('app_signin') }}">← Back to login</a>
                </div>
            </div>
        </section>

<script>
    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        input.type = input.type === 'password' ? 'text' : 'password';
    }
</script>
    </main>
</div>
{% endblock %}

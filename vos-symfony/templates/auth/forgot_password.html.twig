{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mot de passe | VOS{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/reset-password.css') }}">
{% endblock %}

{% block body %}
    {% include 'components/vos_header.html.twig' %}
<div class="forgot-page">

    <main class="reset-layout">
        <section class="visual-side">
            <div class="visual-card">
                <img src="{{ asset('images/reinitialisationmdppage1.png') }}" alt="Réinitialisation de mot de passe">
            </div>
        </section>

        <section class="form-side">
            <div class="form-card">
                <h1>Réinitialiser votre mot de passe</h1>
                <p class="description">Entrez votre email et vous recevrez un code de réinitialisation à 6 chiffres.</p>

                {% for message in app.flashes('error') %}
                    <div class="flash flash-error" style="background: #ffe4e4; color: #8d1f1f; padding: 0.7rem; border-radius: 8px; margin-bottom: 1rem;">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('success') %}
                    <div class="flash flash-success" style="background: #e7f7e7; color: #1d6f3d; padding: 0.7rem; border-radius: 8px; margin-bottom: 1rem;">{{ message }}</div>
                {% endfor %}

                <form method="POST" class="reset-form" novalidate>
                    <input type="hidden" name="_token" value="{{ csrf_token('forgot_password_request') }}">
                    <div class="field">
                        <label for="email">Adresse e-mail</label>
                        <div class="email-field-wrapper">
                            <input type="email" id="email" name="email" placeholder="votre@email.com" value="{{ emailValue|default('') }}" required>
                            <button type="submit" class="btn-send">Envoyer le code</button>
                        </div>
                    </div>
                </form>

                <div class="back-link" style="margin-top: 0.75rem;">
                    <a href="{{ path('app_reset_password') }}">J'ai deja un code</a>
                </div>

                <div class="back-link">
                    <a href="{{ path('app_signin') }}">← Retour à la connexion</a>
                </div>
            </div>
        </section>
    </main>
</div>
{% endblock %}

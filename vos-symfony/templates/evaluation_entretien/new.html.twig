{% extends 'gestion_entretien_base.html.twig' %}
{% block title %}Nouvelle évaluation{% endblock %}

{% block body %}
    <div class="panel">
        <div class="section-head">
            <div>
                <h2>Créer une évaluation</h2>
                <p>Enregistrer une nouvelle évaluation pour un entretien</p>
            </div>
            <a class="btn btn-soft" href="{{ path('app_evaluation_entretien_index') }}">Retour</a>
        </div>

        <div class="form-shell">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="form-layout">
                <div class="form-field">{{ form_row(form.entretien) }}</div>
                <div class="form-field">{{ form_row(form.scoreTest) }}</div>
                <div class="form-field">{{ form_row(form.noteEntretien) }}</div>
                <div class="form-field">{{ form_row(form.decision) }}</div>
                <div class="form-field full">
                    {{ form_row(form.commentaire) }}
                    <div style="margin-top:8px;display:flex;align-items:center;gap:10px;">
                        <button type="button" id="ai-comment-btn"
                                style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:linear-gradient(135deg,#0e7490,#0284c7);color:#fff;border:0;border-radius:10px;font-weight:700;cursor:pointer;font-family:inherit;font-size:.85rem;transition:filter .15s;">
                            <span id="ai-btn-icon">✨</span>
                            <span id="ai-btn-label">Générer avec l'IA</span>
                        </button>
                        <span id="ai-comment-error" style="display:none;color:#b91c1c;font-size:.83rem;"></span>
                    </div>
                </div>
                <div class="form-field">{{ form_row(form.competencesTechniques) }}</div>
                <div class="form-field">{{ form_row(form.competencesComportementales) }}</div>
                <div class="form-field">{{ form_row(form.communication) }}</div>
                <div class="form-field">{{ form_row(form.motivation) }}</div>
                <div class="form-field full">{{ form_row(form.experience) }}</div>
            </div>
            <div class="actions" style="margin-top:18px;">
                <button class="btn btn-primary" type="submit">Enregistrer</button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    'use strict';

    var FIELDS = [
        'evaluation_entretien_competencesTechniques',
        'evaluation_entretien_competencesComportementales',
        'evaluation_entretien_communication',
        'evaluation_entretien_motivation',
        'evaluation_entretien_experience'
    ];

    function getIntVal(id) {
        var el = document.getElementById(id);
        return (el && el.value !== '') ? parseInt(el.value, 10) : 0;
    }

    function setVal(id, value) {
        var el = document.getElementById(id);
        if (el) {
            el.value = value;
            el.style.transition = 'background .3s';
            el.style.background = '#eef4ff';
            setTimeout(function () { el.style.background = ''; }, 800);
        }
    }

    function recalculate() {
        var sum = FIELDS.reduce(function (acc, id) { return acc + getIntVal(id); }, 0);
        var score = Math.round((sum / 25) * 1000) / 10;

        setVal('evaluation_entretien_scoreTest', score.toFixed(1));

        var decision = score >= 70 ? 'Accepté' : (score >= 50 ? 'En attente' : 'Refusé');
        setVal('evaluation_entretien_decision', decision);

        var note = score >= 80 ? 5 : (score >= 60 ? 4 : (score >= 40 ? 3 : (score >= 20 ? 2 : 1)));
        setVal('evaluation_entretien_noteEntretien', note);
    }

    FIELDS.forEach(function (id) {
        var el = document.getElementById(id);
        if (el) { el.addEventListener('change', recalculate); }
    });

    // AI comment generation
    var aiBtn       = document.getElementById('ai-comment-btn');
    var aiBtnIcon   = document.getElementById('ai-btn-icon');
    var aiBtnLabel  = document.getElementById('ai-btn-label');
    var aiError     = document.getElementById('ai-comment-error');
    var commentArea = document.getElementById('evaluation_entretien_commentaire');
    var generateUrl = '{{ path('app_evaluation_entretien_generate_comment') }}';

    function fieldVal(id) {
        var el = document.getElementById(id);
        return el ? el.value : '';
    }

    if (aiBtn) {
        aiBtn.addEventListener('click', function () {
            aiBtn.disabled = true;
            aiBtnIcon.textContent  = '⏳';
            aiBtnLabel.textContent = 'Génération…';
            aiError.style.display  = 'none';

            var body = JSON.stringify({
                scoreTest:                   parseFloat(fieldVal('evaluation_entretien_scoreTest'))   || 0,
                noteEntretien:               parseInt(fieldVal('evaluation_entretien_noteEntretien')) || 0,
                decision:                    fieldVal('evaluation_entretien_decision'),
                competencesTechniques:       parseInt(fieldVal('evaluation_entretien_competencesTechniques'))       || 0,
                competencesComportementales: parseInt(fieldVal('evaluation_entretien_competencesComportementales')) || 0,
                communication:               parseInt(fieldVal('evaluation_entretien_communication'))               || 0,
                motivation:                  parseInt(fieldVal('evaluation_entretien_motivation'))                  || 0,
                experience:                  parseInt(fieldVal('evaluation_entretien_experience'))                  || 0,
            });

            fetch(generateUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: body,
            })
            .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
            .then(function (result) {
                if (result.ok && result.data.comment) {
                    if (commentArea) {
                        commentArea.value = result.data.comment;
                        commentArea.style.transition = 'background .3s';
                        commentArea.style.background = '#eef4ff';
                        setTimeout(function () { commentArea.style.background = ''; }, 800);
                    }
                } else {
                    aiError.textContent   = result.data.error || 'Erreur inconnue.';
                    aiError.style.display = 'inline';
                }
            })
            .catch(function () {
                aiError.textContent   = 'Erreur réseau, veuillez réessayer.';
                aiError.style.display = 'inline';
            })
            .finally(function () {
                aiBtn.disabled         = false;
                aiBtnIcon.textContent  = '✨';
                aiBtnLabel.textContent = 'Générer avec l\'IA';
            });
        });
    }
}());
</script>
{% endblock %}
<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}VOS Admin{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        <style>
            :root {
                --bg: #081533;
                --bg-2: #0d214a;
                --panel: rgba(246, 248, 252, 0.98);
                --panel-soft: rgba(255, 255, 255, 0.14);
                --text: #0c1f3f;
                --muted: #64748b;
                --line: rgba(16, 24, 40, 0.08);
                --primary: #2156d8;
                --primary-dark: #163fa4;
                --success: #14b87a;
                --warning: #d89015;
                --danger: #ea6d6d;
                --radius: 24px;
                --shadow: 0 28px 60px rgba(6, 12, 31, 0.28);
            }

            * { box-sizing: border-box; }

            body {
                margin: 0;
                min-height: 100vh;
                font-family: 'Poppins', 'Segoe UI', sans-serif;
                color: #f8fbff;
                background:
                    radial-gradient(circle at top left, rgba(56, 103, 214, 0.35), transparent 30%),
                    radial-gradient(circle at bottom right, rgba(34, 197, 94, 0.18), transparent 25%),
                    linear-gradient(135deg, var(--bg), #071024 65%, #050b18);
            }

            a { color: inherit; text-decoration: none; }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            .sidebar {
                padding: 24px 18px;
                background: linear-gradient(180deg, rgba(6, 12, 28, 0.9), rgba(10, 23, 56, 0.94));
                border-right: 1px solid rgba(255, 255, 255, 0.06);
                position: sticky;
                top: 0;
                height: 100vh;
                width: 92px;
                overflow: hidden;
                transition: width 0.24s ease;
                flex-shrink: 0;
                display: flex;
                flex-direction: column;
                gap: 10px;
            }

            .sidebar:hover {
                width: 280px;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 12px;
                font-size: 1.15rem;
                font-weight: 800;
                margin-bottom: 28px;
                white-space: nowrap;
            }

            .brand span:last-child,
            .sidebar .nav-item {
                opacity: 0;
                transition: opacity 0.18s ease;
            }

            .sidebar:hover .brand span:last-child,
            .sidebar:hover .nav-item {
                opacity: 1;
            }

            .brand-dot {
                width: 14px;
                height: 14px;
                border-radius: 999px;
                background: linear-gradient(135deg, #6ee7ff, #3b82f6);
                box-shadow: 0 0 0 6px rgba(59, 130, 246, 0.15);
            }

            .nav-list {
                display: grid;
                gap: 10px;
                margin-top: 18px;
            }

            .sidebar-footer {
                margin-top: auto;
                background: rgba(39, 85, 185, 0.2);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 16px;
                text-align: center;
                padding: 14px 12px;
                color: rgba(255, 255, 255, 0.9);
                font-weight: 600;
                white-space: nowrap;
            }

            .nav-item {
                padding: 16px 18px;
                border-radius: 18px;
                color: rgba(255, 255, 255, 0.9);
                background: transparent;
                border: 1px solid transparent;
                transition: 0.2s ease;
                white-space: nowrap;
            }

            .nav-item:hover,
            .nav-item.is-active {
                background: rgba(39, 85, 185, 0.22);
                border-color: rgba(255, 255, 255, 0.08);
                box-shadow: inset 0 0 0 1px rgba(111, 168, 255, 0.12);
            }

            .content {
                padding: 26px 24px 36px;
                flex: 1;
                min-width: 0;
            }

            .topbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                gap: 16px;
                margin-bottom: 18px;
            }

            .page-title {
                margin: 0;
                font-size: clamp(2rem, 2.8vw, 3rem);
                font-weight: 800;
                letter-spacing: -0.03em;
            }

            .subtitle {
                margin: 6px 0 0;
                color: rgba(232, 240, 255, 0.75);
                font-size: 0.98rem;
            }

            .logout-btn {
                padding: 12px 18px;
                border-radius: 16px;
                background: linear-gradient(135deg, #2156d8, #1b4ab7);
                color: #fff;
                font-weight: 600;
                box-shadow: 0 16px 34px rgba(33, 86, 216, 0.28);
            }

            .module-nav {
                margin-bottom: 18px;
                display: inline-flex;
                align-items: center;
                gap: 10px;
                padding: 8px;
                border-radius: 16px;
                background: rgba(255, 255, 255, 0.12);
                backdrop-filter: blur(6px);
                border: 1px solid rgba(255, 255, 255, 0.08);
            }

            .module-link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 10px 16px;
                border-radius: 12px;
                font-weight: 600;
                color: rgba(236, 244, 255, 0.88);
                transition: 0.2s ease;
            }

            .module-link:hover {
                color: #ffffff;
                background: rgba(255, 255, 255, 0.1);
            }

            .module-link.is-active {
                background: #ffffff;
                color: #0f2b64;
                box-shadow: 0 10px 20px rgba(9, 19, 45, 0.2);
            }

            @media (max-width: 960px) {
                .app-shell { display: block; }
                .sidebar {
                    position: static;
                    height: auto;
                    width: 100%;
                    overflow: visible;
                }
                .brand span:last-child,
                .sidebar .nav-item {
                    opacity: 1;
                }

                .sidebar-footer {
                    margin-top: 12px;
                }
            }
        </style>
        {% block styles %}{% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>

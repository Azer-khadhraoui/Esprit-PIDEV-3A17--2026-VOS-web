{% extends 'gestion_offre_base.html.twig' %}

{% block title %}Gestion Contrats | VOS{% endblock %}

{% block styles %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-shell">
    <aside class="sidebar">
        <div class="brand">
            <span class="brand-dot"></span>
            <span>VOS Admin</span>
        </div>
        <nav class="nav-list">
            <a class="nav-item" href="{{ path('app_admin_dashboard') }}">Gestion Users</a>
            <a class="nav-item" href="{{ path('gestion_offre_dashboard') }}">Gestion Offres</a>
            <a class="nav-item" href="{{ path('app_admin_candidatures') }}">Gestion Candidatures</a>
            <a class="nav-item" href="{{ path('gestion_entretien_dashboard') }}">Gestion Entretiens</a>
            <a class="nav-item is-active" href="{{ path('recrutement_index') }}">Gestion Recrutements</a>
            <a class="nav-item" href="#">Forum</a>
            <a class="nav-item" href="#">Rapports</a>
        </nav>
        <div class="sidebar-footer">Panel Administration</div>
    </aside>

    <main class="content">
        <header class="topbar">
            <div>
                <h1>Gestion des contrats</h1>
                <p>Liste des contrats d'embauche</p>
            </div>
            <a href="{{ path('contrat_embauche_new') }}" class="btn-logout">Nouveau contrat</a>
        </header>

        <div class="module-nav">
            <a class="module-link" href="{{ path('recrutement_index') }}">Recrutements</a>
            <a class="module-link is-active" href="{{ path('contrat_embauche_index') }}">Contrats</a>
            <a class="module-link" href="{{ path('recrutement_statistique') }}">Statistiques</a>
        </div>

        <section class="stats-grid">
            <article class="stat-card stat-total">
                <h3>Total contrats</h3>
                <p>{{ stats.total }}</p>
            </article>
            <article class="stat-card stat-admins">
                <h3>Actifs</h3>
                <p>{{ stats.actifs }}</p>
            </article>
            <article class="stat-card stat-clients">
                <h3>Termines</h3>
                <p>{{ stats.termines }}</p>
            </article>
        </section>

        {% for message in app.flashes('success') %}
            <div class="flash flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash flash-error">{{ message }}</div>
        {% endfor %}

        <section class="table-card">
            <div class="table-head">
                <h2>Contrats d'embauche</h2>
                <span class="table-badge">{{ contrats|length }} entrees</span>
            </div>

            <div class="search-filters">
                <form method="get" action="{{ path('contrat_embauche_index') }}" class="filter-grid">
                    <div class="filter-item filter-item-search">
                        <label for="contrat-search">Recherche</label>
                        <input id="contrat-search" class="search-input" type="text" name="search" value="{{ filters.search|default('') }}" placeholder="Type, statut, volume horaire...">
                    </div>

                    <div class="filter-item">
                        <label for="contrat-status">Statut</label>
                        <select id="contrat-status" name="status" class="sort-select">
                            <option value="">Tous</option>
                            {% for option in statusOptions %}
                                <option value="{{ option }}" {{ filters.status|default('') == option ? 'selected' : '' }}>{{ option }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="filter-item">
                        <label for="contrat-type">Type contrat</label>
                        <select id="contrat-type" name="typeContrat" class="sort-select">
                            <option value="">Tous</option>
                            {% for option in typeContratOptions %}
                                <option value="{{ option }}" {{ filters.typeContrat|default('') == option ? 'selected' : '' }}>{{ option }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="filter-item">
                        <label for="contrat-sortBy">Trier par</label>
                        <select id="contrat-sortBy" name="sortBy" class="sort-select">
                            <option value="dateDebut" {{ filters.sortBy|default('dateDebut') == 'dateDebut' ? 'selected' : '' }}>Date debut</option>
                            <option value="dateFin" {{ filters.sortBy|default('dateDebut') == 'dateFin' ? 'selected' : '' }}>Date fin</option>
                            <option value="typeContrat" {{ filters.sortBy|default('dateDebut') == 'typeContrat' ? 'selected' : '' }}>Type contrat</option>
                            <option value="status" {{ filters.sortBy|default('dateDebut') == 'status' ? 'selected' : '' }}>Statut</option>
                            <option value="salaire" {{ filters.sortBy|default('dateDebut') == 'salaire' ? 'selected' : '' }}>Salaire</option>
                        </select>
                    </div>

                    <div class="filter-item">
                        <label for="contrat-sortOrder">Ordre</label>
                        <select id="contrat-sortOrder" name="sortOrder" class="sort-select">
                            <option value="DESC" {{ filters.sortOrder|default('DESC') == 'DESC' ? 'selected' : '' }}>Decroissant</option>
                            <option value="ASC" {{ filters.sortOrder|default('DESC') == 'ASC' ? 'selected' : '' }}>Croissant</option>
                        </select>
                    </div>

                    <div class="filter-actions">
                        <button type="submit" class="btn-filter">Filtrer</button>
                        <a href="{{ path('contrat_embauche_index') }}" class="btn-reset">Reset</a>
                    </div>
                </form>
            </div>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Type</th>
                            <th>Debut</th>
                            <th>Fin</th>
                            <th>Periode</th>
                            <th>Salaire</th>
                            <th>Statut</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for contrat in contrats %}
                            <tr>
                                <td>{{ contrat.id }}</td>
                                <td>{{ contrat.typeContrat }}</td>
                                <td>{{ contrat.dateDebut ? contrat.dateDebut|date('d/m/Y') : '-' }}</td>
                                <td>{{ contrat.dateFin ? contrat.dateFin|date('d/m/Y') : '-' }}</td>
                                <td>{{ contrat.periode ?: '-' }}</td>
                                <td>{{ contrat.salaire }}</td>
                                <td>{{ contrat.status }}</td>
                                <td>
                                    <div class="actions">
                                        <a class="btn-edit" href="{{ path('contrat_embauche_edit', {id: contrat.id}) }}">Modifier</a>
                                        <form method="post" action="{{ path('contrat_embauche_send_reminder', {id: contrat.id}) }}" onsubmit="return confirm('Envoyer un mail de rappel pour ce contrat ?');" novalidate>
                                            <input type="hidden" name="_token" value="{{ csrf_token('send_reminder_contrat_' ~ contrat.id) }}">
                                            <button class="btn-filter" type="submit">Generer mail avec IA</button>
                                        </form>
                                        <form method="post" action="{{ path('contrat_embauche_delete', {id: contrat.id}) }}" onsubmit="return confirm('Supprimer ce contrat ?');" novalidate>
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_contrat_' ~ contrat.id) }}">
                                            <button class="btn-delete" type="submit">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8">Aucun contrat trouve.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>
{% endblock %}

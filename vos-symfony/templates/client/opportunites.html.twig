<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Opportunites | VOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f7f8fc;
            --panel: #ffffff;
            --line: #e8ebf3;
            --text: #1b2440;
            --muted: #6c7693;
            --primary: #4361ee;
            --open: #16a34a;
            --closed: #dc2626;
        }

        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: 'Poppins', 'Segoe UI', sans-serif;
            background:
                radial-gradient(1100px 520px at 14% 6%, rgba(67,97,238,0.18), transparent 50%),
                radial-gradient(1200px 680px at 88% 110%, rgba(67,97,238,0.22), transparent 58%),
                linear-gradient(180deg, #f9fbff 0%, #eef3ff 100%);
            color: var(--text);
            animation: pageFadeIn 0.45s ease;
        }

        @keyframes pageFadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes slideDownSoft {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes riseIn {
            from { opacity: 0; transform: translateY(14px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes brandFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-3px); }
        }

        @keyframes brandShine {
            0% { background-position: 0% 50%; }
            100% { background-position: 100% 50%; }
        }

        .header {
            background: #fff;
            border-bottom: 1px solid var(--line);
            position: sticky;
            top: 0;
            z-index: 30;
        }

        .header-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 18px;
            gap: 16px;
            animation: slideDownSoft 0.5s ease;
        }

        .brand {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            background: linear-gradient(90deg, #0f2b64, #1d4ed8, #0f2b64);
            background-size: 220% 220%;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: brandFloat 2.3s ease-in-out infinite, brandShine 3.8s linear infinite;
        }

        .nav {
            display: flex;
            gap: 24px;
            color: var(--muted);
            font-weight: 600;
        }

        .nav a { text-decoration: none; color: inherit; }
        .nav a.is-active { color: var(--primary); }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .signup {
            border: 0;
            border-radius: 999px;
            padding: 10px 16px;
            background: var(--primary);
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.18s ease, box-shadow 0.2s ease, filter 0.2s ease;
            box-shadow: 0 8px 18px rgba(67, 97, 238, 0.24);
        }

        .signup:hover {
            transform: translateY(-1px);
            filter: brightness(1.03);
        }

        .logout-btn {
            border: 0;
            border-radius: 999px;
            padding: 10px 16px;
            background: rgba(67, 97, 238, 0.14);
            color: #1d4ed8;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            transition: transform 0.18s ease, background 0.2s ease;
        }

        .logout-btn:hover {
            background: rgba(67, 97, 238, 0.24);
            transform: translateY(-1px);
        }

        .container {
            max-width: 1200px;
            margin: 22px auto;
            padding: 0 18px 26px;
            animation: riseIn 0.55s ease;
        }

        h1 {
            margin: 0 0 14px;
            font-size: 2.1rem;
            letter-spacing: -0.02em;
        }

        .flash {
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 10px;
            font-weight: 600;
        }
        .flash.success { background: #dcfce7; color: #166534; }
        .flash.error { background: #fee2e2; color: #991b1b; }

        .filters {
            background: #f1f3f9;
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 16px;
            display: grid;
            gap: 10px;
            margin-bottom: 16px;
        }

        .filters .row {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 10px;
        }

        .filters input,
        .filters select {
            border: 1px solid #d9deea;
            border-radius: 10px;
            padding: 10px 12px;
            font-family: inherit;
            font-size: 0.95rem;
            background: #fff;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .filters input:focus,
        .filters select:focus {
            outline: none;
            border-color: #9fb1ff;
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.12);
        }

        .filter-actions {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            margin-top: 10px;
        }

        .filter-actions .group {
            display: flex;
            gap: 12px;
            align-items: center;
            justify-content: flex-start;
            grid-column: 1;
        }

        .btn {
            border: 0;
            border-radius: 10px;
            padding: 9px 14px;
            background: var(--primary);
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.18s ease, filter 0.2s ease;
        }

        .btn:hover {
            transform: translateY(-1px);
            filter: brightness(1.03);
        }

        .btn-link {
            text-decoration: none;
            color: var(--primary);
            font-weight: 700;
        }

        .results-count {
            color: var(--muted);
            font-weight: 600;
            margin-bottom: 10px;
        }

        .admin-back-wrap {
            margin: 0 0 12px;
            display: flex;
            justify-content: flex-end;
        }

        .admin-back-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 7px 11px;
            border-radius: 10px;
            border: 1px solid #c7d2fe;
            background: #eef2ff;
            color: #3730a3;
            font-weight: 700;
            font-size: 0.82rem;
            text-decoration: none;
        }

        .pagination {
            margin-top: 18px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .pagination-link {
            min-width: 38px;
            height: 38px;
            border: 1px solid #d5dcf0;
            border-radius: 10px;
            background: #fff;
            color: #2a3560;
            font-weight: 700;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 10px;
        }

        .pagination-link:hover {
            border-color: #9fb1ff;
            color: #2844cc;
        }

        .pagination-link.is-current {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 14px;
        }

        .card {
            background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 15px;
            display: grid;
            gap: 10px;
            box-shadow: 0 14px 34px rgba(16, 24, 40, 0.07);
            opacity: 0;
            transform: translateY(14px);
            animation: riseIn 0.45s ease forwards;
            transition: transform 0.22s ease, box-shadow 0.24s ease;
        }

        .card:nth-child(1) { animation-delay: 0.03s; }
        .card:nth-child(2) { animation-delay: 0.06s; }
        .card:nth-child(3) { animation-delay: 0.09s; }
        .card:nth-child(4) { animation-delay: 0.12s; }
        .card:nth-child(5) { animation-delay: 0.15s; }
        .card:nth-child(6) { animation-delay: 0.18s; }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 42px rgba(67, 97, 238, 0.12);
        }

        .card h3 {
            margin: 0;
            font-size: 1.25rem;
            letter-spacing: -0.02em;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 5px 10px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            width: fit-content;
        }

        .badge.contract { background: #e0e7ff; color: #1d4ed8; }
        .badge.open { background: #dcfce7; color: #166534; }
        .badge.closed { background: #fee2e2; color: #991b1b; }

        .meta { color: var(--muted); font-size: 0.92rem; display: grid; gap: 3px; }

        .apply-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-top: 2px;
        }

        .actions-right {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .apply-btn {
            border: 0;
            border-radius: 10px;
            padding: 8px 12px;
            background: var(--primary);
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.18s ease, filter 0.2s ease;
        }

        .apply-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.08);
        }

        .details-btn {
            border: 0;
            border-radius: 10px;
            padding: 8px 12px;
            background: #e0e7ff;
            color: #1d4ed8;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.18s ease, background 0.2s ease;
        }

        .details-btn:hover {
            transform: translateY(-1px);
            background: #cfdaff;
        }

        .lang-switch {
            display: inline-flex;
            border: 1px solid #d9deea;
            border-radius: 999px;
            overflow: hidden;
            background: #fff;
        }

        .lang-btn {
            border: 0;
            background: transparent;
            color: #4b587c;
            font-weight: 700;
            font-size: 0.74rem;
            padding: 5px 9px;
            cursor: pointer;
            font-family: inherit;
        }

        .lang-btn.is-active {
            background: #e0e7ff;
            color: #1d4ed8;
        }

        .modal {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(2, 6, 23, 0.52);
            z-index: 100;
            padding: 16px;
        }

        .modal-card {
            background: #fff;
            width: min(520px, 100%);
            border-radius: 14px;
            overflow: hidden;
        }

        .modal-card.details {
            width: min(760px, 100%);
            max-height: calc(100vh - 32px);
            overflow: auto;
            animation: riseIn 0.25s ease;
        }

        .modal-head {
            padding: 12px 14px;
            border-bottom: 1px solid var(--line);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 700;
        }

        .modal-body {
            padding: 14px;
            display: grid;
            gap: 10px;
        }

        .modal-body input,
        .modal-body textarea {
            border: 1px solid #d9deea;
            border-radius: 10px;
            padding: 10px 12px;
            font-family: inherit;
            font-size: 0.94rem;
            width: 100%;
        }

        .modal-actions { display: flex; justify-content: flex-end; gap: 8px; }

        .details-head {
            padding: 16px 18px;
            border-bottom: 1px solid var(--line);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
        }

        .details-title { margin: 0; font-size: 1.95rem; line-height: 1.1; letter-spacing: -0.02em; }

        .details-meta-grid {
            margin: 14px 18px;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            background: #f4f6fc;
            border-radius: 12px;
            padding: 12px;
        }

        .details-meta-grid .meta-item { color: var(--muted); font-size: 0.92rem; }
        .details-meta-grid strong { display: block; color: var(--text); font-size: 1.02rem; margin-top: 2px; }

        .details-section { padding: 0 18px 12px; }
        .details-section h4 { margin: 10px 0 8px; font-size: 1.25rem; }
        .details-section p { margin: 0; color: #5b647f; line-height: 1.55; }
        .details-list { margin: 0; padding-left: 22px; color: #5b647f; line-height: 1.8; }

        .details-footer {
            padding: 0 18px 18px;
            display: flex;
            justify-content: flex-end;
        }

        .cancel {
            border: 0;
            border-radius: 10px;
            padding: 9px 12px;
            background: #e2e8f0;
            color: #0f172a;
            font-weight: 700;
            cursor: pointer;
        }

        .chatbot-fab {
            position: fixed;
            right: 18px;
            bottom: 18px;
            width: 58px;
            height: 58px;
            border: 0;
            border-radius: 50%;
            background: linear-gradient(135deg, #1d4ed8, #4361ee);
            color: #fff;
            font-size: 1.55rem;
            box-shadow: 0 16px 32px rgba(67, 97, 238, 0.32);
            cursor: pointer;
            z-index: 120;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .chatbot-fab:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(67, 97, 238, 0.38);
        }

        .chatbot-panel {
            position: fixed;
            right: 18px;
            bottom: 86px;
            width: min(380px, calc(100vw - 24px));
            max-height: min(72vh, 620px);
            background: #fff;
            border: 1px solid #dbe2f0;
            border-radius: 16px;
            box-shadow: 0 24px 56px rgba(15, 23, 42, 0.2);
            z-index: 125;
            display: none;
            overflow: hidden;
        }

        .chatbot-panel.is-open {
            display: grid;
            grid-template-rows: auto 1fr auto;
            animation: riseIn 0.2s ease;
        }

        .chatbot-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 14px;
            background: #f4f7ff;
            border-bottom: 1px solid #dbe2f0;
        }

        .chatbot-title {
            margin: 0;
            font-size: 0.95rem;
            font-weight: 800;
            color: #1f2a49;
        }

        .chatbot-subtitle {
            margin: 2px 0 0;
            color: #64748b;
            font-size: 0.78rem;
        }

        .chatbot-close {
            border: 0;
            background: #e2e8f0;
            color: #1e293b;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
        }

        .chatbot-messages {
            padding: 12px;
            overflow-y: auto;
            display: grid;
            gap: 8px;
            background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
        }

        .chatbot-bubble {
            border-radius: 12px;
            padding: 10px 11px;
            font-size: 0.88rem;
            line-height: 1.4;
            max-width: 90%;
            white-space: pre-wrap;
        }

        .chatbot-bubble.user {
            margin-left: auto;
            background: #1d4ed8;
            color: #fff;
        }

        .chatbot-bubble.bot {
            margin-right: auto;
            background: #eef2ff;
            color: #1e293b;
        }

        .chatbot-reco-list {
            margin-top: 6px;
            display: grid;
            gap: 6px;
        }

        .chatbot-reco-item {
            border: 1px solid #dbe2f0;
            background: #fff;
            border-radius: 10px;
            padding: 8px;
            display: grid;
            gap: 4px;
        }

        .chatbot-reco-head {
            display: flex;
            justify-content: space-between;
            gap: 6px;
            align-items: center;
        }

        .chatbot-reco-title {
            margin: 0;
            font-size: 0.86rem;
            font-weight: 700;
            color: #1e293b;
        }

        .chatbot-reco-meta {
            margin: 0;
            color: #64748b;
            font-size: 0.76rem;
        }

        .chatbot-open-offer {
            border: 0;
            border-radius: 8px;
            background: #dbeafe;
            color: #1d4ed8;
            font-weight: 700;
            font-size: 0.74rem;
            padding: 6px 8px;
            cursor: pointer;
            white-space: nowrap;
        }

        .chatbot-form {
            border-top: 1px solid #dbe2f0;
            padding: 10px;
            display: grid;
            gap: 8px;
            background: #fff;
        }

        .chatbot-input {
            border: 1px solid #d3dbef;
            border-radius: 10px;
            padding: 9px 10px;
            font-family: inherit;
            font-size: 0.9rem;
        }

        .chatbot-input:focus {
            outline: none;
            border-color: #9fb1ff;
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.12);
        }

        .chatbot-submit {
            border: 0;
            border-radius: 10px;
            background: #1d4ed8;
            color: #fff;
            font-weight: 700;
            padding: 8px 10px;
            cursor: pointer;
        }

        .chatbot-submit:disabled {
            background: #9aa9dd;
            cursor: not-allowed;
        }

        @media (max-width: 980px) {
            .filters .row { grid-template-columns: 1fr 1fr; }
            .filter-actions { grid-template-columns: 1fr 1fr; }
            .cards { grid-template-columns: 1fr 1fr; }
        }

        @media (max-width: 680px) {
            .nav { display: none; }
            .filters .row { grid-template-columns: 1fr; }
            .filter-actions { grid-template-columns: 1fr; }
            .cards { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
{{ include('client/_client_header.html.twig', { userName: userName|default('Utilisateur'), activePage: 'opportunites' }) }}

<main class="container">
    <h1>Opportunites</h1>

    {% if isAdminAuthenticated|default(false) %}
        <div class="admin-back-wrap">
            <a class="admin-back-btn" href="{{ path('app_admin_dashboard') }}">Retour dashboard admin</a>
        </div>
    {% endif %}

    {% for message in app.flashes('success') %}
        <div class="flash success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash error">{{ message }}</div>
    {% endfor %}

    <form class="filters" method="get" action="{{ path('client_opportunites') }}">
        <div class="row" style="grid-template-columns:1fr;">
            <input type="text" name="q" value="{{ filters.q ?? '' }}" placeholder="Rechercher une opportunite...">
        </div>
        <div class="row">
            <select name="type_contrat">
                <option value="">Type contrat</option>
                {% for option in filterOptions.typesContrat %}
                    <option value="{{ option }}" {{ (filters.type_contrat ?? '') == option ? 'selected' : '' }}>{{ option }}</option>
                {% endfor %}
            </select>
            <select name="work_preference">
                <option value="">Mode travail</option>
                {% for option in filterOptions.workPreferences %}
                    <option value="{{ option }}" {{ (filters.work_preference ?? '') == option ? 'selected' : '' }}>{{ option }}</option>
                {% endfor %}
            </select>
            <input type="text" name="lieu" value="{{ filters.lieu ?? '' }}" placeholder="Lieu">
            <select name="statut">
                <option value="">Statut</option>
                {% for option in filterOptions.statuts %}
                    <option value="{{ option }}" {{ (filters.statut ?? '') == option ? 'selected' : '' }}>{{ option }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="filter-actions">
            <div class="group">
                <button class="btn" type="submit">Rechercher</button>
                <a class="btn-link" href="{{ path('client_opportunites') }}">Effacer</a>
            </div>
        </div>
    </form>

    <div class="results-count">{{ pagination.total }} resultats</div>

    <section class="cards">
        {% for offer in offers %}
            {% set critere = criteriaByOffer[offer.idOffre] ?? null %}
            <article class="card">
                <h3>{{ offer.titre ?? 'Offre sans titre' }}</h3>
                <span class="badge contract">{{ offer.typeContrat ?? 'N/A' }}</span>

                <div class="meta">
                    <div>{{ offer.lieu ?? 'Lieu non precise' }}</div>
                    <div>{{ offer.workPreference ?? 'Mode non precise' }}</div>
                    <div>{{ offer.datePublication ? offer.datePublication|date('d/m/Y') : 'Date non precisee' }}</div>
                </div>

                <div style="color:#5b647f;line-height:1.35;min-height:42px;">
                    {{ offer.description ? offer.description|slice(0, 120) ~ (offer.description|length > 120 ? '...' : '') : 'Aucune description.' }}
                </div>

                <div class="apply-row">
                    <span class="badge {{ offer.statutOffre == 'OUVERTE' ? 'open' : 'closed' }}">{{ offer.statutOffre ?? 'N/A' }}</span>
                    <div class="actions-right">
                        <button type="button" class="details-btn open-offer-details" data-offer-id="{{ offer.idOffre }}">Voir details</button>
                    </div>
                </div>

                <template id="offer-details-{{ offer.idOffre }}">
                    <div class="details-head">
                        <div>
                            <h3 class="details-title">{{ offer.titre ?? 'Offre' }}</h3>
                            <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;">
                                <span class="badge contract">{{ offer.typeContrat ?? 'N/A' }}</span>
                                <span class="badge {{ offer.statutOffre == 'OUVERTE' ? 'open' : 'closed' }}">{{ offer.statutOffre ?? 'N/A' }}</span>
                            </div>
                        </div>
                    </div>

                    <div class="details-meta-grid">
                        <div class="meta-item">Lieu<strong>{{ offer.lieu ?? 'Non precise' }}</strong></div>
                        <div class="meta-item">Mode de travail<strong>{{ offer.workPreference ?? 'Non precise' }}</strong></div>
                        <div class="meta-item">Date de publication<strong>{{ offer.datePublication ? offer.datePublication|date('d/m/Y') : 'Non precisee' }}</strong></div>
                    </div>

                    <div class="details-section">
                        <h4>Description du poste</h4>
                        <p>{{ offer.description ?? 'Aucune description disponible.' }}</p>
                    </div>

                    <div class="details-section">
                        <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
                            <h4>Profil recherche</h4>
                            <div class="lang-switch" data-criteria-switch="{{ offer.idOffre }}">
                                <button type="button" class="lang-btn criteria-lang-btn is-active" data-lang="FR" data-offer-id="{{ offer.idOffre }}">FR</button>
                                <button type="button" class="lang-btn criteria-lang-btn" data-lang="EN" data-offer-id="{{ offer.idOffre }}">EN</button>
                            </div>
                        </div>
                        <ul
                            class="details-list criteria-profile-list"
                            data-offer-id="{{ offer.idOffre }}"
                            data-fr-niveau-experience="{{ (critere.niveau_experience ?? '')|e('html_attr') }}"
                            data-fr-niveau-etude="{{ (critere.niveau_etude ?? '')|e('html_attr') }}"
                            data-fr-competences="{{ (critere.competences_requises ?? '')|e('html_attr') }}"
                        >
                            {% if critere and critere.niveau_experience %}<li>{{ critere.niveau_experience }}</li>{% endif %}
                            {% if critere and critere.niveau_etude %}<li>{{ critere.niveau_etude }}</li>{% endif %}
                            {% if critere and critere.competences_requises %}
                                {% for item in critere.competences_requises|replace({'\r': ''})|split('\n') %}
                                    {% if item|trim != '' %}<li>{{ item|trim }}</li>{% endif %}
                                {% endfor %}
                            {% endif %}
                            {% if not critere %}<li>Profil non precise.</li>{% endif %}
                        </ul>
                    </div>

                    <div class="details-section" style="padding-bottom:18px;">
                        <h4>Responsabilites</h4>
                        <ul class="details-list criteria-responsibilities-list" data-offer-id="{{ offer.idOffre }}" data-fr-responsibilities="{{ (critere.responsibilities ?? '')|e('html_attr') }}">
                            {% if critere and critere.responsibilities %}
                                {% for item in critere.responsibilities|replace({'\r': ''})|split('\n') %}
                                    {% if item|trim != '' %}<li>{{ item|trim }}</li>{% endif %}
                                {% endfor %}
                            {% else %}
                                <li>Responsabilites non precisees.</li>
                            {% endif %}
                        </ul>
                    </div>

                    <div class="details-footer">
                        {% if isClientAuthenticated|default(false) %}
                            <a
                                href="{{ path('app_client_candidature_new', {id_offre: offer.idOffre}) }}"
                                class="apply-btn"
                                style="display:inline-block;text-align:center;text-decoration:none;"
                            >Postuler</a>
                        {% else %}
                            <span style="color:#64748b;font-weight:600;">Mode lecture seule (admin)</span>
                        {% endif %}
                    </div>
                </template>
            </article>
        {% else %}
            <article class="card" style="grid-column:1/-1;">Aucune offre correspondante.</article>
        {% endfor %}
    </section>

    {% if pagination.totalPages > 1 %}
        {% set baseQuery = {
            q: filters.q ?? null,
            type_contrat: filters.type_contrat ?? null,
            work_preference: filters.work_preference ?? null,
            lieu: filters.lieu ?? null,
            statut: filters.statut ?? null
        } %}

        <nav class="pagination" aria-label="Pagination des opportunites">
            {% if pagination.page > 1 %}
                <a class="pagination-link" href="{{ path('client_opportunites', baseQuery|merge({page: pagination.page - 1})) }}">&lsaquo;</a>
            {% endif %}

            {% for p in 1..pagination.totalPages %}
                <a
                    class="pagination-link {{ p == pagination.page ? 'is-current' : '' }}"
                    href="{{ path('client_opportunites', baseQuery|merge({page: p})) }}"
                >{{ p }}</a>
            {% endfor %}

            {% if pagination.page < pagination.totalPages %}
                <a class="pagination-link" href="{{ path('client_opportunites', baseQuery|merge({page: pagination.page + 1})) }}">&rsaquo;</a>
            {% endif %}
        </nav>
    {% endif %}
</main>

<div id="details-modal" class="modal">
    <div class="modal-card details">
        <div class="modal-head">
            <span>Details opportunite</span>
            <button id="close-details-modal" class="cancel" type="button">X</button>
        </div>
        <div id="details-modal-body"></div>
    </div>
</div>

<button id="chatbot-fab" class="chatbot-fab" type="button" aria-label="Ouvrir assistant emploi">AI</button>
<section id="chatbot-panel" class="chatbot-panel" aria-live="polite" aria-label="Assistant offres">
    <header class="chatbot-head">
        <div>
            <h2 class="chatbot-title">Assistant Offres</h2>
            <p class="chatbot-subtitle">Decrivez votre job ideal, je filtre pour vous.</p>
        </div>
        <button id="chatbot-close" class="chatbot-close" type="button">X</button>
    </header>
    <div id="chatbot-messages" class="chatbot-messages">
        <div class="chatbot-bubble bot">Bonjour, je peux vous aider a trouver des offres. Essayez: "Je veux un CDI remote en data a Tunis".</div>
    </div>
    <form id="chatbot-form" class="chatbot-form">
        <input id="chatbot-input" class="chatbot-input" type="text" maxlength="280" placeholder="Ex: Stage developpement web a Sfax" required>
        <button id="chatbot-submit" class="chatbot-submit" type="submit">Trouver des offres</button>
    </form>
</section>

<script>
    (function () {
        const detailsModal = document.getElementById('details-modal');
        const detailsBody = document.getElementById('details-modal-body');
        const closeDetailsBtn = document.getElementById('close-details-modal');
        const criteriaCache = {};
        const chatbotFab = document.getElementById('chatbot-fab');
        const chatbotPanel = document.getElementById('chatbot-panel');
        const chatbotClose = document.getElementById('chatbot-close');
        const chatbotMessages = document.getElementById('chatbot-messages');
        const chatbotForm = document.getElementById('chatbot-form');
        const chatbotInput = document.getElementById('chatbot-input');
        const chatbotSubmit = document.getElementById('chatbot-submit');

        const closeDetailsModal = () => {
            if (!detailsModal || !detailsBody) return;
            detailsModal.style.display = 'none';
            detailsBody.innerHTML = '';
        };

        const openDetailsForOffer = (offerId) => {
            const trigger = document.querySelector(`.open-offer-details[data-offer-id="${offerId}"]`);
            if (!trigger) return;

            trigger.click();
            const card = trigger.closest('.card');
            if (card) {
                card.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        };

        const appendChatMessage = (author, text) => {
            if (!chatbotMessages) return;
            const bubble = document.createElement('div');
            bubble.className = `chatbot-bubble ${author}`;
            bubble.textContent = text;
            chatbotMessages.appendChild(bubble);
            chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
        };

        const appendRecommendations = (recommendations) => {
            if (!chatbotMessages || !Array.isArray(recommendations) || recommendations.length === 0) {
                return;
            }

            const wrapper = document.createElement('div');
            wrapper.className = 'chatbot-reco-list';

            recommendations.forEach((offer) => {
                const item = document.createElement('article');
                item.className = 'chatbot-reco-item';

                const head = document.createElement('div');
                head.className = 'chatbot-reco-head';

                const title = document.createElement('h3');
                title.className = 'chatbot-reco-title';
                title.textContent = offer.titre || 'Offre';

                const openBtn = document.createElement('button');
                openBtn.type = 'button';
                openBtn.className = 'chatbot-open-offer';
                openBtn.textContent = 'Voir details';
                openBtn.addEventListener('click', () => {
                    openDetailsForOffer(offer.idOffre);
                });

                head.appendChild(title);
                head.appendChild(openBtn);

                const meta = document.createElement('p');
                meta.className = 'chatbot-reco-meta';
                meta.textContent = `${offer.typeContrat || 'N/A'} | ${offer.workPreference || 'N/A'} | ${offer.lieu || 'N/A'}`;

                const desc = document.createElement('p');
                desc.className = 'chatbot-reco-meta';
                desc.textContent = offer.descriptionSnippet || '';

                item.appendChild(head);
                item.appendChild(meta);
                item.appendChild(desc);
                wrapper.appendChild(item);
            });

            chatbotMessages.appendChild(wrapper);
            chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
        };

        const setChatbotOpen = (open) => {
            if (!chatbotPanel) return;
            chatbotPanel.classList.toggle('is-open', open);
            if (open && chatbotInput) {
                chatbotInput.focus();
            }
        };

        document.querySelectorAll('.open-offer-details').forEach((button) => {
            button.addEventListener('click', () => {
                const id = button.getAttribute('data-offer-id');
                if (!id || !detailsModal || !detailsBody) return;

                const tpl = document.getElementById('offer-details-' + id);
                if (!tpl) return;

                detailsBody.innerHTML = tpl.innerHTML;
                detailsModal.style.display = 'flex';
            });
        });

        if (closeDetailsBtn) closeDetailsBtn.addEventListener('click', closeDetailsModal);
        if (detailsModal) {
            detailsModal.addEventListener('click', (event) => {
                if (event.target === detailsModal) {
                    closeDetailsModal();
                }
            });
        }

        if (chatbotFab) {
            chatbotFab.addEventListener('click', () => {
                const shouldOpen = !chatbotPanel?.classList.contains('is-open');
                setChatbotOpen(shouldOpen);
            });
        }

        if (chatbotClose) {
            chatbotClose.addEventListener('click', () => setChatbotOpen(false));
        }

        if (chatbotForm && chatbotInput && chatbotSubmit) {
            chatbotForm.addEventListener('submit', async (event) => {
                event.preventDefault();

                const message = chatbotInput.value.trim();
                if (message === '') {
                    return;
                }

                appendChatMessage('user', message);
                chatbotInput.value = '';
                chatbotSubmit.disabled = true;

                try {
                    const response = await fetch('{{ path('client_opportunites_chatbot_suggest') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ message }),
                    });

                    const payload = await response.json();
                    if (!response.ok) {
                        throw new Error(payload.message || 'Erreur assistant.');
                    }

                    appendChatMessage('bot', payload.assistantMessage || 'Voici ce que j ai trouve.');
                    appendRecommendations(payload.recommendations || []);
                } catch (error) {
                    appendChatMessage('bot', 'Je n ai pas pu traiter votre demande. Essayez une phrase plus precise.');
                } finally {
                    chatbotSubmit.disabled = false;
                    chatbotInput.focus();
                }
            });
        }

        const splitLines = (text) => {
            return (text || '')
                .replace(/\r/g, '')
                .split('\n')
                .map((line) => line.trim())
                .filter((line) => line.length > 0);
        };

        const setCriteriaLangButtonState = (offerId, activeLang) => {
            if (!detailsBody) return;
            detailsBody.querySelectorAll(`.criteria-lang-btn[data-offer-id="${offerId}"]`).forEach((btn) => {
                btn.classList.toggle('is-active', btn.getAttribute('data-lang') === activeLang);
            });
        };

        const renderList = (listEl, items, fallbackText) => {
            if (!listEl) return;

            const normalizedItems = items.filter((item) => item.trim() !== '');
            if (normalizedItems.length === 0) {
                listEl.innerHTML = `<li>${fallbackText}</li>`;
                return;
            }

            listEl.innerHTML = normalizedItems.map((item) => `<li>${item}</li>`).join('');
        };

        const renderCriteria = (offerId, criteriaData) => {
            if (!detailsBody) return;

            const profileList = detailsBody.querySelector(`.criteria-profile-list[data-offer-id="${offerId}"]`);
            const responsibilitiesList = detailsBody.querySelector(`.criteria-responsibilities-list[data-offer-id="${offerId}"]`);

            if (!profileList || !responsibilitiesList) return;

            const profileItems = [];
            if ((criteriaData.niveau_experience || '').trim() !== '') {
                profileItems.push(criteriaData.niveau_experience.trim());
            }
            if ((criteriaData.niveau_etude || '').trim() !== '') {
                profileItems.push(criteriaData.niveau_etude.trim());
            }

            splitLines(criteriaData.competences_requises || '').forEach((line) => {
                profileItems.push(line.replace(/^[-*]\s*/, '').trim());
            });

            renderList(profileList, profileItems, 'Profil non precise.');

            const responsibilitiesItems = splitLines(criteriaData.responsibilities || '').map((line) => line.replace(/^[-*]\s*/, '').trim());
            renderList(responsibilitiesList, responsibilitiesItems, 'Responsabilites non precisees.');
        };

        const getFrCriteriaFromDataset = (offerId) => {
            if (!detailsBody) return null;
            const profileList = detailsBody.querySelector(`.criteria-profile-list[data-offer-id="${offerId}"]`);
            const responsibilitiesList = detailsBody.querySelector(`.criteria-responsibilities-list[data-offer-id="${offerId}"]`);
            if (!profileList || !responsibilitiesList) {
                return null;
            }

            return {
                niveau_experience: profileList.dataset.frNiveauExperience || '',
                niveau_etude: profileList.dataset.frNiveauEtude || '',
                competences_requises: profileList.dataset.frCompetences || '',
                responsibilities: responsibilitiesList.dataset.frResponsibilities || '',
            };
        };

        if (detailsBody) {
            detailsBody.addEventListener('click', async (event) => {
                const button = event.target.closest('.criteria-lang-btn');
                if (!button) return;

                const offerId = button.getAttribute('data-offer-id');
                const lang = (button.getAttribute('data-lang') || 'FR').toUpperCase();
                if (!offerId) return;

                const cacheKey = `${offerId}_${lang}`;

                if (lang === 'FR') {
                    const frCriteria = getFrCriteriaFromDataset(offerId);
                    if (frCriteria) {
                        renderCriteria(offerId, frCriteria);
                    }
                    setCriteriaLangButtonState(offerId, 'FR');
                    return;
                }

                if (criteriaCache[cacheKey]) {
                    renderCriteria(offerId, criteriaCache[cacheKey]);
                    setCriteriaLangButtonState(offerId, lang);
                    return;
                }

                try {
                    button.disabled = true;

                    const params = new URLSearchParams({
                        id_offre: offerId,
                        lang: lang,
                    });

                    const response = await fetch(`{{ path('client_opportunites_translate_criteria') }}?${params.toString()}`, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    const payload = await response.json();
                    if (!response.ok) {
                        throw new Error(payload.message || 'Translation failed.');
                    }

                    const translatedData = {
                        niveau_experience: (payload.niveau_experience || '').trim(),
                        niveau_etude: (payload.niveau_etude || '').trim(),
                        competences_requises: (payload.competences_requises || '').trim(),
                        responsibilities: (payload.responsibilities || '').trim(),
                    };

                    criteriaCache[cacheKey] = translatedData;
                    renderCriteria(offerId, translatedData);
                    setCriteriaLangButtonState(offerId, lang);
                } catch (error) {
                    const frCriteria = getFrCriteriaFromDataset(offerId);
                    if (frCriteria) {
                        renderCriteria(offerId, frCriteria);
                    }
                    setCriteriaLangButtonState(offerId, 'FR');
                } finally {
                    button.disabled = false;
                }
            });
        }
    })();
</script>
</body>
</html>

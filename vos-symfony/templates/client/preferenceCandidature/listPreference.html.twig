<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes Préférences | VOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f7f8fc;
            --panel: #ffffff;
            --line: #e8ebf3;
            --text: #1b2440;
            --muted: #6c7693;
            --primary: #4361ee;
            --open: #16a34a;
            --closed: #dc2626;
        }

        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: 'Poppins', 'Segoe UI', sans-serif;
            background:
                radial-gradient(1100px 520px at 14% 6%, rgba(67,97,238,0.18), transparent 50%),
                radial-gradient(1200px 680px at 88% 110%, rgba(67,97,238,0.22), transparent 58%),
                linear-gradient(180deg, #f9fbff 0%, #eef3ff 100%);
            color: var(--text);
            animation: pageFadeIn 0.45s ease;
        }

        @keyframes pageFadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes slideDownSoft {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes riseIn {
            from { opacity: 0; transform: translateY(14px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes brandFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-3px); }
        }

        @keyframes brandShine {
            0% { background-position: 0% 50%; }
            100% { background-position: 100% 50%; }
        }

        .header {
            background: #fff;
            border-bottom: 1px solid var(--line);
            position: sticky;
            top: 0;
            z-index: 30;
        }

        .header-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 18px;
            gap: 16px;
            animation: slideDownSoft 0.5s ease;
        }

        .brand {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            background: linear-gradient(90deg, #0f2b64, #1d4ed8, #0f2b64);
            background-size: 220% 220%;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: brandFloat 2.3s ease-in-out infinite, brandShine 3.8s linear infinite;
        }

        .nav {
            display: flex;
            gap: 24px;
            color: var(--muted);
            font-weight: 600;
        }

        .nav a { text-decoration: none; color: inherit; }
        .nav a.is-active { color: var(--primary); }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .signup {
            border: 0;
            border-radius: 999px;
            padding: 10px 16px;
            background: var(--primary);
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.18s ease, box-shadow 0.2s ease, filter 0.2s ease;
            box-shadow: 0 8px 18px rgba(67, 97, 238, 0.24);
        }

        .signup:hover {
            transform: translateY(-1px);
            filter: brightness(1.03);
        }

        .logout-btn {
            border: 0;
            border-radius: 999px;
            padding: 10px 16px;
            background: rgba(67, 97, 238, 0.14);
            color: #1d4ed8;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            transition: transform 0.18s ease, background 0.2s ease;
        }

        .logout-btn:hover {
            background: rgba(67, 97, 238, 0.24);
            transform: translateY(-1px);
        }

        .container {
            max-width: 1200px;
            margin: 22px auto;
            padding: 0 18px 26px;
            animation: riseIn 0.55s ease;
        }

        h1 {
            margin: 0 0 14px;
            font-size: 2.1rem;
            letter-spacing: -0.02em;
        }


        .flash {
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 10px;
            font-weight: 600;
        }
        .flash.success { background: #dcfce7; color: #166534; }
        .flash.error { background: #fee2e2; color: #991b1b; }

        .controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            gap: 12px;
        }

        .btn-new {
            border: 0;
            border-radius: 10px;
            padding: 10px 16px;
            background: var(--primary);
            color: #fff;
            font-weight: 700;
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.18s ease, filter 0.2s ease;
        }

        .btn-new:hover {
            transform: translateY(-1px);
            filter: brightness(1.08);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 16px;
        }

        .card {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 18px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            animation: riseIn 0.5s ease;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 16px rgba(67, 97, 238, 0.14);
        }

        .card h3 {
            margin: 0 0 8px;
            font-size: 1.2rem;
            color: var(--text);
        }

        .card-detail {
            margin: 8px 0;
            font-size: 0.92rem;
            color: var(--muted);
        }

        .card-detail strong {
            color: var(--text);
        }

        .card-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
        }

        .btn-small {
            flex: 1;
            border: 0;
            border-radius: 8px;
            padding: 8px 12px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            text-decoration: none;
            transition: transform 0.18s ease, background 0.2s ease;
        }

        .btn-view {
            background: rgba(67, 97, 238, 0.12);
            color: var(--primary);
        }

        .btn-view:hover {
            background: rgba(67, 97, 238, 0.2);
            transform: translateY(-1px);
        }

        .btn-edit {
            background: rgba(22, 163, 74, 0.12);
            color: var(--success);
        }

        .btn-edit:hover {
            background: rgba(22, 163, 74, 0.2);
            transform: translateY(-1px);
        }

        .btn-delete {
            background: rgba(220, 38, 38, 0.12);
            color: var(--danger);
        }

        .btn-delete:hover {
            background: rgba(220, 38, 38, 0.2);
            transform: translateY(-1px);
        }

        .empty-state {
            text-align: center;
            padding: 60px 18px;
            color: var(--muted);
        }

        .empty-state h2 {
            margin: 0 0 10px;
            font-size: 1.5rem;
            color: var(--text);
        }

        @media (max-width: 680px) {
            .nav { display: none; }
            h1 { font-size: 1.6rem; }
            .grid { grid-template-columns: 1fr; }
            .controls { flex-direction: column; align-items: stretch; }
        }
    </style>
</head>
<body>
    {{ include('client/_client_header.html.twig', { userName: userName|default('Utilisateur'), activePage: 'preferences' }) }}

    <div class="container">
        <h1>Mes Préférences</h1>

        {% for message in app.flashes('success') %}
            <div class="flash success">✓ {{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash error">✗ {{ message }}</div>
        {% endfor %}

        <div class="controls">
            <div style="flex: 1;"></div>
            <a href="{{ path('app_client_preference_new') }}" class="btn-new">+ Nouvelle Préférence</a>
        </div>

        {% if preferences is empty %}
            <div class="empty-state">
                <h2>Aucune préférence</h2>
                <p>Créez votre première préférence pour définir vos critères de recherche.</p>
            </div>
        {% else %}
        {# ── Recherche avancée Préférences ── #}
<form method="GET" action="{{ path('app_client_preferences') }}" style="margin-bottom:20px;">
    <div style="background:#f1f3f9; border:1px solid #e8ebf3; border-radius:16px; padding:18px;">

        {# Ligne 1 #}
        <div style="display:grid; grid-template-columns:2fr 1fr 1fr; gap:10px; margin-bottom:10px;">

            <input type="text" name="poste" placeholder="🔍 Type de poste (Dev, Data...)"
                   value="{{ filtrePoste }}"
                   style="border:1px solid #d9deea; border-radius:10px; padding:10px 12px; font-family:inherit; background:#fff;">

            <select name="mode" style="border:1px solid #d9deea; border-radius:10px; padding:10px 12px; font-family:inherit; background:#fff;">
                <option value="">Tout mode de travail</option>
                {% for m in ['100% Présentiel', '100% Télétravail', 'Hybride'] %}
                    <option value="{{ m }}" {{ filtreMode == m ? 'selected' : '' }}>{{ m }}</option>
                {% endfor %}
            </select>

            <select name="contrat" style="border:1px solid #d9deea; border-radius:10px; padding:10px 12px; font-family:inherit; background:#fff;">
                <option value="">Tout type contrat</option>
                {% for c in ['CDI', 'CDD', 'Stage', 'Alternance', 'Freelance'] %}
                    <option value="{{ c }}" {{ filtreContrat == c ? 'selected' : '' }}>{{ c }}</option>
                {% endfor %}
            </select>
        </div>

        {# Ligne 2 #}
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:10px; align-items:center;">

            <select name="disponibilite" style="border:1px solid #d9deea; border-radius:10px; padding:10px 12px; font-family:inherit; background:#fff;">
                <option value="">Toute disponibilité</option>
                {% for d in ['Immédiatement', 'Dans 1 mois', 'Dans 3 mois', 'Dans 6 mois'] %}
                    <option value="{{ d }}" {{ filtreDisponible == d ? 'selected' : '' }}>{{ d }}</option>
                {% endfor %}
            </select>

            <input type="number" name="salaire_min" placeholder="Salaire min (TND)"
                   value="{{ filtreSalaireMin }}"
                   style="border:1px solid #d9deea; border-radius:10px; padding:10px 12px; font-family:inherit; background:#fff;">

            <input type="number" name="salaire_max" placeholder="Salaire max (TND)"
                   value="{{ filtreSalaireMax }}"
                   style="border:1px solid #d9deea; border-radius:10px; padding:10px 12px; font-family:inherit; background:#fff;">

            <div style="display:flex; gap:8px;">
                <button type="submit"
                        style="flex:1; border:0; border-radius:10px; padding:10px; background:#4361ee; color:#fff; font-weight:700; cursor:pointer; font-family:inherit;">
                    🔍 Filtrer
                </button>
                <a href="{{ path('app_client_preferences') }}"
                   style="flex:1; border:0; border-radius:10px; padding:10px; background:#e2e8f0; color:#1b2440; font-weight:700; cursor:pointer; font-family:inherit; text-decoration:none; text-align:center; display:flex; align-items:center; justify-content:center;">
                    ✕ Reset
                </a>
            </div>
        </div>

        {% set filtresActifs = (filtrePoste or filtreMode or filtreContrat or filtreDisponible or filtreSalaireMin or filtreSalaireMax) %}
        {% if filtresActifs %}
            <p style="margin:10px 0 0; font-size:0.88rem; color:#6c7693;">
                <strong>{{ preferences|length }}</strong> résultat(s)
                {% if filtreMode %} · Mode: <strong>{{ filtreMode }}</strong>{% endif %}
                {% if filtreContrat %} · Contrat: <strong>{{ filtreContrat }}</strong>{% endif %}
                {% if filtreDisponible %} · Dispo: <strong>{{ filtreDisponible }}</strong>{% endif %}
                {% if filtreSalaireMin or filtreSalaireMax %}
                    · Salaire: <strong>{{ filtreSalaireMin ?: '0' }} — {{ filtreSalaireMax ?: '∞' }} TND</strong>
                {% endif %}
            </p>
        {% endif %}
    </div>
</form>
            <div class="grid">
                {% for preference in preferences %}
                    <div class="card">
                        <h3>{{ preference.typePosteSouhaite ?? 'Sans titre' }}</h3>
                        <div class="card-detail">
                            <strong>Mode de travail:</strong> {{ preference.modeTravail ?? '-' }}
                        </div>
                        <div class="card-detail">
                            <strong>Disponiblité:</strong> {{ preference.disponibilite ?? '-' }}
                        </div>
                        <div class="card-detail">
                            <strong>Contrat souhaité:</strong> {{ preference.typeContratSouhaite ?? '-' }}
                        </div>
                        <div class="card-detail">
                            <strong>Salaire:</strong> {{ preference.pretentionSalariale ? preference.pretentionSalariale ~ ' TND' : '-' }}
                        </div>
                        <div class="card-actions">
                            <a href="{{ path('app_client_preference_detail', {id_preference: preference.idPreference}) }}" class="btn-small btn-view">Voir</a>
                            <a href="{{ path('app_client_preference_edit', {id_preference: preference.idPreference}) }}" class="btn-small btn-edit">Modifier</a>
                            <form method="POST" action="{{ path('app_client_preference_delete', {id_preference: preference.idPreference}) }}" style="flex: 1;" onsubmit="return confirm('Êtes-vous sûr?');" novalidate>
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ preference.idPreference) }}">
                                <button type="submit" class="btn-small btn-delete" style="width: 100%; margin: 0;">Supprimer</button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</body>
</html>

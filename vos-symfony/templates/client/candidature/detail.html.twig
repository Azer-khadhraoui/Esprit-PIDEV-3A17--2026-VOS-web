<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Détails de la candidature | VOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f7f8fc;
            --panel: #ffffff;
            --line: #e8ebf3;
            --text: #1b2440;
            --muted: #6c7693;
            --primary: #4361ee;
            --success: #16a34a;
        }

        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Poppins', 'Segoe UI', sans-serif;
            background:
                radial-gradient(1100px 520px at 14% 6%, rgba(67,97,238,0.18), transparent 50%),
                radial-gradient(1200px 680px at 88% 110%, rgba(67,97,238,0.22), transparent 58%),
                linear-gradient(180deg, #f9fbff 0%, #eef3ff 100%);
            color: var(--text);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .modal-card,
        .card {
            background: #fff;
            width: min(760px, 100%);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 24px 70px rgba(15, 23, 42, 0.14);
            animation: riseIn 0.28s ease;
            padding: 0;
        }

        .header {
            padding: 24px 24px 16px;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            border-bottom: 1px solid var(--line);
        }

        .header-title {
            margin: 0;
            font-size: 2rem;
            line-height: 1.05;
        }

        .label {
            display: inline-flex;
            gap: 8px;
            align-items: center;
            color: var(--muted);
            font-weight: 600;
            margin-top: 10px;
        }

        .content {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
            margin: 20px 24px 0;
            background: #f4f6fc;
            border-radius: 14px;
            padding: 18px;
        }

        .field {
            background: #fff;
            border-radius: 12px;
            padding: 16px;
            border: 1px solid rgba(226, 232, 240, 0.9);
        }

        .field h3 {
            margin: 0 0 10px;
            font-size: 0.95rem;
            color: var(--muted);
        }

        .field p {
            margin: 0;
            line-height: 1.7;
            color: var(--text);
            font-weight: 700;
        }

        .section {
            padding: 0 24px 22px;
            border-bottom: 1px solid var(--line);
        }

        .section:last-child {
            border-bottom: none;
        }

        .section h3 {
            margin: 16px 0 10px;
            font-size: 1.05rem;
            color: var(--text);
        }

        .section p,
        .section a {
            margin: 0;
            color: #475569;
            line-height: 1.7;
            text-decoration: none;
        }

        .section a:hover {
            text-decoration: underline;
        }

        .actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            padding: 18px 24px 24px;
        }

        .btn,
        .btn-light {
            border: 0;
            border-radius: 12px;
            padding: 12px 18px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.18s ease, filter 0.2s ease;
        }

        .btn {
            background: var(--primary);
            color: #fff;
        }

        .btn:hover {
            transform: translateY(-1px);
            filter: brightness(1.08);
        }

        .btn-light {
            background: #e2e8f0;
            color: var(--text);
        }

        .details-head {
            padding: 24px 24px 12px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 18px;
            border-bottom: 1px solid var(--line);
        }

        .details-title {
            margin: 0;
            font-size: 2rem;
            line-height: 1.05;
            letter-spacing: -0.02em;
        }

        .modal-label {
            display: inline-flex;
            gap: 8px;
            align-items: center;
            color: var(--muted);
            font-weight: 600;
            margin-top: 10px;
        }

        .badge {
            padding: 10px 16px;
            border-radius: 999px;
            background: #e0e7ff;
            color: #1d4ed8;
            font-weight: 700;
            white-space: nowrap;
        }

        .details-meta-grid {
            margin: 0 24px 20px;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
            background: #f4f6fc;
            border-radius: 14px;
            padding: 18px;
        }

        .meta-item {
            background: #fff;
            border-radius: 12px;
            padding: 16px;
            border: 1px solid rgba(226, 232, 240, 0.9);
        }

        .meta-item h4 {
            margin: 0 0 10px;
            font-size: 0.95rem;
            color: var(--muted);
        }

        .meta-item p {
            margin: 0;
            color: var(--text);
            font-weight: 700;
        }

        .details-section {
            padding: 0 24px 22px;
            border-bottom: 1px solid var(--line);
        }

        .details-section:last-child {
            border-bottom: none;
        }

        .details-section h4 {
            margin: 16px 0 10px;
            font-size: 1.05rem;
            color: var(--text);
        }

        .details-section p,
        .details-section a {
            margin: 0;
            color: #475569;
            line-height: 1.7;
            text-decoration: none;
        }

        .details-section a:hover {
            text-decoration: underline;
        }

        .details-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            padding: 18px 24px 24px;
        }

        .btn,
        .btn-light {
            border: 0;
            border-radius: 12px;
            padding: 12px 18px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.18s ease, filter 0.2s ease;
        }

        .btn {
            background: var(--primary);
            color: #fff;
        }

        .btn:hover {
            transform: translateY(-1px);
            filter: brightness(1.08);
        }

        .btn-light {
            background: #e2e8f0;
            color: var(--text);
        }

        @keyframes riseIn {
            from { opacity: 0; transform: translateY(14px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 760px) {
            .details-head {
                flex-direction: column;
                align-items: stretch;
            }

            .details-meta-grid {
                grid-template-columns: 1fr;
            }

            .details-actions {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="card">
        <div class="header">
            <div>
                <h1 class="header-title">Détails de la candidature</h1>
                <p class="label">Offre: <strong>{{ offreTitre }}</strong></p>
            </div>
            <span class="badge">{{ candidature.statut }}</span>
        </div>

        <div class="content">
            <div class="field">
                <h3>Date de candidature</h3>
                <p>{{ candidature.dateCandidature ? candidature.dateCandidature|date('d/m/Y') : 'Non renseignée' }}</p>
            </div>
            <div class="field">
                <h3>Niveau</h3>
                <p>{{ candidature.niveauExperience ?? 'N/A' }}</p>
            </div>
            <div class="field">
                <h3>Années d'expérience</h3>
                <p>{{ candidature.anneesExperience ?? 'N/A' }}</p>
            </div>
            <div class="field">
                <h3>Domaine</h3>
                <p>{{ candidature.domaineExperience ?? 'N/A' }}</p>
            </div>
        </div>

        <div class="section">
            <h3>Dernier poste</h3>
            <p>{{ candidature.dernierPoste ?: 'Non renseigné' }}</p>
        </div>

        <div class="section">
            <h3>Message du candidat</h3>
            <p>{{ candidature.messageCandidat ?: 'Aucun message.' }}</p>
        </div>

        <div class="section">
            <h3>Fichiers</h3>
            <p>
                CV:
                {% if candidature.cv %}
                    <a href="{{ asset(candidature.cv) }}" target="_blank">Voir le CV</a>
                {% else %}
                    Aucun CV
                {% endif %}
            </p>
            <p>
                Lettre de motivation:
                {% if candidature.lettreMotivation %}
                    <a href="{{ asset(candidature.lettreMotivation) }}" target="_blank">Voir la lettre</a>
                {% else %}
                    Aucune lettre
                {% endif %}
            </p>
        </div>
        <div class="card mt-4 text-center">
    <div class="card-body">
        <h6 class="card-title">
            <i class="fas fa-qrcode"></i> QR Code de la candidature
        </h6>
        <img src="data:image/png;base64,{{ qrCodeBase64 }}"
             alt="QR Code Candidature #{{ candidature.idCandidature }}"
             style="max-width: 200px;" />
        <p class="text-muted small mt-2">
            Scannez pour afficher le résumé de cette candidature
        </p>
    </div>
</div>

        <div class="actions">
            <a href="{{ path('app_client_candidature_detail_pdf', {id_candidature: candidature.idCandidature}) }}" class="btn" title="Télécharger en PDF">📄 Exporter en PDF</a>
            <a href="{{ path('app_client_candidature_edit', {id_candidature: candidature.idCandidature}) }}" class="btn">Modifier</a>
            <a href="{{ path('analyse_cv_afficher', {idCandidature: candidature.idCandidature}) }}" class="btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">🤖 Analyser Mon CV</a>
            <a href="{{ path('app_client_candidatures') }}" class="btn btn-light">Retour</a>
        </div>
    </div>
</div>
</body>
</html>
{% extends 'base.html.twig' %}

{% block title %}Mes contrats | VOS{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/client.css') }}">
    <style>
        .contracts-wrap {
            display: grid;
            gap: 18px;
        }

        .contracts-hero {
            position: relative;
            overflow: hidden;
            border-radius: 20px;
            border: 1px solid #d4def1;
            padding: 22px;
            background:
                radial-gradient(circle at 88% 20%, rgba(14, 77, 164, 0.2) 0%, rgba(14, 77, 164, 0) 42%),
                linear-gradient(135deg, #ffffff 0%, #f3f7ff 100%);
            box-shadow: 0 18px 40px rgba(9, 26, 61, 0.1);
        }

        .contracts-hero::after {
            content: "";
            position: absolute;
            right: -34px;
            top: -34px;
            width: 140px;
            height: 140px;
            border-radius: 50%;
            border: 16px solid rgba(14, 77, 164, 0.08);
        }

        .contracts-title {
            margin: 0;
            font-size: clamp(1.75rem, 3.8vw, 2.4rem);
            color: #102347;
            letter-spacing: -0.03em;
        }

        .contracts-subtitle {
            margin: 8px 0 0;
            color: #4d607f;
            font-size: 1rem;
            max-width: 62ch;
        }

        .contracts-kpis {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 16px;
        }

        .contracts-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border-radius: 999px;
            border: 1px solid #c9d8f3;
            background: #ffffff;
            color: #1e3768;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 6px 12px;
        }

        .contracts-pill strong {
            color: #0c4aa0;
            font-size: 0.95rem;
        }

        .contracts-grid {
            margin-top: 4px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
            gap: 16px;
        }

        .contract-card {
            position: relative;
            overflow: hidden;
            background: linear-gradient(160deg, #ffffff 0%, #f9fbff 100%);
            border: 1px solid #d8e2f3;
            border-radius: 18px;
            padding: 16px;
            box-shadow: 0 10px 24px rgba(5, 20, 45, 0.08);
            display: grid;
            gap: 12px;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .contract-card::before {
            content: "";
            position: absolute;
            inset: 0 auto 0 0;
            width: 5px;
            background: linear-gradient(180deg, #0e4da4, #5a9bff);
        }

        .contract-card:hover {
            transform: translateY(-3px);
            border-color: #bdd0f3;
            box-shadow: 0 16px 34px rgba(11, 35, 77, 0.15);
        }

        .contract-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .contract-id {
            font-weight: 700;
            color: #0a4b9f;
            font-size: 0.9rem;
        }

        .contract-type {
            margin: 0;
            font-size: 1.14rem;
            color: #101828;
        }

        .status-badge {
            border-radius: 999px;
            padding: 5px 10px;
            font-size: 0.74rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            white-space: nowrap;
        }

        .status-active,
        .status-actif {
            background: #dcfce7;
            color: #166534;
        }

        .status-terminated,
        .status-termine,
        .status-closed {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-default {
            background: #e2e8f0;
            color: #334155;
        }

        .status-accepted {
            background: #dcfce7;
            color: #166534;
        }

        .status-refused {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-pending {
            background: #e2e8f0;
            color: #334155;
        }

        .contract-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 9px 12px;
            color: #475467;
            font-size: 0.92rem;
            background: #f4f8ff;
            border: 1px solid #d9e5f8;
            border-radius: 12px;
            padding: 10px;
        }

        .contract-meta strong {
            color: #1f2937;
            font-weight: 600;
        }

        .contract-note {
            margin: 0;
            padding: 10px 12px;
            border-radius: 10px;
            background: #f8fafc;
            border: 1px dashed #d3dcec;
            color: #4b5563;
            font-size: 0.9rem;
            line-height: 1.4;
        }

        .empty-state {
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, #ffffff, #f8fbff);
            border: 1px dashed #bfcfeb;
            border-radius: 18px;
            padding: 28px 20px;
            color: #465a78;
            text-align: center;
            box-shadow: 0 10px 24px rgba(5, 20, 45, 0.07);
        }

        .empty-state::before {
            content: "";
            position: absolute;
            left: -30px;
            bottom: -34px;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: rgba(14, 77, 164, 0.08);
        }

        .empty-state h3 {
            margin: 0;
            color: #16335f;
            font-size: 1.2rem;
        }

        .empty-state p {
            margin: 8px 0 0;
            font-size: 0.95rem;
        }

        .btn-pdf {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: 0;
            border-radius: 10px;
            padding: 9px 14px;
            background: #0e4da4;
            color: #fff;
            font-family: 'Poppins', sans-serif;
            font-size: 0.84rem;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: transform 0.18s ease, filter 0.2s ease, box-shadow 0.2s ease;
            box-shadow: 0 4px 14px rgba(14,77,164,0.22);
            margin-top: 6px;
        }

        .btn-pdf:hover {
            transform: translateY(-2px);
            filter: brightness(1.08);
            box-shadow: 0 8px 20px rgba(14,77,164,0.32);
        }

        /* ── Filters ── */
        .filters-panel {
            background: #fff;
            border: 1px solid #d4def1;
            border-radius: 16px;
            padding: 16px 18px;
            box-shadow: 0 2px 10px rgba(9,26,61,0.06);
            display: grid;
            gap: 12px;
        }
        .filters-row {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 10px;
            align-items: center;
        }
        .filters-row-2 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr auto;
            gap: 10px;
            align-items: center;
        }
        .filter-input-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #f7f9ff;
            border: 1px solid #d4def1;
            border-radius: 10px;
            padding: 9px 12px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .filter-input-wrap:focus-within {
            border-color: #7baaf7;
            box-shadow: 0 0 0 3px rgba(14,77,164,0.09);
        }
        .filter-input-wrap svg { flex-shrink: 0; color: #7a93bb; }
        .filter-input-wrap input {
            flex: 1; border: none; outline: none; background: transparent;
            font-family: 'Poppins', sans-serif; font-size: 0.93rem; color: #101828;
        }
        .filter-input-wrap input::placeholder { color: #9aaac0; }
        .filter-select {
            width: 100%;
            border: 1px solid #d4def1;
            border-radius: 10px;
            padding: 10px 12px;
            font-family: 'Poppins', sans-serif;
            font-size: 0.93rem;
            color: #101828;
            background: #f7f9ff;
            outline: none;
            cursor: pointer;
            transition: border-color 0.2s;
        }
        .filter-select:focus { border-color: #7baaf7; box-shadow: 0 0 0 3px rgba(14,77,164,0.09); }
        .filter-date {
            width: 100%;
            border: 1px solid #d4def1;
            border-radius: 10px;
            padding: 10px 12px;
            font-family: 'Poppins', sans-serif;
            font-size: 0.93rem;
            color: #101828;
            background: #f7f9ff;
            outline: none;
            transition: border-color 0.2s;
        }
        .filter-date:focus { border-color: #7baaf7; box-shadow: 0 0 0 3px rgba(14,77,164,0.09); }
        .btn-reset {
            display: inline-flex; align-items: center; gap: 6px;
            border: 1px solid #d4def1; border-radius: 10px;
            padding: 10px 14px; background: #fff; color: #64748b;
            font-family: 'Poppins', sans-serif; font-size: 0.88rem; font-weight: 600;
            cursor: pointer; white-space: nowrap;
            transition: border-color 0.2s, color 0.2s;
        }
        .btn-reset:hover { border-color: #0e4da4; color: #0e4da4; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .spinner {
            width: 16px; height: 16px; border-radius: 50%;
            border: 2px solid #dde8f8; border-top-color: #0e4da4;
            animation: spin 0.7s linear infinite;
            flex-shrink: 0; display: none;
        }
        .spinner.active { display: inline-block; }
        .filters-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }
        .results-counter {
            font-size: 0.87rem; color: #6b7f9e; font-weight: 500;
            transition: opacity 0.2s;
        }
        .results-counter strong { color: #0e4da4; }
        .active-filters {
            display: flex; flex-wrap: wrap; gap: 6px;
        }
        .filter-tag {
            display: inline-flex; align-items: center; gap: 5px;
            background: #e8f0ff; color: #0e4da4; border-radius: 999px;
            font-size: 0.78rem; font-weight: 600; padding: 3px 10px;
        }
        mark {
            background: rgba(14,77,164,0.14); color: #0a3a82;
            border-radius: 3px; padding: 0 2px; font-weight: 700;
        }

        @media (max-width: 900px) {
            .contracts-grid {
                grid-template-columns: 1fr;
            }

            .contracts-hero {
                padding: 18px;
            }

            .contract-meta {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="client-shell">
    {{ include('client/_client_header.html.twig', { userName: userName|default('Utilisateur'), activePage: 'mes-contrats' }) }}

    <main class="client-content">
        <section class="contracts-wrap">
            <div class="contracts-hero">
                <h1 class="contracts-title">Mes contrats</h1>
                <p class="contracts-subtitle">Retrouvez ici l'ensemble de vos contrats, leurs dates importantes et les conditions associées.</p>
                <div class="contracts-kpis">
                    <span class="contracts-pill">Total contrats <strong>{{ contracts|length }}</strong></span>
                    <span class="contracts-pill">Compte <strong>{{ userName|default('Utilisateur') }}</strong></span>
                </div>
            </div>

            <div class="filters-panel">
                {# Row 1: text search + type + statut #}
                <div class="filters-row">
                    <div class="filter-input-wrap">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                        </svg>
                        <input id="f-search" type="text" placeholder="Mots clés (type, avantages, période...)" autocomplete="off">
                        <div class="spinner" id="spinner"></div>
                    </div>
                    <select id="f-type" class="filter-select">
                        <option value="">Tous les types</option>
                        <option value="CDI">CDI</option>
                        <option value="CDD">CDD</option>
                        <option value="Stage">Stage</option>
                        <option value="Alternance">Alternance</option>
                        <option value="Freelance">Freelance</option>
                    </select>
                    <select id="f-decision" class="filter-select">
                        <option value="">Toutes les décisions</option>
                        <option value="accepte">Accepté</option>
                        <option value="refuse">Refusé</option>
                        <option value="attente">En attente</option>
                    </select>
                </div>

                {# Row 2: date range + reset #}
                <div class="filters-row-2">
                    <input id="f-date-from" type="date" class="filter-date" title="Date début à partir de">
                    <input id="f-date-to"   type="date" class="filter-date" title="Date début jusqu'au">
                    <div></div>
                    <button id="btn-reset" class="btn-reset" type="button">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                            <path d="M3 3v5h5"/>
                        </svg>
                        Réinitialiser
                    </button>
                </div>

                {# Footer: counter + active filter tags #}
                <div class="filters-footer">
                    <p class="results-counter" id="results-counter">
                        <strong>{{ contracts|length }}</strong> contrat(s) trouvé(s)
                    </p>
                    <div class="active-filters" id="active-filters"></div>
                </div>
            </div>

            {% if contracts is empty %}
                <div class="empty-state" id="empty-initial">
                    <h3>Aucun contrat pour le moment</h3>
                    <p>Vos contrats apparaîtront ici dès qu'un recrutement est finalisé et qu'un contrat est créé.</p>
                </div>
            {% else %}
                <div class="contracts-grid" id="contracts-grid">
                    {% for contract in contracts %}
                        {% set decisionRaw = (contract.decision_finale ?? '')|lower %}
                        {% set statusLabel = contract.status ?? 'N/A' %}
                        {% if decisionRaw is not empty %}
                            {% if 'accept' in decisionRaw %}
                                {% set statusLabel = 'Accepté' %}
                            {% elseif 'refus' in decisionRaw %}
                                {% set statusLabel = 'Refusé' %}
                            {% elseif 'attente' in decisionRaw %}
                                {% set statusLabel = 'En attente' %}
                            {% else %}
                                {% set statusLabel = contract.decision_finale %}
                            {% endif %}
                        {% endif %}

                        {% set statusRaw = statusLabel|lower %}
                        {% set statusClass = 'status-default' %}
                        {% if 'accept' in statusRaw %}
                            {% set statusClass = 'status-accepted' %}
                        {% elseif 'refus' in statusRaw %}
                            {% set statusClass = 'status-refused' %}
                        {% elseif 'attente' in statusRaw %}
                            {% set statusClass = 'status-pending' %}
                        {% elseif 'active' in statusRaw or 'actif' in statusRaw %}
                            {% set statusClass = 'status-active' %}
                        {% elseif 'termine' in statusRaw or 'closed' in statusRaw %}
                            {% set statusClass = 'status-terminated' %}
                        {% endif %}

                        <article class="contract-card">
                            <div class="contract-head">
                                <span class="contract-id">Contrat #{{ contract.id_contrat }}</span>
                                <span class="status-badge {{ statusClass }}">{{ statusLabel }}</span>
                            </div>

                            <h3 class="contract-type">{{ contract.type_contrat ?? 'Type non défini' }}</h3>

                            <div class="contract-meta">
                                <span><strong>Date début:</strong> {{ contract.date_debut ? contract.date_debut|date('d/m/Y') : '-' }}</span>
                                <span><strong>Date fin:</strong> {{ contract.date_fin ? contract.date_fin|date('d/m/Y') : '-' }}</span>
                                <span><strong>Salaire:</strong> {{ contract.salaire is not null ? contract.salaire ~ ' TND' : '-' }}</span>
                                <span><strong>Volume:</strong> {{ contract.volume_horaire ?? '-' }}</span>
                                <span><strong>Période:</strong> {{ contract.periode ?? '-' }}</span>
                                <span><strong>Décision:</strong> {{ contract.decision_finale ?? '-' }}</span>
                            </div>

                            {% if contract.avantages %}
                                <p class="contract-note">
                                    <strong>Avantages:</strong> {{ contract.avantages }}
                                </p>
                            {% endif %}

                            <a href="{{ path('app_front_contrat_pdf', {id: contract.id_contrat}) }}"
                               class="btn-pdf" target="_blank">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                    <polyline points="7 10 12 15 17 10"/>
                                    <line x1="12" y1="15" x2="12" y2="3"/>
                                </svg>
                                Télécharger mon contrat
                            </a>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </main>
</div>

{% block javascripts %}
<script>
(function () {
    const fSearch   = document.getElementById('f-search');
    const fType     = document.getElementById('f-type');
    const fDecision = document.getElementById('f-decision');
    const fDateFrom = document.getElementById('f-date-from');
    const fDateTo   = document.getElementById('f-date-to');
    const btnReset  = document.getElementById('btn-reset');
    const grid      = document.getElementById('contracts-grid');
    const counter   = document.getElementById('results-counter');
    const spinner   = document.getElementById('spinner');
    const emptyInit = document.getElementById('empty-initial');
    const activeTags = document.getElementById('active-filters');
    const searchUrl  = {{ path('client_mes_contrats_search')|json_encode|raw }};
    const pdfBase    = {{ path('app_front_contrat_pdf', {id: 0})|json_encode|raw }};

    let debounce = null;

    /* ── helpers ── */
    function esc(s) {
        return (s ?? '').toString()
            .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    function highlight(text, term) {
        if (!term) return esc(text);
        const re = new RegExp('(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        return esc(text).replace(re, '<mark>$1</mark>');
    }
    function statusClass(d, s) {
        d = (d ?? '').toLowerCase(); s = (s ?? '').toLowerCase();
        if (d.includes('accept') || s === 'actif' || s === 'active') return 'status-accepted';
        if (d.includes('refus')  || s.includes('termin') || s === 'closed') return 'status-refused';
        if (d.includes('attente') || s.includes('attente')) return 'status-pending';
        return 'status-default';
    }
    function statusLabel(d, s) {
        d = (d ?? '').toLowerCase();
        if (d.includes('accept')) return 'Accepté';
        if (d.includes('refus'))  return 'Refusé';
        if (d.includes('attente')) return 'En attente';
        return s || 'N/A';
    }
    function pdfUrl(id) { return pdfBase.replace('/0/', '/' + id + '/'); }
    function fmtDate(raw) {
        if (!raw) return '-';
        const d = new Date(raw);
        return isNaN(d) ? raw : d.toLocaleDateString('fr-FR');
    }

    /* ── render ── */
    function renderCards(contracts, term) {
        if (!grid) return;
        if (contracts.length === 0) {
            grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
                <h3>Aucun contrat trouvé</h3>
                <p>Aucun contrat ne correspond à vos critères de recherche.</p></div>`;
            return;
        }
        grid.innerHTML = contracts.map(c => {
            const sc = statusClass(c.decision_finale, c.status);
            const sl = statusLabel(c.decision_finale, c.status);
            const avantages = c.avantages
                ? `<p class="contract-note"><strong>Avantages:</strong> ${highlight(c.avantages, term)}</p>` : '';
            return `
            <article class="contract-card">
                <div class="contract-head">
                    <span class="contract-id">Contrat #${esc(c.id_contrat)}</span>
                    <span class="status-badge ${sc}">${highlight(sl, term)}</span>
                </div>
                <h3 class="contract-type">${highlight(c.type_contrat || 'Type non défini', term)}</h3>
                <div class="contract-meta">
                    <span><strong>Date début:</strong> ${fmtDate(c.date_debut)}</span>
                    <span><strong>Date fin:</strong> ${fmtDate(c.date_fin)}</span>
                    <span><strong>Salaire:</strong> ${c.salaire != null ? esc(c.salaire) + ' TND' : '-'}</span>
                    <span><strong>Volume:</strong> ${esc(c.volume_horaire ?? '-')}</span>
                    <span><strong>Période:</strong> ${highlight(c.periode ?? '-', term)}</span>
                    <span><strong>Décision:</strong> ${highlight(c.decision_finale ?? '-', term)}</span>
                </div>
                ${avantages}
                <a href="${pdfUrl(c.id_contrat)}" class="btn-pdf" target="_blank">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    Télécharger mon contrat
                </a>
            </article>`;
        }).join('');
    }

    /* ── active tags ── */
    const LABELS = { type: 'Type', decision: 'Décision', date_from: 'Depuis', date_to: 'Jusqu\'au' };
    const DECISION_LABELS = { accepte: 'Accepté', refuse: 'Refusé', attente: 'En attente' };
    function renderTags(params) {
        if (!activeTags) return;
        const tags = [];
        if (params.type)      tags.push(`Type: ${esc(params.type)}`);
        if (params.decision)  tags.push(`Décision: ${DECISION_LABELS[params.decision] ?? esc(params.decision)}`);
        if (params.date_from) tags.push(`Depuis: ${esc(params.date_from)}`);
        if (params.date_to)   tags.push(`Jusqu'au: ${esc(params.date_to)}`);
        activeTags.innerHTML = tags.map(t => `<span class="filter-tag">${t}</span>`).join('');
    }

    /* ── fetch ── */
    async function fetchResults() {
        const params = {
            search:    fSearch.value.trim(),
            type:      fType.value,
            decision:  fDecision.value,
            date_from: fDateFrom.value,
            date_to:   fDateTo.value,
        };

        const qs = Object.entries(params)
            .filter(([, v]) => v !== '')
            .map(([k, v]) => k + '=' + encodeURIComponent(v))
            .join('&');

        spinner.classList.add('active');
        if (counter) counter.style.opacity = '0.4';

        try {
            const res = await fetch(searchUrl + (qs ? '?' + qs : ''), {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            if (!res.ok) throw new Error('Erreur réseau');
            const json = await res.json();

            if (emptyInit) emptyInit.style.display = 'none';
            renderCards(json.contracts, params.search);
            renderTags(params);

            if (counter) {
                counter.innerHTML = `<strong>${json.total}</strong> contrat(s) trouvé(s)`;
                counter.style.opacity = '1';
            }
        } catch (e) {
            console.error(e);
        } finally {
            spinner.classList.remove('active');
            if (counter) counter.style.opacity = '1';
        }
    }

    /* ── debounced text, immediate for selects & dates ── */
    fSearch.addEventListener('input', () => {
        clearTimeout(debounce);
        debounce = setTimeout(fetchResults, 300);
    });
    [fType, fDecision, fDateFrom, fDateTo].forEach(el => el.addEventListener('change', fetchResults));

    /* ── reset ── */
    btnReset.addEventListener('click', () => {
        fSearch.value = fType.value = fDecision.value = fDateFrom.value = fDateTo.value = '';
        if (activeTags) activeTags.innerHTML = '';
        fetchResults();
    });
})();
</script>
{% endblock %}
{% endblock %}

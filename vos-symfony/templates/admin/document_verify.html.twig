<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verification Document | VOS</title>
    <style>
        :root {
            --ok: #15803d;
            --ok-bg: #ecfdf3;
            --bad: #b91c1c;
            --bad-bg: #fef2f2;
            --line: #dbe2ef;
            --ink: #0f172a;
            --muted: #475569;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Segoe UI", Arial, sans-serif;
            color: var(--ink);
            background: radial-gradient(circle at 15% 12%, #e9f1ff 0%, transparent 40%),
                        linear-gradient(140deg, #eef3fb, #f8fbff);
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
        }

        .card {
            width: min(760px, 100%);
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 16px;
            box-shadow: 0 14px 50px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .head {
            padding: 22px 24px;
            background: linear-gradient(120deg, #0a2f72, #1f5db7);
            color: #fff;
        }

        .head h1 {
            margin: 0;
            font-size: 1.45rem;
        }

        .head p {
            margin: 6px 0 0;
            opacity: 0.92;
            font-size: 0.95rem;
        }

        .body {
            padding: 22px 24px 24px;
        }

        .status {
            border-radius: 12px;
            padding: 14px 16px;
            font-weight: 700;
            margin-bottom: 18px;
            border: 1px solid transparent;
        }

        .status.ok {
            color: var(--ok);
            background: var(--ok-bg);
            border-color: #bbf7d0;
        }

        .status.bad {
            color: var(--bad);
            background: var(--bad-bg);
            border-color: #fecaca;
        }

        .grid {
            display: grid;
            grid-template-columns: 200px 1fr;
            border: 1px solid var(--line);
            border-radius: 12px;
            overflow: hidden;
        }

        .label,
        .value {
            padding: 11px 12px;
            border-bottom: 1px solid var(--line);
        }

        .label {
            background: #f6f9ff;
            font-weight: 700;
            color: #1e3a8a;
        }

        .grid div:nth-last-child(-n+2) {
            border-bottom: none;
        }

        .value {
            color: var(--ink);
        }

        .muted {
            margin-top: 14px;
            color: var(--muted);
            font-size: 0.92rem;
        }

        .actions {
            margin-top: 16px;
        }

        .btn-download {
            display: inline-block;
            text-decoration: none;
            padding: 10px 14px;
            border-radius: 10px;
            background: linear-gradient(135deg, #1d4ed8, #0b3a9d);
            color: #fff;
            font-weight: 700;
        }

        @media (max-width: 640px) {
            .grid {
                grid-template-columns: 1fr;
            }

            .label {
                border-bottom: none;
                border-top: 1px solid var(--line);
            }

            .grid div:first-child {
                border-top: none;
            }
        }
    </style>
</head>
<body>
<div class="card">
    <div class="head">
        <h1>Verification de document</h1>
        <p>Service administratif VOS</p>
    </div>

    <div class="body">
        <div class="status {{ isValid ? 'ok' : 'bad' }}">{{ message }}</div>

        <div class="grid">
            <div class="label">Reference</div>
            <div class="value">{{ reference ?: '-' }}</div>

            <div class="label">Type</div>
            <div class="value">{{ type ?: '-' }}</div>

            <div class="label">Nom</div>
            <div class="value">{{ name ?: '-' }}</div>

            <div class="label">Date de generation</div>
            <div class="value">{{ issuedAt ? issuedAt|date('d/m/Y H:i') : '-' }}</div>
        </div>

        <p class="muted">Cette page valide la signature numerique incluse dans le QR code du document PDF.</p>

        {% if isValid and downloadUrl %}
            <div class="actions">
                <a class="btn-download" href="{{ downloadUrl }}">Telecharger le PDF</a>
            </div>
        {% endif %}
    </div>
</div>
{% if isValid and downloadUrl %}
    <script>
        (function () {
            // Ouvre le telechargement apres affichage de la page de verification.
            setTimeout(function () {
                window.location.href = '{{ downloadUrl }}';
            }, 600);
        })();
    </script>
{% endif %}
</body>
</html>

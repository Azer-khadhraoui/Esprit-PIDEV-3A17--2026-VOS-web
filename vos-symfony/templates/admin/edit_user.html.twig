{% extends 'gestion_offre_base.html.twig' %}

{% block title %}Modifier un utilisateur | VOS{% endblock %}

{% block styles %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const input = document.querySelector('[data-profile-input="1"]');
            const previewImage = document.querySelector('[data-profile-preview]');
            const previewPlaceholder = document.querySelector('[data-profile-placeholder]');
            const previewFilename = document.querySelector('[data-profile-filename]');

            if (!input || !previewImage || !previewPlaceholder || !previewFilename) {
                return;
            }

            input.addEventListener('change', () => {
                const file = input.files && input.files[0];

                if (!file) {
                    previewFilename.textContent = 'Aucun fichier sélectionné';
                    return;
                }

                previewFilename.textContent = file.name;

                const reader = new FileReader();
                reader.onload = event => {
                    previewImage.src = event.target.result;
                    previewImage.hidden = false;
                    previewPlaceholder.hidden = true;
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
{% endblock %}

{% block body %}
<div class="admin-shell">
    <aside class="sidebar" aria-label="Navigation principale de l'administration">
        <div class="brand">
            <span class="brand-dot"></span>
            <span>VOS Admin</span>
        </div>
        <nav class="nav-list" aria-label="Sections de l'administration">
            <a class="nav-item is-active" href="{{ path('app_admin_dashboard') }}">Gestion des utilisateurs</a>
            <a class="nav-item" href="{{ path('gestion_offre_dashboard') }}">Gestion Offres</a>
            <a class="nav-item" href="{{ path('app_admin_candidatures') }}">Gestion Candidatures</a>
            <a class="nav-item" href="{{ path('gestion_entretien_dashboard') }}">Gestion Entretiens</a>
            <a class="nav-item" href="{{ path('recrutement_index') }}">Gestion Recrutements</a>
            <a class="nav-item" href="#">Forum</a>
            <a class="nav-item" href="#">Rapports</a>
        </nav>
        <div class="sidebar-footer">Panel Administration</div>
    </aside>

    <main class="content">
        <header class="topbar">
            <div>
                <h1>Modifier un utilisateur</h1>
                <p>{{ adminName }}</p>
            </div>
            <a class="btn-edit" href="{{ path('app_admin_dashboard') }}">Retour au tableau de bord</a>
        </header>

        <nav class="module-nav" aria-label="Navigation users">
            <a class="module-link" href="{{ path('app_admin_dashboard') }}">Utilisateurs</a>
            <a class="module-link" href="{{ path('app_admin_users_statistique') }}">Statistiques</a>
            <a class="module-link" href="{{ path('app_admin_users_administrative_service') }}">Service administrative</a>
        </nav>

        <section class="table-card edit-page-card">
            <h2>{{ user.prenom }} {{ user.nom }}</h2>
            {{ form_start(editForm, {'attr': {'class': 'admin-edit-form', 'novalidate': 'novalidate'}}) }}
                <div class="edit-layout">
                    <aside class="edit-profile-panel" aria-label="Photo de profil">
                        <h3>Photo de profil</h3>
                        <div class="profile-upload">
                            <div class="profile-preview profile-preview-large">
                                <img
                                    data-profile-preview
                                    class="profile-preview-image"
                                    src="{% if user.imageProfil %}{{ asset(user.imageProfil) }}{% endif %}"
                                    alt="Aperçu de profil"
                                    {% if not user.imageProfil %}hidden{% endif %}
                                >
                                <div class="profile-placeholder profile-placeholder-large" data-profile-placeholder {% if user.imageProfil %}hidden{% endif %}>
                                    <span>Choisir une photo</span>
                                </div>
                            </div>
                            <div class="profile-filename" data-profile-filename>Aucun fichier sélectionné</div>
                            {{ form_label(editForm.imageFile) }}
                            {{ form_widget(editForm.imageFile, {'attr': {'data-profile-input': '1', 'accept': 'image/*'}}) }}
                            {{ form_errors(editForm.imageFile) }}
                        </div>
                    </aside>

                    <div class="edit-form-panel">
                        {{ form_row(editForm.nom) }}
                        {{ form_row(editForm.prenom) }}
                        {{ form_row(editForm.email) }}
                        {{ form_row(editForm.role) }}
                        <button class="btn-edit" type="submit">Enregistrer</button>
                    </div>
                </div>
            {{ form_end(editForm) }}
        </section>
    </main>
</div>
{% endblock %}


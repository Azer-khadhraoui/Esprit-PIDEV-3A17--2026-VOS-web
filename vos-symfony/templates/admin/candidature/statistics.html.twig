{# templates/admin/candidature/statistics.html.twig #}
{% extends 'gestion_offre_base.html.twig' %}

{% block title %}Statistiques Avancées | VOS Admin{% endblock %}

{% block styles %}
<link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
<style>
/* ═══════════════════════════════════════════════
   VARIABLES & RESET
═══════════════════════════════════════════════ */
:root {
    --blue:    #4361ee;
    --green:   #06d6a0;
    --orange:  #ff9500;
    --red:     #ef476f;
    --purple:  #7209b7;
    --cyan:    #00b4d8;
    --yellow:  #ffd60a;
    --bg:      #f4f6fb;
    --card:    #ffffff;
    --border:  #e8ebf3;
    --text:    #2c3e50;
    --muted:   #6c757d;
    --radius:  12px;
    --shadow:  0 2px 12px rgba(0,0,0,0.07);
}

/* ═══════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════ */
.stats-page { padding: 0; }

/* ═══════════════════════════════════════════════
   FILTER BAR
═══════════════════════════════════════════════ */
.filter-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    margin-bottom: 28px;
    box-shadow: var(--shadow);
    flex-wrap: wrap;
}
.filter-bar label {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .5px;
    margin-right: 4px;
}
.filter-btn {
    padding: 8px 18px;
    border-radius: 20px;
    border: 2px solid var(--border);
    background: transparent;
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    cursor: pointer;
    transition: all .2s;
    text-decoration: none;
}
.filter-btn:hover, .filter-btn.active {
    background: var(--blue);
    border-color: var(--blue);
    color: #fff;
}
.filter-info {
    margin-left: auto;
    font-size: 12px;
    color: var(--muted);
    background: var(--bg);
    padding: 6px 12px;
    border-radius: 20px;
}

/* ═══════════════════════════════════════════════
   SECTION TITLE
═══════════════════════════════════════════════ */
.section-heading {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 36px 0 20px;
}
.section-heading .sh-icon {
    width: 38px; height: 38px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
}
.section-heading h2 {
    font-size: 20px;
    font-weight: 700;
    color: #ffffff;        /* blanc pur sur fond sombre */
    margin: 0;
}
.section-heading p {
    margin: 2px 0 0;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.65);   /* sous-titre légèrement transparent */
}
/* ═══════════════════════════════════════════════
   KPI CARDS
═══════════════════════════════════════════════ */
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
}
.kpi-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
    transition: transform .2s, box-shadow .2s;
}
.kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
.kpi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent, var(--blue));
}
.kpi-card .kpi-icon {
    width: 44px; height: 44px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    background: color-mix(in srgb, var(--accent, var(--blue)) 12%, transparent);
    margin-bottom: 14px;
}
.kpi-value { font-size: 34px; font-weight: 800; color: var(--text); line-height: 1; }
.kpi-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: .6px; margin-top: 6px; }
.kpi-sub { font-size: 13px; color: var(--accent, var(--blue)); margin-top: 8px; font-weight: 500; }

/* ═══════════════════════════════════════════════
   CHART CARDS
═══════════════════════════════════════════════ */
.chart-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}
@media (max-width: 900px) { .chart-grid-2 { grid-template-columns: 1fr; } }

.chart-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
}
.chart-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
}
.chart-card-header h3 {
    font-size: 15px; font-weight: 700; color: var(--text); margin: 0;
    display: flex; align-items: center; gap: 8px;
}
.chart-badge {
    font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 20px;
    background: color-mix(in srgb, var(--blue) 10%, transparent);
    color: var(--blue);
}

/* Bar rows */
.bar-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid #f5f7fa;
}
.bar-row:last-child { border-bottom: none; }
.bar-label {
    width: 140px; flex-shrink: 0;
    font-size: 13px; color: var(--text); font-weight: 500;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.bar-track {
    flex: 1;
    height: 28px;
    background: #f0f3fa;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
}
.bar-fill {
    height: 100%;
    border-radius: 6px;
    background: linear-gradient(90deg, var(--bar-color, var(--blue)), color-mix(in srgb, var(--bar-color, var(--blue)) 70%, white));
    display: flex; align-items: center; padding-left: 10px;
    font-size: 11px; color: white; font-weight: 700;
    transition: width 0.8s cubic-bezier(.4,0,.2,1);
    min-width: 0;
}
.bar-count {
    width: 36px; flex-shrink: 0;
    text-align: right;
    font-size: 13px; font-weight: 700; color: var(--text);
}

/* Status colors */
.status-En-attente  { --bar-color: var(--yellow); color: #333 !important; }
.status-Accepté     { --bar-color: var(--green); }
.status-Refusé      { --bar-color: var(--red); }
.status-En-examens  { --bar-color: var(--cyan); }
.mode-hybride       { --bar-color: var(--purple); }
.mode-tele          { --bar-color: var(--cyan); }
.mode-presentiel    { --bar-color: var(--orange); }

/* ═══════════════════════════════════════════════
   TIMELINE
═══════════════════════════════════════════════ */
.timeline-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
    margin-bottom: 20px;
}
.timeline-chart {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    height: 100px;
    margin-top: 16px;
    padding: 0 4px;
}
.tl-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
}
.tl-bar-wrap { flex: 1; width: 100%; display: flex; align-items: flex-end; }
.tl-bar {
    width: 100%;
    border-radius: 4px 4px 0 0;
    background: linear-gradient(180deg, var(--blue), #3a52d0);
    transition: all .2s;
    min-height: 3px;
    position: relative;
}
.tl-col:hover .tl-bar { background: linear-gradient(180deg, var(--green), #04b486); }
.tl-bar[data-val="0"] { background: #e8ebf3 !important; }
.tl-label { font-size: 9px; color: var(--muted); white-space: nowrap; }
.tl-tooltip {
    display: none;
    position: absolute;
    top: -28px; left: 50%;
    transform: translateX(-50%);
    background: var(--text);
    color: white;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 6px;
    white-space: nowrap;
}
.tl-col:hover .tl-tooltip { display: block; }

/* ═══════════════════════════════════════════════
   MATCHING TABLE
═══════════════════════════════════════════════ */
.match-table-wrap {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
    margin-bottom: 20px;
}
.match-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 16px;
}
.match-table th {
    font-size: 11px; text-transform: uppercase; letter-spacing: .5px;
    color: var(--muted); font-weight: 700;
    padding: 10px 14px; border-bottom: 2px solid var(--border);
    background: #f8f9fb; text-align: left;
}
.match-table td {
    padding: 12px 14px;
    border-bottom: 1px solid #f0f3fa;
    font-size: 13px; color: var(--text);
    vertical-align: middle;
}
.match-table tr:last-child td { border-bottom: none; }
.match-table tr:hover td { background: #f8f9fb; }
.score-pill {
    display: inline-flex; align-items: center; justify-content: center;
    width: 52px; height: 28px;
    border-radius: 20px;
    font-size: 12px; font-weight: 800;
    color: white;
}
.match-mini-bar {
    width: 100%; height: 6px; background: #eee; border-radius: 3px; overflow: hidden; margin-top: 4px;
}
.match-mini-fill {
    height: 100%; border-radius: 3px;
    transition: width 0.8s ease;
}
.candidates-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: #f0f3fa; border-radius: 20px;
    padding: 3px 10px; font-size: 12px; font-weight: 600; color: var(--blue);
}

/* ═══════════════════════════════════════════════
   SALARY TABLE
═══════════════════════════════════════════════ */
.salary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 14px;
    margin-top: 16px;
}
.salary-card {
    background: linear-gradient(135deg, var(--blue), var(--cyan));
    border-radius: 10px;
    padding: 16px;
    color: white;
    text-align: center;
}
.salary-card.cdd  { background: linear-gradient(135deg, var(--purple), #a855f7); }
.salary-card.stage { background: linear-gradient(135deg, var(--orange), #f59e0b); }
.salary-card.alternance { background: linear-gradient(135deg, var(--green), #059669); }
.salary-card.freelance  { background: linear-gradient(135deg, var(--red), #dc2626); }
.salary-contrat { font-size: 11px; font-weight: 700; opacity: .85; text-transform: uppercase; letter-spacing: .5px; }
.salary-amount { font-size: 26px; font-weight: 800; margin: 8px 0 2px; }
.salary-unit { font-size: 11px; opacity: .75; }

/* ═══════════════════════════════════════════════
   DONUT CHARTS (CSS only)
═══════════════════════════════════════════════ */
.donut-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 12px;
}
.donut-item {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    min-width: 120px;
}
.donut-dot {
    width: 12px; height: 12px; border-radius: 50%;
    flex-shrink: 0;
}
.donut-text { font-size: 13px; color: var(--text); }
.donut-pct { font-size: 12px; color: var(--muted); }

/* Donut SVG */
.donut-svg-wrap {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 12px;
    flex-wrap: wrap;
}
.donut-svg { flex-shrink: 0; }
.donut-legend { flex: 1; min-width: 120px; }
.donut-legend-item {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 8px;
}
.donut-legend-color { width: 10px; height: 10px; border-radius: 50%; }
.donut-legend-label { font-size: 12px; color: var(--text); }
.donut-legend-val { font-size: 12px; font-weight: 700; color: var(--muted); margin-left: auto; }

/* ═══════════════════════════════════════════════
   SEARCH FILTER on table
═══════════════════════════════════════════════ */
.table-search {
    padding: 8px 12px; border: 1px solid var(--border);
    border-radius: 8px; font-size: 13px; width: 220px;
    outline: none; transition: border-color .2s;
}
.table-search:focus { border-color: var(--blue); }

/* ═══════════════════════════════════════════════
   EMPTY STATE
═══════════════════════════════════════════════ */
.empty-state {
    text-align: center; padding: 32px;
    color: var(--muted); font-size: 14px;
}
</style>
{% endblock %}

{% block body %}
<div class="admin-shell">
    <aside class="sidebar">
        <div class="brand"><span class="brand-dot"></span><span>VOS Admin</span></div>
        <nav class="nav-list">
            <a class="nav-item" href="{{ path('app_admin_dashboard') }}">Gestion Users</a>
            <a class="nav-item" href="{{ path('gestion_offre_dashboard') }}">Gestion Offres</a>
            <a class="nav-item is-active" href="{{ path('app_admin_candidatures') }}">Gestion Candidatures</a>
            <a class="nav-item" href="{{ path('gestion_entretien_dashboard') }}">Gestion Entretiens</a>
            <a class="nav-item" href="{{ path('recrutement_index') }}">Gestion Recrutements</a>
            <a class="nav-item" href="#">Forum</a>
        </nav>
        <div class="sidebar-footer">Panel Administration</div>
    </aside>

    <main class="content stats-page">
        <header class="topbar">
            <div>
                <h1>📊 Statistiques Avancées</h1>
                <p style="color:#6c757d;font-size:13px;margin:4px 0 0">Bienvenue {{ adminName }}</p>
            </div>
            <form method="post" action="{{ path('app_logout') }}" novalidate>
                <button class="btn-logout" type="submit">Déconnexion</button>
            </form>
        </header>

        {# ── Nav ── #}
        <nav class="module-nav" aria-label="Navigation candidatures">
            <a class="module-link" href="{{ path('app_admin_candidatures') }}">Candidatures</a>
            <a class="module-link" href="{{ path('app_admin_preferences') }}">Préférences</a>
            <a class="module-link is-active" href="{{ path('app_admin_statistics') }}">Statistiques</a>
        </nav>

        {# ══════════════════════════════════════
           FILTRE PÉRIODE
        ══════════════════════════════════════ #}
        <div class="filter-bar">
            <label>Période :</label>
            <a href="{{ path('app_admin_statistics', {periode: 'all'}) }}"
               class="filter-btn {{ periode == 'all' ? 'active' : '' }}">Tout</a>
            <a href="{{ path('app_admin_statistics', {periode: 'month'}) }}"
               class="filter-btn {{ periode == 'month' ? 'active' : '' }}">30 derniers jours</a>
            <a href="{{ path('app_admin_statistics', {periode: 'week'}) }}"
               class="filter-btn {{ periode == 'week' ? 'active' : '' }}">7 derniers jours</a>
            <span class="filter-info">
                {{ totalCandidatures }} candidature{{ totalCandidatures > 1 ? 's' : '' }} affichée{{ totalCandidatures > 1 ? 's' : '' }}
            </span>
        </div>

        {# ══════════════════════════════════════
           KPI GLOBAUX
        ══════════════════════════════════════ #}
        <div class="section-heading">
            <div class="sh-icon" style="background:#eef0fd">📈</div>
            <div><h2>Vue d'ensemble</h2><p>Indicateurs clés de performance</p></div>
        </div>

        <div class="kpi-grid">
            <div class="kpi-card" style="--accent: var(--blue)">
                <div class="kpi-icon">🗂️</div>
                <div class="kpi-value">{{ totalCandidatures }}</div>
                <div class="kpi-label">Candidatures</div>
                <div class="kpi-sub">{{ rateOfCandidature }}% des utilisateurs</div>
            </div>
            <div class="kpi-card" style="--accent: var(--green)">
                <div class="kpi-icon">✅</div>
                <div class="kpi-value">{{ acceptanceRate }}%</div>
                <div class="kpi-label">Taux d'acceptation</div>
                <div class="kpi-sub">{{ candidaturesByStatus['Accepté'] ?? 0 }} acceptées</div>
            </div>
            <div class="kpi-card" style="--accent: var(--purple)">
                <div class="kpi-icon">⭐</div>
                <div class="kpi-value">{{ totalPreferences }}</div>
                <div class="kpi-label">Préférences</div>
                <div class="kpi-sub">{{ rateOfPreference }}% des utilisateurs</div>
            </div>
            <div class="kpi-card" style="--accent: var(--cyan)">
                <div class="kpi-icon">💼</div>
                <div class="kpi-value">{{ totalOffers }}</div>
                <div class="kpi-label">Offres actives</div>
                <div class="kpi-sub">{{ totalUsers }} utilisateurs</div>
            </div>
            <div class="kpi-card" style="--accent: var(--orange)">
                <div class="kpi-icon">🎯</div>
                {% set avgMatchGlobal = matchingStats|length > 0 ? (matchingStats|map(m => m.avgScore)|reduce((acc, v) => acc + v, 0) / matchingStats|length)|round(1) : 0 %}
                <div class="kpi-value">{{ avgMatchGlobal }}%</div>
                <div class="kpi-label">Score matching moyen</div>
                <div class="kpi-sub">{{ matchingStats|length }} offres analysées</div>
            </div>
        </div>

        {# ══════════════════════════════════════
           TIMELINE
        ══════════════════════════════════════ #}
        <div class="timeline-card">
            <div class="chart-card-header">
                <h3>📆 Activité des candidatures — 14 derniers jours</h3>
                <span class="chart-badge">Timeline</span>
            </div>
            {% set tlMax = timeline|reduce((acc, v) => v > acc ? v : acc, 1) %}
            <div class="timeline-chart">
                {% for day, count in timeline %}
                    {% set pct = tlMax > 0 ? (count / tlMax * 100) : 0 %}
                    <div class="tl-col" title="{{ count }} candidature(s) le {{ day }}">
                        <div class="tl-bar-wrap">
                            <div class="tl-bar" data-val="{{ count }}"
                                 style="height: {{ pct }}%; position:relative">
                                <span class="tl-tooltip">{{ count }}</span>
                            </div>
                        </div>
                        <div class="tl-label">{{ day|date('d/M') }}</div>
                    </div>
                {% endfor %}
            </div>
        </div>

        {# ══════════════════════════════════════
           CANDIDATURES — 2 colonnes
        ══════════════════════════════════════ #}
        <div class="section-heading">
            <div class="sh-icon" style="background:#fef3f2">🗂️</div>
            <div><h2>Analyse des Candidatures</h2><p>Statuts, niveaux et domaines</p></div>
        </div>

        <div class="chart-grid-2">
            {# Statuts #}
            <div class="chart-card">
                <div class="chart-card-header">
                    <h3>📊 Par statut</h3>
                    <span class="chart-badge">{{ candidaturesByStatus|length }} statuts</span>
                </div>
                {% if candidaturesByStatus|length > 0 %}
                    {% for status, count in candidaturesByStatus %}
                        {% set pct = maxStatus > 0 ? (count / maxStatus * 100)|round : 0 %}
                        {% set cssClass = status|replace({' ': '-'}) %}
                        <div class="bar-row">
                            <div class="bar-label" title="{{ status }}">{{ status }}</div>
                            <div class="bar-track">
                                <div class="bar-fill status-{{ cssClass }}"
                                     style="width:{{ pct }}%">
                                    {% if pct > 20 %}{{ count }}{% endif %}
                                </div>
                            </div>
                            <div class="bar-count">{{ count }}</div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">Aucune donnée</div>
                {% endif %}
            </div>

            {# Niveaux d'expérience #}
            <div class="chart-card">
                <div class="chart-card-header">
                    <h3>🎓 Par niveau d'expérience</h3>
                    <span class="chart-badge">{{ candidaturesByNiveau|length }} niveaux</span>
                </div>
                {% set niveauColors = ['var(--blue)', 'var(--cyan)', 'var(--green)', 'var(--orange)', 'var(--purple)', 'var(--red)'] %}
                {% if candidaturesByNiveau|length > 0 %}
                    {% for niveau, count in candidaturesByNiveau %}
                        {% set pct = maxNiveau > 0 ? (count / maxNiveau * 100)|round : 0 %}
                        {% set colorIdx = loop.index0 % 6 %}
                        <div class="bar-row">
                            <div class="bar-label">{{ niveau }}</div>
                            <div class="bar-track">
                                <div class="bar-fill"
                                     style="width:{{ pct }}%; --bar-color:{{ niveauColors[colorIdx] }}">
                                    {% if pct > 20 %}{{ count }}{% endif %}
                                </div>
                            </div>
                            <div class="bar-count">{{ count }}</div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">Aucune donnée</div>
                {% endif %}
            </div>
        </div>

        <div class="chart-grid-2">
            {# Domaines #}
            <div class="chart-card">
                <div class="chart-card-header">
                    <h3>🏷️ Par domaine d'expérience</h3>
                    <span class="chart-badge">{{ candidaturesByDomaine|length }} domaines</span>
                </div>
                {% if candidaturesByDomaine|length > 0 %}
                    {% set sortedDomaines = candidaturesByDomaine|sort|reverse %}
                    {% for domaine, count in sortedDomaines|slice(0, 8) %}
                        {% set pct = maxDomaine > 0 ? (count / maxDomaine * 100)|round : 0 %}
                        <div class="bar-row">
                            <div class="bar-label">{{ domaine }}</div>
                            <div class="bar-track">
                                <div class="bar-fill" style="width:{{ pct }}%; --bar-color: var(--cyan)">
                                    {% if pct > 20 %}{{ count }}{% endif %}
                                </div>
                            </div>
                            <div class="bar-count">{{ count }}</div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">Aucune donnée</div>
                {% endif %}
            </div>

            {# Top offres #}
            <div class="chart-card">
                <div class="chart-card-header">
                    <h3>💼 Top offres demandées</h3>
                    <span class="chart-badge">Top 8</span>
                </div>
                {% if candidaturesByOffers|length > 0 %}
                    {% set sortedOffers = candidaturesByOffers|sort|reverse %}
                    {% for offre, count in sortedOffers|slice(0, 8) %}
                        {% set pct = maxOffers > 0 ? (count / maxOffers * 100)|round : 0 %}
                        <div class="bar-row">
                            <div class="bar-label" title="{{ offre }}">{{ offre|length > 22 ? offre|slice(0,22)~'…' : offre }}</div>
                            <div class="bar-track">
                                <div class="bar-fill" style="width:{{ pct }}%; --bar-color: var(--orange)">
                                    {% if pct > 20 %}{{ count }}{% endif %}
                                </div>
                            </div>
                            <div class="bar-count">{{ count }}</div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">Aucune donnée</div>
                {% endif %}
            </div>
        </div>

        {# ══════════════════════════════════════
           PRÉFÉRENCES
        ══════════════════════════════════════ #}
        <div class="section-heading">
            <div class="sh-icon" style="background:#f0fdf4">⭐</div>
            <div><h2>Analyse des Préférences</h2><p>Modes de travail, disponibilités et contrats souhaités</p></div>
        </div>

        <div class="chart-grid-2">
            {# Mode de travail #}
            <div class="chart-card">
                <div class="chart-card-header">
                    <h3>🌍 Mode de travail souhaité</h3>
                    <span class="chart-badge">{{ preferencesByMode|length }} modes</span>
                </div>
                {% set modeColors = {'Hybride': 'var(--purple)', '100% Télétravail': 'var(--cyan)', '100% Présentiel': 'var(--orange)'} %}
                {% if preferencesByMode|length > 0 %}
                    {# SVG donut #}
                    {% set total = preferencesByMode|reduce((acc, v) => acc + v, 0) %}
                    <div class="donut-svg-wrap">
                        <svg class="donut-svg" width="100" height="100" viewBox="0 0 36 36">
                            {% set colors = ['#7209b7','#00b4d8','#ff9500','#4361ee','#06d6a0'] %}
                            {% set offset = 0 %}
                            {% set circumference = 100.53 %}{# 2*pi*16 #}
                            {% for mode, count in preferencesByMode %}
                                {% set pct = total > 0 ? (count / total * 100) : 0 %}
                                {% set dash = (pct / 100 * circumference)|round(2) %}
                                {% set gap = (circumference - dash)|round(2) %}
                                <circle cx="18" cy="18" r="16"
                                    fill="none"
                                    stroke="{{ colors[loop.index0 % 5] }}"
                                    stroke-width="3"
                                    stroke-dasharray="{{ dash }} {{ gap }}"
                                    stroke-dashoffset="{{ -(offset * circumference / 100)|round(2) + 25.13 }}"
                                    transform="rotate(-90 18 18)" />
                                {% set offset = offset + pct %}
                            {% endfor %}
                            <text x="18" y="20" text-anchor="middle" font-size="5" font-weight="bold" fill="#2c3e50">{{ total }}</text>
                        </svg>
                        <div class="donut-legend">
                            {% for mode, count in preferencesByMode %}
                                {% set pct = total > 0 ? (count / total * 100)|round : 0 %}
                                <div class="donut-legend-item">
                                    <div class="donut-legend-color" style="background:{{ colors[loop.index0 % 5] }}"></div>
                                    <span class="donut-legend-label">{{ mode|length > 18 ? mode|slice(0,18)~'…' : mode }}</span>
                                    <span class="donut-legend-val">{{ pct }}%</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                    {# Barres #}
                    {% for mode, count in preferencesByMode %}
                        {% set pct = maxMode > 0 ? (count / maxMode * 100)|round : 0 %}
                        <div class="bar-row">
                            <div class="bar-label">{{ mode|length > 20 ? mode|slice(0,20)~'…' : mode }}</div>
                            <div class="bar-track">
                                <div class="bar-fill" style="width:{{ pct }}%; --bar-color: {{ colors[loop.index0 % 5] }}">
                                    {% if pct > 20 %}{{ count }}{% endif %}
                                </div>
                            </div>
                            <div class="bar-count">{{ count }}</div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">Aucune donnée</div>
                {% endif %}
            </div>

            {# Disponibilité #}
            <div class="chart-card">
                <div class="chart-card-header">
                    <h3>📅 Disponibilité déclarée</h3>
                    <span class="chart-badge">{{ preferencesByDisponibilite|length }} valeurs</span>
                </div>
                {% if preferencesByDisponibilite|length > 0 %}
                    {% for dispo, count in preferencesByDisponibilite %}
                        {% set pct = maxDispo > 0 ? (count / maxDispo * 100)|round : 0 %}
                        <div class="bar-row">
                            <div class="bar-label">{{ dispo }}</div>
                            <div class="bar-track">
                                <div class="bar-fill" style="width:{{ pct }}%; --bar-color: var(--green)">
                                    {% if pct > 20 %}{{ count }}{% endif %}
                                </div>
                            </div>
                            <div class="bar-count">{{ count }}</div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">Aucune donnée</div>
                {% endif %}
            </div>
        </div>

        {# Contrats + Salaires #}
        <div class="chart-grid-2">
            <div class="chart-card">
                <div class="chart-card-header">
                    <h3>📝 Type de contrat souhaité</h3>
                    <span class="chart-badge">{{ preferencesByContrat|length }} types</span>
                </div>
                {% if preferencesByContrat|length > 0 %}
                    {% for contrat, count in preferencesByContrat %}
                        {% set pct = maxContrat > 0 ? (count / maxContrat * 100)|round : 0 %}
                        <div class="bar-row">
                            <div class="bar-label">{{ contrat }}</div>
                            <div class="bar-track">
                                <div class="bar-fill" style="width:{{ pct }}%; --bar-color: var(--blue)">
                                    {% if pct > 20 %}{{ count }}{% endif %}
                                </div>
                            </div>
                            <div class="bar-count">{{ count }}</div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">Aucune donnée</div>
                {% endif %}
            </div>

            <div class="chart-card">
                <div class="chart-card-header">
                    <h3>💰 Prétention salariale moyenne (TND)</h3>
                    <span class="chart-badge">Par contrat</span>
                </div>
                {% if avgSalairesByContrat|length > 0 %}
                    {% set salClasses = {'CDI':'','CDD':'cdd','Stage':'stage','Alternance':'alternance','Freelance':'freelance'} %}
                    <div class="salary-grid">
                        {% for contrat, avg in avgSalairesByContrat %}
                            <div class="salary-card {{ salClasses[contrat] ?? '' }}">
                                <div class="salary-contrat">{{ contrat }}</div>
                                <div class="salary-amount">{{ avg|number_format(0, ',', ' ') }}</div>
                                <div class="salary-unit">TND / mois</div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-state">Aucune donnée salariale</div>
                {% endif %}
            </div>
        </div>

        {# ══════════════════════════════════════
           MATCHING ANALYTICS
        ══════════════════════════════════════ #}
        <div class="section-heading">
            <div class="sh-icon" style="background:#fff7ed">🎯</div>
            <div><h2>Matching Offres / Candidats</h2><p>Score de compatibilité moyen par offre</p></div>
        </div>

        <div class="match-table-wrap">
            <div class="chart-card-header">
                <h3>🔍 Compatibilité offres — préférences candidats</h3>
                <input type="text" class="table-search" id="matchSearch"
                       placeholder="Filtrer par offre…" oninput="filterMatchTable(this.value)">
            </div>
            {% if matchingStats|length > 0 %}
                <table class="match-table" id="matchTable">
                    <thead>
                        <tr>
                            <th>Offre</th>
                            <th>Score moyen</th>
                            <th>Meilleur score</th>
                            <th>Candidats compatibles (≥70%)</th>
                            <th>Total analysés</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stat in matchingStats %}
                            {% set color =
                                stat.avgScore >= 85 ? '#06d6a0' :
                                stat.avgScore >= 70 ? '#00b4d8' :
                                stat.avgScore >= 55 ? '#ffd60a' :
                                stat.avgScore >= 40 ? '#ff9500' : '#ef476f' %}
                            <tr>
                                <td><strong>{{ stat.offre }}</strong></td>
                                <td>
                                    <div class="score-pill" style="background:{{ color }}">{{ stat.avgScore }}%</div>
                                    <div class="match-mini-bar">
                                        <div class="match-mini-fill" style="width:{{ stat.avgScore }}%; background:{{ color }}"></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="score-pill" style="background:#4361ee">{{ stat.maxScore }}%</div>
                                </td>
                                <td>
                                    <span class="candidates-chip">
                                        👤 {{ stat.candidatesMatched }} / {{ stat.total }}
                                    </span>
                                </td>
                                <td style="color:var(--muted)">{{ stat.total }} préf.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="empty-state">Aucune offre ouverte à analyser, ou aucune préférence enregistrée.</div>
            {% endif %}
        </div>

    </main>
</div>

<script>
// Filtrage live de la table matching
function filterMatchTable(query) {
    const rows = document.querySelectorAll('#matchTable tbody tr');
    const q = query.toLowerCase();
    rows.forEach(row => {
        row.style.display = row.cells[0].textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}

// Animer les barres au chargement
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.bar-fill, .match-mini-fill').forEach(bar => {
        const w = bar.style.width;
        bar.style.width = '0';
        setTimeout(() => { bar.style.width = w; }, 100);
    });
});
</script>
{% endblock %}
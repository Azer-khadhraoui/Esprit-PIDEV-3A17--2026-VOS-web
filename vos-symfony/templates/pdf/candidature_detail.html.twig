<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Détail de Candidature</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            color: #333;
            line-height: 1.5;
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #4361ee;
            padding-bottom: 15px;
        }
        .header h1 {
            color: #4361ee;
            margin: 0;
            font-size: 28px;
        }
        .header p {
            margin: 5px 0 0 0;
            color: #666;
            font-size: 12px;
        }
        .section {
            margin-bottom: 25px;
            page-break-inside: avoid;
        }
        .section h2 {
            background-color: #f0f3ff;
            color: #4361ee;
            padding: 10px 12px;
            margin: 15px 0 10px 0;
            font-size: 16px;
            border-left: 4px solid #4361ee;
        }
        .info-row {
            display: flex;
            margin-bottom: 8px;
            padding-bottom: 5px;
            border-bottom: 1px dotted #ddd;
        }
        .info-label {
            font-weight: bold;
            width: 200px;
            color: #4361ee;
            flex-shrink: 0;
        }
        .info-value {
            flex: 1;
            color: #333;
        }
        .info-row.full {
            flex-direction: column;
        }
        .info-row.full .info-label {
            margin-bottom: 5px;
        }
        .status {
            padding: 5px 10px;
            border-radius: 4px;
            font-weight: bold;
            display: inline-block;
            font-size: 12px;
        }
        .status-pending,
        .status-en-attente {
            background-color: #fef3c7;
            color: #92400e;
        }
        .status-examining,
        .status-en-examens {
            background-color: #dbeafe;
            color: #1e40af;
        }
        .status-accepted,
        .status-accepté {
            background-color: #dcfce7;
            color: #166534;
        }
        .status-rejected,
        .status-refusé {
            background-color: #fee2e2;
            color: #991b1b;
        }
        .experience-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 10px;
        }
        .experience-card {
            background-color: #f9fbff;
            border: 1px solid #e8ebf3;
            border-radius: 6px;
            padding: 12px;
        }
        .experience-card .label {
            font-size: 12px;
            color: #666;
            font-weight: 600;
            margin-bottom: 5px;
        }
        .experience-card .value {
            font-size: 14px;
            color: #333;
            font-weight: bold;
        }
        .message-box {
            background-color: #f9fbff;
            border: 1px solid #e8ebf3;
            border-radius: 6px;
            padding: 12px;
            margin-top: 10px;
            font-size: 13px;
            color: #333;
            line-height: 1.6;
        }
        .files-status {
            display: flex;
            gap: 15px;
            margin-top: 10px;
        }
        .file-item {
            flex: 1;
            background-color: #f9fbff;
            border: 1px solid #e8ebf3;
            border-radius: 6px;
            padding: 10px;
            text-align: center;
        }
        .file-item.uploaded {
            border-color: #16a34a;
            background-color: #f0fdf4;
        }
        .file-item.missing {
            border-color: #dc2626;
            background-color: #fef2f2;
        }
        .file-item .status-icon {
            font-size: 28px;
            margin-bottom: 8px;
            font-weight: bold;
            line-height: 1;
        }
        .file-item .name {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 3px;
        }
        .file-item .status-text {
            font-size: 11px;
            color: #666;
        }
        .footer {
            margin-top: 40px;
            padding-top: 15px;
            border-top: 2px solid #4361ee;
            text-align: center;
            color: #666;
            font-size: 12px;
        }
        .no-data {
            color: #999;
            font-style: italic;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Détail de Candidature</h1>
        <p>VOS - Système de Gestion des Candidatures</p>
    </div>

    <!-- SECTION CANDIDATURE -->
    <div class="section">
        <h2>📋 Informations de la Candidature</h2>
        <div class="info-row">
        </div>
        <div class="info-row">
            <div class="info-label">Date de candidature :</div>
            <div class="info-value">{{ candidature.dateCandidature|date('d/m/Y') }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Statut :</div>
            <div class="info-value">
                <span class="status status-{{ candidature.statut|lower|replace({' ': '-'}) }}">
                    {{ candidature.statut }}
                </span>
            </div>
        </div>
    </div>

    <!-- SECTION CANDIDAT -->
    <div class="section">
        <h2>👤 Informations du Candidat</h2>
        <div class="info-row">
            <div class="info-label">Nom Complet :</div>
            <div class="info-value">{{ candidat.nom }} {{ candidat.prenom }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Email :</div>
            <div class="info-value">{{ candidat.email }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Téléphone :</div>
            <div class="info-value">{{ candidat.telephone ?? '<span class="no-data">Non disponible</span>' }}</div>
        </div>
    </div>

    <!-- SECTION OFFRE -->
    <div class="section">
        <h2>💼 Offre d'Emploi</h2>
        <div class="info-row">
            <div class="info-label">Titre du Poste :</div>
            <div class="info-value">{{ offre.titre ?? '<span class="no-data">Offre supprimée</span>' }}</div>
        </div>
        {% if offre %}
        <div class="info-row">
            <div class="info-label">Entreprise :</div>
            <div class="info-value">{{ offre.nomEntreprise ?? '<span class="no-data">Non spécifiée</span>' }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Localisation :</div>
            <div class="info-value">{{ offre.lieu ?? '<span class="no-data">Non spécifiée</span>' }}</div>
        </div>
        {% endif %}
    </div>

    <!-- SECTION EXPÉRIENCE -->
    <div class="section">
        <h2>⭐ Expérience Professionnelle</h2>
        <div class="info-row">
            <div class="info-label">Niveau d'expérience :</div>
            <div class="info-value">{{ candidature.niveauExperience ?? '<span class="no-data">Non spécifié</span>' }}</div>
        </div>
        <div class="experience-grid">
            <div class="experience-card">
                <div class="label">Années d'expérience</div>
                <div class="value">
                    {% if candidature.anneesExperience is not null %}
                        {{ candidature.anneesExperience }} an{{ candidature.anneesExperience > 1 ? 's' : '' }}
                    {% else %}
                        <span class="no-data">Non spécifié</span>
                    {% endif %}
                </div>
            </div>
            <div class="experience-card">
                <div class="label">Domaine d'expérience</div>
                <div class="value">{{ candidature.domaineExperience ?? '<span class="no-data">Non spécifié</span>' }}</div>
            </div>
        </div>
        <div class="info-row" style="margin-top: 15px;">
            <div class="info-label">Dernier poste occupé :</div>
            <div class="info-value">{{ candidature.dernierPoste ?? '<span class="no-data">Non spécifié</span>' }}</div>
        </div>
    </div>

    <!-- SECTION MESSAGE -->
    {% if candidature.messageCandidat %}
    <div class="section">
        <h2>💬 Message du Candidat</h2>
        <div class="message-box">
            {{ candidature.messageCandidat }}
        </div>
    </div>
    {% endif %}

    <!-- SECTION FICHIERS -->
    <div class="section">
        <h2>📄 Fichiers Joints</h2>
        <div class="files-status">
            <div class="file-item {{ candidature.cv ? 'uploaded' : 'missing' }}">
                <div class="name">CV</div>
                <div class="status-text">{{ candidature.cv ? 'Uploadé' : 'Non uploadé' }}</div>
            </div>
            <div class="file-item {{ candidature.lettreMotivation ? 'uploaded' : 'missing' }}">
                <div class="name">Lettre de Motivation</div>
                <div class="status-text">{{ candidature.lettreMotivation ? 'Uploadée' : 'Non uploadée' }}</div>
            </div>
        </div>
    </div>

    <div class="footer">
        <p>Ce document a été généré automatiquement par le système VOS.</p>
        <p>Date d'édition : {{ 'now'|date('d/m/Y à H:i') }}</p>
    </div>
</body>
</html>

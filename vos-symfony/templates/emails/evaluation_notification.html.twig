<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Notification Evaluation</title>
</head>
<body style="margin:0;padding:24px;background:#f8fafc;font-family:Segoe UI,Arial,sans-serif;color:#111827;">
<div style="max-width:680px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;">

    {# En-tête : orange pour création, violet pour mise à jour #}
    {% if action == 'mise_a_jour' %}
        <div style="padding:20px 24px;background:linear-gradient(90deg,#6d28d9,#8b5cf6);color:#ffffff;">
            <p style="margin:0 0 4px 0;font-size:11px;letter-spacing:.08em;text-transform:uppercase;opacity:.85;">Mise à jour</p>
            <h1 style="margin:0;font-size:20px;line-height:1.2;">Evaluation modifiée</h1>
            <p style="margin:8px 0 0 0;font-size:13px;opacity:.92;">Entretien #{{ entretienId }}</p>
        </div>
    {% else %}
        <div style="padding:20px 24px;background:linear-gradient(90deg,#b45309,#f97316);color:#ffffff;">
            <p style="margin:0 0 4px 0;font-size:11px;letter-spacing:.08em;text-transform:uppercase;opacity:.85;">Nouveau</p>
            <h1 style="margin:0;font-size:20px;line-height:1.2;">Résultat évaluation</h1>
            <p style="margin:8px 0 0 0;font-size:13px;opacity:.92;">Entretien #{{ entretienId }}</p>
        </div>
    {% endif %}

    <div style="padding:24px;">
        <p style="margin:0 0 12px 0;font-size:15px;">Bonjour {{ recipientName }},</p>

        {% if action == 'mise_a_jour' %}
            {% if recipientRole == 'candidat' %}
                <p style="margin:0 0 14px 0;font-size:14px;line-height:1.6;">
                    L'évaluation de votre entretien a été mise à jour. Voici les informations actualisées.
                </p>
            {% else %}
                <p style="margin:0 0 14px 0;font-size:14px;line-height:1.6;">
                    L'évaluation de l'entretien #{{ entretienId }} a été modifiée. Voici les données actualisées.
                </p>
            {% endif %}
        {% else %}
            {% if recipientRole == 'candidat' %}
                <p style="margin:0 0 14px 0;font-size:14px;line-height:1.6;">
                    Le résultat de votre évaluation est maintenant disponible.
                </p>
            {% else %}
                <p style="margin:0 0 14px 0;font-size:14px;line-height:1.6;">
                    L'évaluation de l'entretien #{{ entretienId }} a été enregistrée pour suivi admin/RH.
                </p>
            {% endif %}
        {% endif %}

        <div style="border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;margin-bottom:16px;">
            <table style="width:100%;border-collapse:collapse;">
                <thead>
                    <tr style="display:none;"><th scope="col">Champ</th><th scope="col">Valeur</th></tr>
                </thead>
                <tbody>
                    <tr style="border-bottom:1px solid #e5e7eb;">
                        <th scope="row" style="width:40%;padding:10px 12px;background:#fff7ed;font-size:13px;font-weight:600;text-align:left;">Date entretien</th>
                        <td style="width:60%;padding:10px 12px;font-size:13px;">{{ date }}</td>
                    </tr>
                    <tr style="border-bottom:1px solid #e5e7eb;">
                        <th scope="row" style="padding:10px 12px;background:#fff7ed;font-size:13px;font-weight:600;text-align:left;">Heure entretien</th>
                        <td style="padding:10px 12px;font-size:13px;">{{ heure }}</td>
                    </tr>
                    <tr style="border-bottom:1px solid #e5e7eb;">
                        <th scope="row" style="padding:10px 12px;background:#fff7ed;font-size:13px;font-weight:600;text-align:left;">Décision</th>
                        <td style="padding:10px 12px;font-size:13px;">{{ decision }}</td>
                    </tr>
                    <tr style="border-bottom:1px solid #e5e7eb;">
                        <th scope="row" style="padding:10px 12px;background:#fff7ed;font-size:13px;font-weight:600;text-align:left;">Note entretien</th>
                        <td style="padding:10px 12px;font-size:13px;">{{ note }}</td>
                    </tr>
                    <tr style="border-bottom:1px solid #e5e7eb;">
                        <th scope="row" style="padding:10px 12px;background:#fff7ed;font-size:13px;font-weight:600;text-align:left;">Score test</th>
                        <td style="padding:10px 12px;font-size:13px;">{{ score }}</td>
                    </tr>
                    <tr>
                        <th scope="row" style="padding:10px 12px;background:#fff7ed;font-size:13px;font-weight:600;text-align:left;">Commentaire</th>
                        <td style="padding:10px 12px;font-size:13px;">{{ commentaire }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <p style="margin:0;font-size:12px;color:#6b7280;">Message automatique, merci de ne pas y répondre.</p>
    </div>
</div>
</body>
</html>

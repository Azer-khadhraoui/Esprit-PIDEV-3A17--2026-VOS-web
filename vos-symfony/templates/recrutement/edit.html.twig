{% extends 'gestion_offre_base.html.twig' %}

{% block title %}Modifier Recrutement | VOS{% endblock %}

{% block styles %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-shell">
    <aside class="sidebar">
        <div class="brand">
            <span class="brand-dot"></span>
            <span>VOS Admin</span>
        </div>
        <nav class="nav-list">
            <a class="nav-item" href="{{ path('app_admin_dashboard') }}">Gestion Users</a>
            <a class="nav-item" href="{{ path('gestion_offre_dashboard') }}">Gestion Offres</a>
            <a class="nav-item" href="{{ path('app_admin_candidatures') }}">Gestion Candidatures</a>
            <a class="nav-item" href="{{ path('gestion_entretien_dashboard') }}">Gestion Entretiens</a>
            <a class="nav-item is-active" href="{{ path('recrutement_index') }}">Gestion Recrutements</a>
            <a class="nav-item" href="#">Forum</a>
            <a class="nav-item" href="#">Rapports</a>
        </nav>
        <div class="sidebar-footer">Panel Administration</div>
    </aside>

    <main class="content">
        <header class="topbar">
            <div>
                <h1>Modifier le recrutement #{{ recrutement.id }}</h1>
                <p>Mettre a jour les informations du recrutement.</p>
            </div>
            <a href="{{ path('recrutement_index') }}" class="btn-logout">Retour a la liste</a>
        </header>

        <section class="table-card edit-page-card">
            {{ include('recrutement/_form.html.twig', {'form': form, 'button_label': 'Mettre a jour'}) }}
        </section>
    </main>
</div>
{% endblock %}

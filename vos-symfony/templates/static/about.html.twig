{% extends 'base.html.twig' %}

{% block title %}À propos | VOS{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/public-pages.css') }}">
{% endblock %}

{% block body %}
    {% include 'components/vos_header.html.twig' %}
<div class="public-page">

    <section class="public-card">
        <div class="public-hero">
            <h1>À propos de VOS</h1>
            <p>VOS centralise la gestion des utilisateurs avec une interface simple, moderne et sécurisée pour les administrateurs et les clients.</p>
        </div>

        <div class="public-content">
            <div class="info-grid">
                <article class="info-item">
                    <h3>Mission</h3>
                    <p>Faciliter la gestion des comptes et offrir une expérience claire pour tous les rôles.</p>
                </article>

                <article class="info-item">
                    <h3>Vision</h3>
                    <p>Construire une plateforme RH évolutive, fiable et facile à maintenir.</p>
                </article>

                <article class="info-item">
                    <h3>Valeurs</h3>
                    <p>Simplicité, performance et sécurité des données utilisateur.</p>
                    <a class="cta-link" href="{{ path('app_contact') }}">Nous contacter</a>
                </article>
            </div>

            {% if appUrl is defined and appUrl != '' %}
                <div class="info-item" style="margin-top: 24px; display: grid; gap: 14px; align-items: center; grid-template-columns: 140px 1fr;">
                    <div style="background:#fff;border:1px solid #d8e4f6;border-radius:18px;padding:12px;box-shadow:0 12px 26px rgba(15,29,53,0.08);width:fit-content;">
                        <img src="{{ qr_code_data_uri(appUrl) }}" alt="QR code vers l'application VOS" style="width:116px;height:116px;display:block;">
                    </div>
                    <div>
                        <h3 style="margin-top:0;">Accès mobile</h3>
                        <p>Scanne ce QR code avec ton téléphone pour ouvrir directement l'application VOS sur le réseau actuel.</p>
                    </div>
                </div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}

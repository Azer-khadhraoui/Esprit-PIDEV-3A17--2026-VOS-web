{% extends 'gestion_offre_base.html.twig' %}

{% block title %}{{ pageTitle }} | VOS Admin{% endblock %}

{% block body %}
    <div class="app-shell">
        <aside class="sidebar">
        <div class="brand">
            <span class="brand-dot"></span>
            <span>VOS Admin</span>
        </div>
        <nav class="nav-list">
            <a class="nav-item" href="{{ path('app_admin_dashboard') }}">Gestion Users</a>
            <a class="nav-item is-active" href="{{ path('gestion_offre_dashboard') }}">Gestion Offres</a>
            <a class="nav-item" href="{{ path('app_admin_candidatures') }}">Gestion Candidatures</a>
            <a class="nav-item" href="{{ path('gestion_entretien_dashboard') }}">Gestion Entretiens</a>
            <a class="nav-item" href="{{ path('recrutement_index') }}">Gestion Recrutements</a>
            <a class="nav-item" href="#">Forum</a>
            <a class="nav-item" href="#">Rapports</a>
        </nav>
        <div class="sidebar-footer">Panel Administration</div>
    </aside>

        <main class="content">
            <div class="topbar">
                <div>
                    <h1 class="page-title" style="font-size:clamp(1.8rem, 2.5vw, 2.7rem);">{{ pageTitle }}</h1>
                    <p class="subtitle">Bienvenue {{ currentUserName }}</p>
                </div>
                <form method="post" action="{{ path('app_logout') }}" novalidate>
                    <button class="logout-btn" type="submit">Déconnexion</button>
                </form>
            </div>

            <nav class="module-nav" aria-label="Navigation offre et critere offre">
                <a class="module-link is-active" href="{{ path('gestion_offre_dashboard') }}">Offre</a>
                {% if offre.idOffre %}
                    <a class="module-link" href="{{ path('gestion_offre_criteres', {idOffre: offre.idOffre}) }}">Critere Offre</a>
                {% else %}
                    <span class="module-link" style="opacity:0.55;cursor:not-allowed;">Critere Offre</span>
                {% endif %}
                <a class="module-link" href="{{ path('gestion_offre_statistique') }}">Statistique</a>
            </nav>

            {% for message in app.flashes('error') %}
                <div style="margin-bottom:14px;padding:14px 16px;border-radius:14px;background:#fee2e2;color:#991b1b;font-weight:600;max-width:980px;">{{ message }}</div>
            {% endfor %}

            <section style="background:var(--panel);color:var(--text);border-radius:var(--radius);box-shadow:var(--shadow);padding:24px;max-width:980px;">
                <form method="post" id="offreForm" novalidate style="display:grid;gap:14px;">
                    <input type="hidden" name="_token" value="{{ csrf_token(csrfTokenId|default('offre_form_new')) }}">
                    {% if fieldErrors._form is defined %}
                        <div style="padding:10px 12px;border-radius:10px;background:#fee2e2;color:#991b1b;font-size:0.9rem;">{{ fieldErrors._form }}</div>
                    {% endif %}
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div style="display:grid;gap:6px;">
                            <label style="font-weight:600;color:#334155;">
                                Titre
                            </label>
                            <input type="text" name="titre" id="titre" value="{{ offre.titre ?? '' }}" minlength="3" maxlength="100" style="border:1px solid #d0d8e5;border-radius:12px;padding:12px;transition:border-color 0.2s;">
                            <span id="titre-error" style="display:{{ fieldErrors.titre is defined ? 'block' : 'none' }};font-size:0.875rem;color:#dc2626;margin-top:2px;">{{ fieldErrors.titre|default('') }}</span>
                        </div>
                        <div style="display:grid;gap:6px;">
                            <label style="font-weight:600;color:#334155;">
                                Type contrat
                            </label>
                            {% set currentTypeContrat = offre.typeContrat ?? '' %}
                            <select name="type_contrat" id="type_contrat" style="border:1px solid #d0d8e5;border-radius:12px;padding:12px;background:#fff;transition:border-color 0.2s;">
                                <option value="">Choisir un type</option>
                                <option value="CDI" {{ currentTypeContrat == 'CDI' ? 'selected' : '' }}>CDI</option>
                                <option value="CDD" {{ currentTypeContrat == 'CDD' ? 'selected' : '' }}>CDD</option>
                                <option value="Stage" {{ currentTypeContrat == 'Stage' ? 'selected' : '' }}>Stage</option>
                                <option value="Alternance" {{ currentTypeContrat == 'Alternance' ? 'selected' : '' }}>Alternance</option>
                                <option value="Freelance" {{ currentTypeContrat == 'Freelance' ? 'selected' : '' }}>Freelance</option>
                                {% if currentTypeContrat not in ['', 'CDI', 'CDD', 'Stage', 'Alternance', 'Freelance'] %}
                                    <option value="{{ currentTypeContrat }}" selected>{{ currentTypeContrat }}</option>
                                {% endif %}
                            </select>
                            <span id="type_contrat-error" style="display:{{ fieldErrors.type_contrat is defined ? 'block' : 'none' }};font-size:0.875rem;color:#dc2626;margin-top:2px;">{{ fieldErrors.type_contrat|default('') }}</span>
                        </div>
                    </div>

                    <div style="display:grid;gap:6px;">
                        <label style="font-weight:600;color:#334155;">
                            Description
                        </label>
                        <textarea name="description" id="description" rows="4" maxlength="5000" style="border:1px solid #d0d8e5;border-radius:12px;padding:12px;resize:vertical;transition:border-color 0.2s;">{{ offre.description ?? '' }}</textarea>
                        <span id="description-error" style="display:{{ fieldErrors.description is defined ? 'block' : 'none' }};font-size:0.875rem;color:#dc2626;margin-top:2px;">{{ fieldErrors.description|default('') }}</span>
                        {% if submitLabel == 'Ajouter' %}
                            <small id="description-ai-feedback" style="font-size:0.82rem;color:#64748b;">Description auto-generee selon le titre de l offre.</small>
                        {% endif %}
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
                        <div style="display:grid;gap:6px;">
                            <label style="font-weight:600;color:#334155;">
                                Statut
                            </label>
                            <select name="statut_offre" id="statut_offre" style="border:1px solid #d0d8e5;border-radius:12px;padding:12px;background:#fff;transition:border-color 0.2s;">
                                {% set currentStatus = offre.statutOffre ?? '' %}
                                <option value="">Choisir un statut</option>
                                <option value="OUVERTE" {{ currentStatus in ['OUVERTE', 'ACTIVE'] ? 'selected' : '' }}>Ouverte aux candidatures</option>
                                <option value="INACTIVE" {{ currentStatus == 'INACTIVE' ? 'selected' : '' }}>En pause (temporairement masquée)</option>
                                <option value="FERMEE" {{ currentStatus == 'FERMEE' ? 'selected' : '' }}>Fermée</option>
                                {% if currentStatus not in ['', 'OUVERTE', 'ACTIVE', 'INACTIVE', 'FERMEE'] %}
                                    <option value="{{ currentStatus }}" selected>{{ currentStatus }}</option>
                                {% endif %}
                            </select>
                            <span id="statut_offre-error" style="display:{{ fieldErrors.statut_offre is defined ? 'block' : 'none' }};font-size:0.875rem;color:#dc2626;margin-top:2px;">{{ fieldErrors.statut_offre|default('') }}</span>
                        </div>

                        <div style="display:grid;gap:6px;">
                            <label style="font-weight:600;color:#334155;">
                                Date publication
                            </label>
                            <input type="date" name="date_publication" id="date_publication" value="{{ offre.datePublication ? offre.datePublication|date('Y-m-d') : '' }}" min="{{ 'now'|date('Y-m-d') }}" style="border:1px solid #d0d8e5;border-radius:12px;padding:12px;transition:border-color 0.2s;">
                            <span id="date_publication-error" style="display:{{ fieldErrors.date_publication is defined ? 'block' : 'none' }};font-size:0.875rem;color:#dc2626;margin-top:2px;">{{ fieldErrors.date_publication|default('') }}</span>
                        </div>

                        <div style="display:grid;gap:6px;">
                            <label style="font-weight:600;color:#334155;">
                                ID utilisateur
                            </label>
                            <select name="id_utilisateur" id="id_utilisateur" style="border:1px solid #d0d8e5;border-radius:12px;padding:12px;background:#fff;transition:border-color 0.2s;">
                                {% if userOptions is not empty %}
                                    {% for user in userOptions %}
                                        <option value="{{ user.id }}" selected>{{ user.label }}</option>
                                    {% endfor %}
                                {% else %}
                                    <option value="">Aucun administrateur connecté</option>
                                {% endif %}
                            </select>
                            <span id="id_utilisateur-error" style="display:{{ fieldErrors.id_utilisateur is defined ? 'block' : 'none' }};font-size:0.875rem;color:#dc2626;margin-top:2px;">{{ fieldErrors.id_utilisateur|default('') }}</span>
                        </div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div style="display:grid;gap:6px;">
                            <label style="font-weight:600;color:#334155;">
                                Work preference
                            </label>
                            {% set currentWorkPreference = offre.workPreference ?? '' %}
                            <select name="work_preference" id="work_preference" style="border:1px solid #d0d8e5;border-radius:12px;padding:12px;background:#fff;transition:border-color 0.2s;">
                                <option value="">Choisir une preference</option>
                                <option value="On-site" {{ currentWorkPreference == 'On-site' ? 'selected' : '' }}>On-site</option>
                                <option value="Remote" {{ currentWorkPreference == 'Remote' ? 'selected' : '' }}>Remote</option>
                                <option value="Hybrid" {{ currentWorkPreference == 'Hybrid' ? 'selected' : '' }}>Hybrid</option>
                                {% if currentWorkPreference not in ['', 'On-site', 'Remote', 'Hybrid'] %}
                                    <option value="{{ currentWorkPreference }}" selected>{{ currentWorkPreference }}</option>
                                {% endif %}
                            </select>
                            <span id="work_preference-error" style="display:{{ fieldErrors.work_preference is defined ? 'block' : 'none' }};font-size:0.875rem;color:#dc2626;margin-top:2px;">{{ fieldErrors.work_preference|default('') }}</span>
                        </div>
                        <div style="display:grid;gap:6px;">
                            <label style="font-weight:600;color:#334155;">
                                Lieu
                            </label>
                            <input type="text" name="lieu" id="lieu" value="{{ offre.lieu ?? '' }}" maxlength="255" style="border:1px solid #d0d8e5;border-radius:12px;padding:12px;transition:border-color 0.2s;">
                            <span id="lieu-error" style="display:{{ fieldErrors.lieu is defined ? 'block' : 'none' }};font-size:0.875rem;color:#dc2626;margin-top:2px;">{{ fieldErrors.lieu|default('') }}</span>
                        </div>
                    </div>

                    {% if submitLabel == 'Ajouter' %}
                        <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid #d0d8e5;border-radius:12px;background:#f8fafc;">
                            <input type="checkbox" name="send_notification" id="send_notification" value="1" {{ sendNotification|default(true) ? 'checked' : '' }} style="width:18px;height:18px;">
                            <label for="send_notification" style="font-weight:600;color:#334155;cursor:pointer;">
                                Envoyer un email a tous les comptes client apres la creation
                            </label>
                        </div>
                    {% endif %}

                    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:2px;">
                        <button type="submit" style="padding:11px 18px;border:0;border-radius:12px;background:#1d4ed8;color:#fff;font-weight:700;cursor:pointer;">{{ submitLabel }}</button>
                        <a href="{{ path('gestion_offre_dashboard') }}" style="display:inline-flex;align-items:center;padding:11px 16px;border-radius:12px;background:#e2e8f0;color:#0f172a;font-weight:700;">Annuler</a>
                    </div>
                </form>
            </section>

            <script>
                (function() {
                    const form = document.getElementById('offreForm');
                    const fields = {
                        titre: { required: true, minLength: 3, maxLength: 100, type: 'text', label: 'Titre' },
                        type_contrat: { required: true, type: 'select', label: 'Type contrat' },
                        description: { required: true, minLength: 10, maxLength: 5000, type: 'textarea', label: 'Description' },
                        statut_offre: { required: true, type: 'select', label: 'Statut' },
                        date_publication: { required: true, type: 'date', label: 'Date publication' },
                        id_utilisateur: { required: true, type: 'select', label: 'ID utilisateur' },
                        work_preference: { required: true, type: 'select', label: 'Work preference' },
                        lieu: { required: true, minLength: 3, maxLength: 255, type: 'text', label: 'Lieu' }
                    };

                    // Track which fields have been touched
                    const touchedFields = new Set();
                    const successTimeouts = {};

                    // Validation logic
                    function validateField(fieldName, showMessage = true) {
                        const field = document.getElementById(fieldName);
                        const error = document.getElementById(fieldName + '-error');
                        const config = fields[fieldName];
                        
                        if (!field || !error) return true;

                        const value = field.value.trim();
                        let errorMsg = '';
                        let isValid = true;

                        // Required field validation
                        if (config.required && !value) {
                            errorMsg = 'Ce champ est obligatoire';
                            isValid = false;
                        }
                        // Min length validation
                        else if (value && config.minLength && value.length < config.minLength) {
                            errorMsg = `⚠️ Au moins ${config.minLength} caractères requis`;
                            isValid = false;
                        }
                        // Max length validation
                        else if (value && config.maxLength && value.length > config.maxLength) {
                            errorMsg = `Maximum ${config.maxLength} caracteres (${value.length}/${config.maxLength})`;
                            isValid = false;
                        }
                        else if (fieldName === 'date_publication' && value) {
                            const selectedDate = new Date(value + 'T00:00:00');
                            const today = new Date();
                            today.setHours(0, 0, 0, 0);

                            if (selectedDate > today) {
                                errorMsg = 'La date ne peut pas etre dans le futur';
                                isValid = false;
                            }
                        }
                        // Success feedback for valid filled fields
                        else if (value && isValid) {
                            if (config.required || (config.minLength && value.length >= config.minLength)) {
                                errorMsg = `✓ Valide (${value.length}/${config.maxLength || 'illimité'} caractères)`;
                            }
                        }

                        // Clear any existing timeout for this field
                        if (successTimeouts[fieldName]) {
                            clearTimeout(successTimeouts[fieldName]);
                            delete successTimeouts[fieldName];
                        }

                        // Update border color and error message
                        if (!isValid) {
                            field.style.borderColor = '#dc2626';
                            if (showMessage) {
                                error.style.display = 'block';
                                error.textContent = errorMsg;
                                error.style.color = '#dc2626';
                            }
                        } else if (isValid && value && (config.required || (config.minLength && value.length >= config.minLength))) {
                            field.style.borderColor = '#16a34a';
                            if (showMessage && touchedFields.has(fieldName)) {
                                error.style.display = 'block';
                                error.textContent = errorMsg;
                                error.style.color = '#16a34a';
                                
                                // Auto-hide success message after 1 second
                                successTimeouts[fieldName] = setTimeout(() => {
                                    error.style.display = 'none';
                                    delete successTimeouts[fieldName];
                                }, 1000);
                            }
                        } else {
                            field.style.borderColor = '#d0d8e5';
                            error.style.display = 'none';
                            error.style.color = '#f59e0b';
                        }

                        return isValid;
                    }

                    // Attach event listeners to all fields
                    Object.keys(fields).forEach(fieldName => {
                        const field = document.getElementById(fieldName);
                        if (field) {
                            // Mark field as touched on first interaction
                            field.addEventListener('input', () => {
                                touchedFields.add(fieldName);
                                validateField(fieldName, true);
                            });
                            field.addEventListener('change', () => {
                                touchedFields.add(fieldName);
                                validateField(fieldName, true);
                            });
                            field.addEventListener('blur', () => {
                                touchedFields.add(fieldName);
                                validateField(fieldName, true);
                            });
                        }
                    });

                    const enableAutoDescription = {{ submitLabel == 'Ajouter' ? 'true' : 'false' }};
                    const titleInput = document.getElementById('titre');
                    const descriptionInput = document.getElementById('description');
                    const descriptionFeedback = document.getElementById('description-ai-feedback');
                    let autoDescriptionTimer = null;
                    let lastGeneratedTitle = '';
                    let descriptionManuallyEdited = descriptionInput ? descriptionInput.value.trim() !== '' : false;
                    let isAutoUpdatingDescription = false;

                    const setDescriptionFeedback = (message, color) => {
                        if (!descriptionFeedback) return;
                        descriptionFeedback.textContent = message;
                        descriptionFeedback.style.color = color;
                    };

                    const generateDescription = async () => {
                        if (!enableAutoDescription || !titleInput || !descriptionInput) return;

                        const title = titleInput.value.trim();
                        if (title.length < 3) {
                            setDescriptionFeedback('Le titre doit contenir au moins 3 caracteres pour generer la description.', '#b91c1c');
                            return;
                        }

                        if (descriptionManuallyEdited) {
                            setDescriptionFeedback('Description modifiee manuellement. Videz le champ pour reactiver l auto-generation.', '#64748b');
                            return;
                        }

                        if (title === lastGeneratedTitle) {
                            return;
                        }

                        try {
                            setDescriptionFeedback('Generation automatique en cours...', '#475569');

                            const params = new URLSearchParams({ titre: title });
                            const response = await fetch(`{{ path('gestion_offre_description_suggestion') }}?${params.toString()}`, {
                                method: 'GET',
                                headers: {
                                    'X-Requested-With': 'XMLHttpRequest'
                                }
                            });

                            const payload = await response.json();
                            if (!response.ok) {
                                throw new Error(payload.message || 'Impossible de generer la description.');
                            }

                            const generatedDescription = (payload.description || '').trim();
                            if (generatedDescription !== '') {
                                isAutoUpdatingDescription = true;
                                descriptionInput.value = generatedDescription;
                                descriptionInput.dispatchEvent(new Event('input'));
                                isAutoUpdatingDescription = false;
                                lastGeneratedTitle = title;
                                setDescriptionFeedback('Description generee automatiquement depuis le titre.', '#15803d');
                            }
                        } catch (error) {
                            setDescriptionFeedback(error.message || 'Erreur API pendant la generation de description.', '#b91c1c');
                        }
                    };

                    const scheduleDescriptionGeneration = () => {
                        if (!enableAutoDescription) return;

                        if (autoDescriptionTimer) {
                            clearTimeout(autoDescriptionTimer);
                        }

                        autoDescriptionTimer = setTimeout(() => {
                            generateDescription();
                        }, 500);
                    };

                    if (enableAutoDescription && descriptionInput) {
                        descriptionInput.addEventListener('input', () => {
                            if (isAutoUpdatingDescription) {
                                return;
                            }

                            descriptionManuallyEdited = descriptionInput.value.trim() !== '';

                            if (!descriptionManuallyEdited) {
                                lastGeneratedTitle = '';
                                setDescriptionFeedback('Champ vide detecte. L auto-generation est reactivee.', '#475569');
                                scheduleDescriptionGeneration();
                            }
                        });
                    }

                    if (enableAutoDescription && titleInput) {
                        titleInput.addEventListener('input', scheduleDescriptionGeneration);
                        titleInput.addEventListener('blur', scheduleDescriptionGeneration);
                    }

                    // Form submission validation
                    form.addEventListener('submit', function() {
                        Object.keys(fields).forEach(fieldName => {
                            touchedFields.add(fieldName);
                            validateField(fieldName, true);
                        });
                    });
                })();
            </script>
        </main>
    </div>
{% endblock %}


{% extends 'front/base_front.html.twig' %}
{% block title %}Mes Entretiens{% endblock %}
{% block hero_title %}Mes Entretiens{% endblock %}
{% block hero_subtitle %}Consultez tous vos entretiens planifiés et passés{% endblock %}

{% block body %}
    <div class="panel" style="margin-bottom:16px;">
        <div class="section-head">
            <div>
                <h2>Mes entretiens</h2>
                <p>Suivez vos rendez-vous passés et à venir</p>
            </div>
        </div>
        <div class="search-filters">
            <form id="filter-form" class="filter-form" onsubmit="return false;">
                <label style="display:grid;gap:6px;">
                    <span style="font-size:.85rem;color:var(--muted);font-weight:600;">Recherche</span>
                    <input class="search-input" type="text" id="search-input" value="{{ search }}" placeholder="Lieu, type, test..." autocomplete="off">
                </label>
                <label style="display:grid;gap:6px;">
                    <span style="font-size:.85rem;color:var(--muted);font-weight:600;">Type</span>
                    <select class="sort-select" id="type-filter">
                        <option value="">Tous les types</option>
                        <option value="RH" {% if type == 'RH' %}selected{% endif %}>RH</option>
                        <option value="TECHNIQUE" {% if type == 'TECHNIQUE' %}selected{% endif %}>TECHNIQUE</option>
                    </select>
                </label>
                <label style="display:grid;gap:6px;">
                    <span style="font-size:.85rem;color:var(--muted);font-weight:600;">Statut</span>
                    <select class="sort-select" id="statut-filter">
                        <option value="">Tous les statuts</option>
                        <option value="Planifié" {% if statut == 'Planifié' %}selected{% endif %}>Planifié</option>
                        <option value="Terminé" {% if statut == 'Terminé' %}selected{% endif %}>Terminé</option>
                        <option value="Annulé" {% if statut == 'Annulé' %}selected{% endif %}>Annulé</option>
                        <option value="En attente" {% if statut == 'En attente' %}selected{% endif %}>En attente</option>
                    </select>
                </label>
                <div style="display:flex;gap:8px;align-items:end;">
                    <button class="btn btn-primary" type="button" id="btn-filter">Filtrer</button>
                    <button class="btn btn-reset" type="button" id="btn-reset">Reset</button>
                </div>
            </form>
        </div>
        <div id="results-counter" style="padding:0 22px 12px;font-size:.85rem;color:var(--muted);font-weight:600;"></div>
    </div>

    <div class="grid cols-3" id="cards-grid">
        {% for entretien in entretiens %}
            <article class="card"
                data-type="{{ entretien.typeEntretien|lower }}"
                data-statut="{{ entretien.statutEntretien|lower }}"
                data-search="{{ ((entretien.lieu ?? '') ~ ' ' ~ (entretien.typeEntretien ?? '') ~ ' ' ~ (entretien.typeTest ?? '') ~ ' ' ~ (entretien.statutEntretien ?? ''))|lower }}">
                <div style="display:flex;justify-content:space-between;gap:12px;align-items:start;">
                    <div>
                        <div style="font-size:.8rem;color:#6c7693;">Entretien #{{ entretien.id }}</div>
                        <h3 style="margin:.2rem 0 0;">{{ entretien.dateEntretien ? entretien.dateEntretien|date('d/m/Y') : '-' }}</h3>
                    </div>
                    <span class="badge b-blue">{{ entretien.typeEntretien ?? '-' }}</span>
                </div>
                <p style="color:#6c7693; margin:12px 0 0;">{{ entretien.lieu ?? '-' }} - {{ entretien.heureEntretien ? entretien.heureEntretien|date('H:i') : '-' }}</p>
                <div style="margin-top:14px; display:flex; justify-content:space-between; gap:10px; align-items:center;">
                    <span class="badge {% set s = entretien.statutEntretien|lower %}{% if 'termin' in s %}b-green{% elseif 'planifi' in s %}b-blue{% elseif 'annul' in s %}b-red{% else %}b-orange{% endif %}">{{ entretien.statutEntretien ?? '-' }}</span>
                    <a class="btn btn-soft" href="{{ path('app_front_entretien_show', {id: entretien.id}) }}">Voir détail</a>
                </div>
            </article>
        {% else %}
            <div class="panel" style="grid-column:1 / -1;" id="empty-initial"><div class="empty">Aucun entretien trouvé.</div></div>
        {% endfor %}
    </div>
    <div id="empty-filtered" style="display:none;grid-column:1 / -1;">
        <div class="panel"><div class="empty">Aucun entretien ne correspond à votre recherche.</div></div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    var searchInput  = document.getElementById('search-input');
    var typeFilter   = document.getElementById('type-filter');
    var statutFilter = document.getElementById('statut-filter');
    var counter      = document.getElementById('results-counter');
    var emptyFilt    = document.getElementById('empty-filtered');
    var cards        = Array.from(document.querySelectorAll('#cards-grid .card'));
    var debounce;

    function normalize(str) { return (str || '').toLowerCase().trim(); }

    function filterCards() {
        var q      = normalize(searchInput.value);
        var type   = normalize(typeFilter.value);
        var statut = normalize(statutFilter.value);
        var visible = 0;

        cards.forEach(function (card) {
            var matchSearch = q === '' || card.dataset.search.includes(q);
            var matchType   = type === '' || card.dataset.type === type;
            var matchStatut = statut === '' || card.dataset.statut.includes(statut.replace('é','e').replace('é','e'));

            /* accent-insensitive statut match */
            var cardStatut = card.dataset.statut;
            var filterStatut = statut;
            matchStatut = statut === '' || cardStatut === filterStatut ||
                          cardStatut.includes(filterStatut.substring(0, 5));

            var show = matchSearch && matchType && matchStatut;
            card.style.display = show ? '' : 'none';
            if (show) { visible++; }
        });

        counter.textContent = visible + ' entretien' + (visible !== 1 ? 's' : '') + ' trouvé' + (visible !== 1 ? 's' : '');
        emptyFilt.style.display = (visible === 0 && cards.length > 0) ? 'block' : 'none';
    }

    searchInput.addEventListener('input', function () {
        clearTimeout(debounce);
        debounce = setTimeout(filterCards, 300);
    });

    typeFilter.addEventListener('change', filterCards);
    statutFilter.addEventListener('change', filterCards);

    document.getElementById('btn-filter').addEventListener('click', filterCards);

    document.getElementById('btn-reset').addEventListener('click', function () {
        searchInput.value  = '';
        typeFilter.value   = '';
        statutFilter.value = '';
        filterCards();
    });

    /* Run once on load to set counter */
    filterCards();
})();
</script>
{% endblock %}

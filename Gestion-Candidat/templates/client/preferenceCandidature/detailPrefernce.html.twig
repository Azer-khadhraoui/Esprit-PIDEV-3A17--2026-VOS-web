<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Détails Préférence | VOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f7f8fc;
            --panel: #ffffff;
            --line: #e8ebf3;
            --text: #1b2440;
            --muted: #6c7693;
            --primary: #4361ee;
        }

        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: 'Poppins', 'Segoe UI', sans-serif;
            background:
                radial-gradient(1100px 520px at 14% 6%, rgba(67,97,238,0.18), transparent 50%),
                radial-gradient(1200px 680px at 88% 110%, rgba(67,97,238,0.22), transparent 58%),
                linear-gradient(180deg, #f9fbff 0%, #eef3ff 100%);
            color: var(--text);
        }

        @keyframes slideDownSoft {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes riseIn {
            from { opacity: 0; transform: translateY(14px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header {
            background: #fff;
            border-bottom: 1px solid var(--line);
            position: sticky;
            top: 0;
            z-index: 30;
        }

        .header-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 18px;
            gap: 16px;
            animation: slideDownSoft 0.5s ease;
        }

        .brand {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.04em;
        }

        .nav {
            display: flex;
            gap: 24px;
            color: var(--muted);
            font-weight: 600;
        }

        .nav a { text-decoration: none; color: inherit; }
        .nav a.is-active { color: var(--primary); }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .profile-btn {
            border: 0;
            border-radius: 999px;
            padding: 10px 16px;
            background: var(--primary);
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.18s ease, box-shadow 0.2s ease;
            box-shadow: 0 8px 18px rgba(67, 97, 238, 0.24);
        }

        .profile-btn:hover {
            transform: translateY(-1px);
        }

        .logout-btn {
            border: 0;
            border-radius: 999px;
            padding: 10px 16px;
            background: rgba(67, 97, 238, 0.14);
            color: #1d4ed8;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            transition: transform 0.18s ease, background 0.2s ease;
        }

        .logout-btn:hover {
            background: rgba(67, 97, 238, 0.24);
            transform: translateY(-1px);
        }

        .container {
            max-width: 720px;
            margin: 22px auto;
            padding: 0 18px;
            animation: riseIn 0.55s ease;
        }

        h1 {
            margin: 0 0 14px;
            font-size: 2.1rem;
            letter-spacing: -0.02em;
        }

        .detail-card {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        }

        .detail-card h2 {
            margin: 0 0 18px;
            font-size: 1.5rem;
            color: var(--primary);
        }

        .detail-row {
            display: flex;
            padding: 12px 0;
            border-bottom: 1px solid var(--line);
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            font-weight: 600;
            color: var(--muted);
            min-width: 180px;
            font-size: 0.95rem;
        }

        .detail-value {
            color: var(--text);
            flex: 1;
        }

        .detail-value em {
            color: var(--muted);
            font-style: normal;
        }

        .actions {
            display: flex;
            gap: 10px;
            margin-top: 18px;
        }

        .btn {
            flex: 1;
            border: 0;
            border-radius: 10px;
            padding: 11px 16px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            text-decoration: none;
            transition: transform 0.18s ease, filter 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .btn-primary {
            background: var(--primary);
            color: #fff;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            filter: brightness(1.08);
        }

        .btn-secondary {
            background: #e2e8f0;
            color: var(--text);
        }

        .btn-secondary:hover {
            background: #cbd5e1;
            transform: translateY(-2px);
        }

        .btn-danger {
            background: rgba(220, 38, 38, 0.12);
            color: #dc2626;
        }

        .btn-danger:hover {
            background: rgba(220, 38, 38, 0.24);
            transform: translateY(-2px);
        }

        @media (max-width: 680px) {
            .nav { display: none; }
            h1 { font-size: 1.6rem; }
            .detail-row { flex-direction: column; }
            .detail-label { min-width: auto; margin-bottom: 4px; }
            .actions { flex-direction: column; }
        }
    </style>
</head>
<body>
    {{ include('client/_client_header.html.twig', { userName: userName|default('Utilisateur'), activePage: 'preferences' }) }}

    <div class="container">
        <h1>Détails de la Préférence</h1>

        <div class="detail-card">
            <h2>{{ preference.typePosteSouhaite ?? 'Préférence sans titre' }}</h2>

            <div class="detail-row">
                <div class="detail-label">Type de poste:</div>
                <div class="detail-value">{{ preference.typePosteSouhaite ?? '<em>Non renseigné</em>' }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Mode de travail:</div>
                <div class="detail-value">{{ preference.modeTravail ?? '<em>Non renseigné</em>' }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Disponibilité:</div>
                <div class="detail-value">{{ preference.disponibilite ?? '<em>Non renseigné</em>' }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Mobilité géographique:</div>
                <div class="detail-value">{{ preference.mobiliteGeographique ?? '<em>Non renseigné</em>' }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Prêt au déplacement:</div>
                <div class="detail-value">{{ preference.pretDeplacement ?? '<em>Non renseigné</em>' }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Type de contrat souhaité:</div>
                <div class="detail-value">{{ preference.typeContratSouhaite ?? '<em>Non renseigné</em>' }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Prétention salariale:</div>
                <div class="detail-value">
                    {% if preference.pretentionSalariale %}
                        {{ preference.pretentionSalariale }} TND
                    {% else %}
                        <em>Non renseigné</em>
                    {% endif %}
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Date de disponibilité:</div>
                <div class="detail-value">
                    {% if preference.dateDisponibilite %}
                        {{ preference.dateDisponibilite|date('d/m/Y') }}
                    {% else %}
                        <em>Non renseigné</em>
                    {% endif %}
                </div>
            </div>

            <div class="actions">
                <a href="{{ path('app_client_preference_edit', {id_preference: preference.idPreference}) }}" class="btn btn-primary">
                    ✏️ Modifier
                </a>
                <a href="{{ path('app_client_preferences') }}" class="btn btn-secondary">Retour</a>
                <form method="POST" action="{{ path('app_client_preference_delete', {id_preference: preference.idPreference}) }}" style="flex: 1;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette préférence?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ preference.idPreference) }}">
                    <button type="submit" class="btn btn-danger" style="width: 100%; margin: 0;">🗑️ Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
